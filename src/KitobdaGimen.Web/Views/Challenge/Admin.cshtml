@using System.Text.Json
@using KitobdaGimen.Application.Common
@using KitobdaGimen.Application.Features.Challenge.Dtos
@model KitobdaGimen.Web.Models.ChallengeAdminViewModel
@{
    ViewData["Title"] ??= "Challenge — admin";
    ViewData["Robots"] = "noindex, nofollow";

    string Initial(string name) => string.IsNullOrWhiteSpace(name) ? "?" : name.Trim()[..1].ToUpper();
    string MedalIcon(int rank)
    {
        var cls = rank switch { 1 => "ch-medal-gold", 2 => "ch-medal-silver", _ => "ch-medal-bronze" };
        return $"<span class=\"material-symbols-outlined ch-medal-ic {cls}\">workspace_premium</span>";
    }

    var (prevY, prevM) = ChallengeCalendar.PreviousPeriod(Model.Year, Model.Month);
    var (nextY, nextM) = ChallengeCalendar.NextPeriod(Model.Year, Model.Month);
    var podiumOrder = new[] { 2, 1, 3 };

    var jsonOpts = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
    var coversJson = Html.Raw(JsonSerializer.Serialize(Model.DecorationCovers, jsonOpts));
    var standingsJson = Html.Raw(JsonSerializer.Serialize(Model.Standings, jsonOpts));

    var msg = TempData["ChallengeMsg"] as string;
}

@Html.AntiForgeryToken()
<div class="ch-decor" data-ch-decor aria-hidden="true"></div>

<div class="container page ch-page ch-admin">
    <header class="ch-head">
        <div>
            <h1 class="section-title" style="margin:0">
                <span class="material-symbols-outlined" style="vertical-align:-4px;color:var(--accent)">visibility</span>
                Challenge — admin oldindan ko'rish
            </h1>
            <p class="muted ch-sub">
                G'oliblar qanday ko'rinishini oldindan ko'ring, oyni e'lon qiling.
                @if (Model.IsSuperAdmin)
                {
                    <text>Super admin sifatida 1-o'rin g'olibiga kitob sovg'a qila olasiz.</text>
                }
            </p>
        </div>
        <a class="btn btn-outline" href="/challenge">
            <span class="material-symbols-outlined" style="vertical-align:-4px">arrow_back</span>
            Challenge sahifasi
        </a>
    </header>

    @if (!string.IsNullOrEmpty(msg))
    {
        <div class="card ch-msg">@msg</div>
    }

    @* Davr navigatsiyasi *@
    <div class="ch-period-nav card">
        <a class="btn btn-sm btn-outline" href="/challenge/admin?year=@prevY&month=@prevM">
            <span class="material-symbols-outlined" style="vertical-align:-4px">chevron_left</span> Oldingi davr
        </a>
        <div class="ch-period-label">
            <strong>@Model.PeriodLabel</strong>
            <span class="muted">
                @if (Model.Announced is not null)
                {
                    <span class="ch-status is-announced"><span class="material-symbols-outlined">check_circle</span> E'lon qilingan</span>
                }
                else if (Model.IsPeriodCompleted)
                {
                    <span class="ch-status is-completed"><span class="material-symbols-outlined">hourglass_top</span> Yakunlangan — e'lon qilinmagan</span>
                }
                else
                {
                    <span class="ch-status is-live"><span class="material-symbols-outlined">radio_button_checked</span> Davom etmoqda (jonli)</span>
                }
            </span>
        </div>
        <a class="btn btn-sm btn-outline" href="/challenge/admin?year=@nextY&month=@nextM">
            Keyingi davr <span class="material-symbols-outlined" style="vertical-align:-4px">chevron_right</span>
        </a>
    </div>

    @* Amallar *@
    <div class="ch-actions">
        <button type="button" class="btn btn-accent" data-preview-modal>
            <span class="material-symbols-outlined" style="vertical-align:-4px">slideshow</span>
            G'olib modalini ko'rish (preview)
        </button>
        <button type="button" class="btn btn-outline" data-festive-toggle>
            <span class="material-symbols-outlined" style="vertical-align:-4px">celebration</span>
            Bayram ko'rinishini sinash
        </button>
        @if (Model.Announced is null && Model.IsSuperAdmin)
        {
            <button type="button" class="btn btn-primary" data-announce-open @(Model.Standings.Count == 0 ? "disabled" : "")>
                <span class="material-symbols-outlined" style="vertical-align:-4px">campaign</span>
                G'oliblarni e'lon qilish
            </button>
        }
    </div>

    @if (Model.Announced is null && !Model.IsSuperAdmin)
    {
        <p class="muted">
            <span class="material-symbols-outlined" style="vertical-align:-4px;font-size:18px">info</span>
            G'oliblar odatda davr oxirida avtomatik e'lon qilinadi. Avtomatik jarayon ishlamay qolsa,
            faqat <strong>super admin</strong> qo'lda e'lon qila oladi.
        </p>
    }

    @* Reyting preview (podium) *@
    <section class="ch-section">
        <h2 class="ch-h2"><span class="material-symbols-outlined">leaderboard</span> Reyting (top 3)</h2>
        @if (Model.Standings.Count == 0)
        {
            <div class="card ch-empty">
                <span class="material-symbols-outlined">auto_stories</span>
                <h3>Bu davrda o'qish yozuvi yo'q</h3>
                <p class="muted">Bu oy uchun hali reyting shakllanmagan.</p>
            </div>
        }
        else
        {
            <div class="ch-podium">
                @foreach (var slot in podiumOrder)
                {
                    var u = Model.Standings.FirstOrDefault(x => x.Rank == slot);
                    if (u is null) { continue; }
                    <div class="ch-podium-card ch-place-@u.Rank">
                        <div class="ch-medal">@Html.Raw(MedalIcon(u.Rank))</div>
                        <div class="ch-avatar-wrap">
                            @if (!string.IsNullOrEmpty(u.AvatarUrl))
                            {
                                <img class="avatar ch-avatar" src="@u.AvatarUrl" alt="@u.FullName" referrerpolicy="no-referrer" />
                            }
                            else
                            {
                                <span class="avatar ch-avatar">@Initial(u.FullName)</span>
                            }
                            <span class="ch-rank-badge">@u.Rank</span>
                        </div>
                        <div class="ch-name" title="@u.FullName">@u.FullName</div>
                        <div class="ch-score"><strong>@u.PagesRead</strong> bet</div>
                        <div class="ch-detail muted">@u.BooksRead kitob · kuniga @u.AvgPagesPerDay bet</div>
                        <div class="ch-pillar"></div>
                    </div>
                }
            </div>
        }
    </section>

    @* Super admin: sovg'a kitob (faqat e'lon qilingandan keyin — 1-, 2-, 3-o'rin uchun) *@
    @if (Model.IsSuperAdmin && Model.Announced is not null && Model.Announced.Winners.Count > 0)
    {
        <section class="ch-section">
            <h2 class="ch-h2"><span class="material-symbols-outlined">redeem</span> G'oliblarga kitob sovg'a qilish</h2>
            <p class="muted ch-note">Har bir g'olibga (1-, 2-, 3-o'rin) bittadan kitob sovg'a qilishingiz mumkin.</p>
            @foreach (var win in Model.Announced.Winners.OrderBy(w => w.Rank))
            {
                <div class="card ch-gift-form" style="margin-bottom:14px">
                    <p class="muted">
                        @Html.Raw(MedalIcon(win.Rank)) <strong>@win.Rank-o'rin — @win.FullName</strong>.
                        @if (!string.IsNullOrEmpty(win.GiftBookTitle))
                        {
                            <text> Joriy sovg'a: <strong>@win.GiftBookTitle</strong>.</text>
                        }
                    </p>
                    <form method="post" action="/challenge/admin/gift" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="year" value="@Model.Year" />
                        <input type="hidden" name="month" value="@Model.Month" />
                        <input type="hidden" name="rank" value="@win.Rank" />
                        <div class="ch-form-row">
                            <label>Kitob nomi
                                <input type="text" name="title" value="@win.GiftBookTitle" placeholder="Masalan: Atom odatlari" required />
                            </label>
                            <label>Muallif
                                <input type="text" name="author" value="@win.GiftBookAuthor" placeholder="Masalan: Jeyms Klir" />
                            </label>
                        </div>
                        <div class="ch-form-row">
                            <label>Muqova rasmi (yuklash)
                                <input type="file" name="cover" accept="image/*" />
                            </label>
                        </div>
                        <button type="submit" class="btn btn-accent">
                            <span class="material-symbols-outlined" style="vertical-align:-4px">save</span>
                            @win.Rank-o'rin sovg'asini saqlash
                        </button>
                    </form>
                    @if (!string.IsNullOrEmpty(win.GiftBookCoverUrl))
                    {
                        <div class="ch-gift" style="margin-top:14px;max-width:320px">
                            <img src="@win.GiftBookCoverUrl" alt="@win.GiftBookTitle" referrerpolicy="no-referrer" />
                            <div>
                                <span class="ch-gift-label"><span class="material-symbols-outlined">redeem</span> Joriy sovg'a</span>
                                <strong>@win.GiftBookTitle</strong>
                                <span class="muted">@win.GiftBookAuthor</span>
                            </div>
                        </div>
                    }
                </div>
            }
        </section>
    }
    else if (Model.IsSuperAdmin && Model.Announced is null)
    {
        <p class="muted">Sovg'a kitob kiritish uchun avval oyni e'lon qiling.</p>
    }
</div>

@* Preview modal (standings'dan quriladi) *@
<div class="ch-modal" data-preview-modal-box hidden>
    <div class="ch-modal-backdrop" data-preview-close></div>
    <div class="ch-modal-box" role="dialog" aria-modal="true">
        <div class="ch-modal-header">
            <div class="ch-modal-confetti" aria-hidden="true"></div>
            <button type="button" class="ch-modal-x" data-preview-close aria-label="Yopish">
                <span class="material-symbols-outlined">close</span>
            </button>
            <span class="material-symbols-outlined ch-modal-crown">workspace_premium</span>
            <h2 class="ch-modal-title">@Model.PeriodLabel g'oliblari (preview)</h2>
            <p class="ch-modal-sub">Foydalanuvchilar shu ko'rinishni ko'radi.</p>
        </div>
        <div class="ch-modal-winners" data-preview-winners></div>
        <button type="button" class="btn btn-accent" data-preview-close>Yopish</button>
    </div>
</div>

@* E'lon qilish oynasi — g'oliblarga sovg'a kitob biriktirib, birga e'lon qilish *@
@if (Model.Announced is null && Model.IsSuperAdmin && Model.Standings.Count > 0)
{
    <div class="ch-modal" data-announce-modal hidden>
        <div class="ch-modal-backdrop" data-announce-close></div>
        <div class="ch-modal-box" role="dialog" aria-modal="true">
            <div class="ch-modal-header">
                <button type="button" class="ch-modal-x" data-announce-close aria-label="Yopish">
                    <span class="material-symbols-outlined">close</span>
                </button>
                <span class="material-symbols-outlined ch-modal-crown">campaign</span>
                <h2 class="ch-modal-title">@Model.PeriodLabel g'oliblarini e'lon qilish</h2>
                <p class="ch-modal-sub">Har bir g'olibga sovg'a kitob biriktiring (ixtiyoriy), so'ng e'lon qiling.</p>
            </div>
            <form method="post" action="/challenge/admin/announce" enctype="multipart/form-data" class="ch-announce-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="year" value="@Model.Year" />
                <input type="hidden" name="month" value="@Model.Month" />
                @foreach (var u in Model.Standings.OrderBy(x => x.Rank))
                {
                    <div class="card ch-gift-form" style="margin:0 16px 12px;text-align:left">
                        <p class="muted">
                            @Html.Raw(MedalIcon(u.Rank)) <strong>@u.Rank-o'rin — @u.FullName</strong>
                            <span class="muted">· @u.PagesRead bet · @u.BooksRead kitob</span>
                        </p>
                        <div class="ch-form-row">
                            <label>Kitob nomi
                                <input type="text" name="title_@u.Rank" placeholder="Masalan: Atom odatlari" />
                            </label>
                            <label>Muallif
                                <input type="text" name="author_@u.Rank" placeholder="Masalan: Jeyms Klir" />
                            </label>
                        </div>
                        <div class="ch-form-row">
                            <label>Muqova rasmi (yuklash)
                                <input type="file" name="cover_@u.Rank" accept="image/*" />
                            </label>
                        </div>
                    </div>
                }
                <div style="text-align:center;padding:6px 16px 0">
                    <button type="submit" class="btn btn-primary"
                            onclick="return confirm('@Model.PeriodLabel uchun g\'oliblarni e\'lon qilishni tasdiqlaysizmi? Bu amalni orqaga qaytarib bo\'lmaydi.');">
                        <span class="material-symbols-outlined" style="vertical-align:-4px">campaign</span>
                        E'lon qilish va sovg'alarni saqlash
                    </button>
                </div>
            </form>
        </div>
    </div>
}

<link rel="stylesheet" href="/css/challenge.css" asp-append-version="true" />

@section Scripts {
    <script type="application/json" data-ch-data>
        { "covers": @coversJson, "daily": [], "monthly": [], "announced": null, "announceKey": "" }
    </script>
    <script type="module" src="~/js/challenge.js" asp-append-version="true"></script>
    <script type="application/json" data-preview-standings>@standingsJson</script>
    <script src="~/js/challenge-admin.js" asp-append-version="true"></script>
}
