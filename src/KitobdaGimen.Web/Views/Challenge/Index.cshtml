@using System.Text.Json
@using KitobdaGimen.Application.Features.Challenge.Dtos
@using KitobdaGimen.Domain.Enums
@model KitobdaGimen.Web.Models.ChallengePageViewModel
@{
    ViewData["Title"] ??= "Challenge";

    string ProfileUrl(int userId, string? username) =>
        "/profile/" + (string.IsNullOrWhiteSpace(username) ? userId.ToString() : username);

    string Initial(string name) => string.IsNullOrWhiteSpace(name) ? "?" : name.Trim()[..1].ToUpper();

    // Zamonaviy medal ikonlari (emoji o'rniga)
    string MedalIcon(int rank)
    {
        var (icon, cls) = rank switch
        {
            1 => ("workspace_premium", "ch-medal-gold"),
            2 => ("workspace_premium", "ch-medal-silver"),
            _ => ("workspace_premium", "ch-medal-bronze")
        };
        return $"<span class=\"material-symbols-outlined ch-medal-ic {cls}\">{icon}</span>";
    }

    // G'olib kartochkasi uchun bezak ikoni (turli xil)
    string DecoIcon(int rank) => rank switch
    {
        1 => "emoji_events",
        2 => "workspace_premium",
        _ => "military_tech"
    };

    var announced = Model.Announced;
    var festive = announced?.IsAnnouncementActive == true;

    var podiumOrder = new[] { 2, 1, 3 };

    // Mijoz JS uchun ma'lumotlar
    var jsonOpts = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
    var coversJson = Html.Raw(JsonSerializer.Serialize(Model.DecorationCovers, jsonOpts));
    var dailyJson = Html.Raw(JsonSerializer.Serialize(Model.Stats.Daily, jsonOpts));
    var yearJson = Html.Raw(JsonSerializer.Serialize(Model.Stats.Year, jsonOpts));
    var availableYearsJson = Html.Raw(JsonSerializer.Serialize(Model.Stats.AvailableYears, jsonOpts));
    var announcedJson = Html.Raw(JsonSerializer.Serialize(announced, jsonOpts));
    var announceKey = announced is null ? "" : $"{announced.Year}-{announced.Month}-{announced.AnnouncedAt.Ticks}";
}

@Html.AntiForgeryToken()

@if (festive)
{
    <div class="ch-festive" data-ch-festive aria-hidden="true"></div>
}

<div class="container page ch-page @(festive ? "is-festive" : "")">
    <header class="ch-head">
        <div>
            <h1 class="section-title" style="margin:0">
                <span class="material-symbols-outlined ic-accent" style="vertical-align:-4px">military_tech</span>
                Challenge
            </h1>
            <p class="muted ch-sub">
                Har bir davr — 1 oy: oyning 1-kunidan o'sha oyning oxirgi kunigacha. Eng ko'p
                kitob o'qigan 3 kitobxon g'olib bo'ladi va oyning oxirgi kunida e'lon qilinadi.
                Joriy davr: <strong>@Model.CurrentPeriodLabel</strong>.
            </p>
        </div>
        @if (Model.MyRole >= UserRole.Admin)
        {
            <div class="ch-head-actions">
                <a class="btn btn-outline ch-admin-link" href="/challenge/admin">
                    <span class="material-symbols-outlined" style="vertical-align:-4px">visibility</span>
                    Admin ko'rinishi
                </a>
                @if (Model.MyRole == UserRole.SuperAdmin)
                {
                    <button type="button" class="btn btn-primary ch-preview-btn" data-sa-preview>
                        <span class="material-symbols-outlined" style="vertical-align:-4px">science</span>
                        Oldindan sinab ko'rish
                    </button>
                }
            </div>
        }
    </header>

    @if (festive && announced is not null)
    {
        <div class="ch-banner">
            <span class="material-symbols-outlined ch-banner-ic">celebration</span>
            <div>
                <strong>@announced.PeriodLabel challenge g'oliblari e'lon qilindi!</strong>
                <span class="muted">Tabriklaymiz!</span>
            </div>
            <button type="button" class="btn btn-accent btn-sm" data-open-winners>Ko'rish</button>
        </div>
    }

    @* ================= JORIY OY JONLI REYTING ================= *@
    <section class="ch-section">
        <h2 class="ch-h2">
            <span class="material-symbols-outlined">trending_up</span>
            Joriy davr reytingi — @Model.CurrentPeriodLabel
        </h2>
        <p class="muted ch-note">Bu — hozircha yetakchilar. Davr (1 oy) tugagach g'oliblar rasman e'lon qilinadi.</p>

        @if (Model.LiveStandings.Count == 0)
        {
            <div class="card ch-empty">
                <span class="material-symbols-outlined">auto_stories</span>
                <h3>Hozircha bo'sh</h3>
                <p class="muted">Bu davrda hali hech kim kitob o'qimadi. Kutubxonadan kitob qo'shib,
                    har kuni o'qiganingizni belgilang — birinchi bo'ling!</p>
                <a class="btn btn-accent" href="/reading-books">Kutubxonaga o'tish</a>
            </div>
        }
        else
        {
            <div class="ch-podium">
                @foreach (var slot in podiumOrder)
                {
                    var u = Model.LiveStandings.FirstOrDefault(x => x.Rank == slot);
                    if (u is null) { continue; }
                    <a class="ch-podium-card ch-place-@u.Rank" href="@ProfileUrl(u.UserId, u.Username)">
                        <div class="ch-medal">@Html.Raw(MedalIcon(u.Rank))</div>
                        <div class="ch-avatar-wrap">
                            @if (!string.IsNullOrEmpty(u.AvatarUrl))
                            {
                                <img class="avatar ch-avatar" src="@u.AvatarUrl" alt="@u.FullName" referrerpolicy="no-referrer" />
                            }
                            else
                            {
                                <span class="avatar ch-avatar">@Initial(u.FullName)</span>
                            }
                            <span class="ch-rank-badge">@u.Rank</span>
                        </div>
                        <div class="ch-name" title="@u.FullName">@u.FullName</div>
                        <div class="ch-score"><strong>@u.PagesRead</strong> bet</div>
                        <div class="ch-detail muted">@u.BooksRead kitob · kuniga @u.AvgPagesPerDay bet</div>
                        <div class="ch-pillar"></div>
                    </a>
                }
            </div>

            @if (Model.OtherStandings.Count > 0)
            {
                <h3 class="ch-h3">
                    <span class="material-symbols-outlined">format_list_numbered</span>
                    Reyting davomi
                </h3>
                <ol class="ch-rank-list">
                    @foreach (var u in Model.OtherStandings)
                    {
                        var isMe = Model.CurrentUserId == u.UserId;
                        <li class="ch-rank-row @(isMe ? "is-me" : "")">
                            <span class="ch-rank-num">@u.Rank</span>
                            <a class="ch-rank-user" href="@ProfileUrl(u.UserId, u.Username)">
                                @if (!string.IsNullOrEmpty(u.AvatarUrl))
                                {
                                    <img class="avatar ch-rank-avatar" src="@u.AvatarUrl" alt="@u.FullName" referrerpolicy="no-referrer" />
                                }
                                else
                                {
                                    <span class="avatar ch-rank-avatar">@Initial(u.FullName)</span>
                                }
                                <span class="ch-rank-name" title="@u.FullName">@u.FullName@(isMe ? " (siz)" : "")</span>
                            </a>
                            <span class="ch-rank-score"><strong>@u.PagesRead</strong> bet · @u.BooksRead kitob</span>
                        </li>
                    }
                </ol>
            }

            @if (Model.MyStanding is not null)
            {
                <div class="ch-my-rank" title="Sizning o'rningiz">
                    <span class="material-symbols-outlined ch-my-rank-ic">person_pin_circle</span>
                    <span class="ch-rank-num ch-my-rank-num">@Model.MyStanding.Rank</span>
                    <span class="ch-my-rank-label">Siz — <strong>@Model.MyStanding.Rank-o'rin</strong></span>
                    <span class="ch-rank-score"><strong>@Model.MyStanding.PagesRead</strong> bet · @Model.MyStanding.BooksRead kitob</span>
                </div>
            }
        }
    </section>

    @* ================= E'LON QILINGAN G'OLIBLAR ================= *@
    @if (announced is not null)
    {
        <section class="ch-section ch-announced">
            <h2 class="ch-h2">
                <span class="material-symbols-outlined">emoji_events</span>
                G'oliblar — @announced.PeriodLabel
            </h2>
            <div class="ch-winners-grid">
                @foreach (var w in announced.Winners)
                {
                    <div class="card ch-winner ch-place-@w.Rank" data-winner-id="@w.Id">
                        <span class="material-symbols-outlined ch-winner-deco">@DecoIcon(w.Rank)</span>
                        <div class="ch-winner-top">
                            <span class="ch-medal">@Html.Raw(MedalIcon(w.Rank))</span>
                            <a class="ch-winner-user" href="@ProfileUrl(w.UserId, w.Username)">
                                @if (!string.IsNullOrEmpty(w.AvatarUrl))
                                {
                                    <img class="avatar ch-avatar" src="@w.AvatarUrl" alt="@w.FullName" referrerpolicy="no-referrer" />
                                }
                                else
                                {
                                    <span class="avatar ch-avatar">@Initial(w.FullName)</span>
                                }
                                <span>
                                    <span class="ch-name">@w.FullName</span>
                                    <span class="ch-detail muted">@w.Rank-o'rin</span>
                                </span>
                            </a>
                        </div>
                        <div class="ch-winner-stats">
                            <div><strong>@w.PagesRead</strong><span class="muted">bet</span></div>
                            <div><strong>@w.BooksRead</strong><span class="muted">kitob</span></div>
                            <div><strong>@w.AvgPagesPerDay</strong><span class="muted">bet/kun</span></div>
                        </div>

                        @if (!string.IsNullOrEmpty(w.GiftBookTitle))
                        {
                            <div class="ch-gift">
                                @if (!string.IsNullOrEmpty(w.GiftBookCoverUrl))
                                {
                                    <img src="@w.GiftBookCoverUrl" alt="@w.GiftBookTitle" referrerpolicy="no-referrer" />
                                }
                                else
                                {
                                    <span class="ch-gift-noimg"><span class="material-symbols-outlined">menu_book</span></span>
                                }
                                <div>
                                    <span class="ch-gift-label"><span class="material-symbols-outlined">redeem</span> Sovg'a kitob</span>
                                    <strong>@w.GiftBookTitle</strong>
                                    @if (!string.IsNullOrEmpty(w.GiftBookAuthor))
                                    {
                                        <span class="muted">@w.GiftBookAuthor</span>
                                    }
                                </div>
                            </div>
                        }

                        <button type="button"
                                class="ch-like-btn @(w.LikedByCurrentUser ? "is-liked" : "")"
                                data-like-btn data-winner-id="@w.Id"
                                aria-pressed="@(w.LikedByCurrentUser ? "true" : "false")">
                            <span class="material-symbols-outlined">favorite</span>
                            <span data-like-count>@w.LikeCount</span>
                        </button>
                    </div>
                }
            </div>
        </section>
    }

    @* ================= STATISTIKA — GitHub uslubidagi heatmap ================= *@
    <section class="ch-section ch-stats-section">
        <h2 class="ch-h2">
            <span class="material-symbols-outlined">insights</span>
            Mening o'qish statistikam
        </h2>

        <div class="ch-stats-tabs">
            <button type="button" class="ch-stat-tab" data-stat-tab="year">
                <span class="material-symbols-outlined">calendar_month</span> 1 yillik
            </button>
            <button type="button" class="ch-stat-tab" data-stat-tab="daily">
                <span class="material-symbols-outlined">date_range</span> 30 kunlik
            </button>
        </div>

        <div class="ch-stats-bar">
            <div class="ch-stat-summary" data-stat-summary></div>
            <div class="ch-year-nav" data-year-nav>
                <button type="button" data-year-prev aria-label="Avvalgi yil">
                    <span class="material-symbols-outlined">chevron_left</span>
                </button>
                <span class="ch-year-label" data-year-label></span>
                <button type="button" data-year-next aria-label="Keyingi yil">
                    <span class="material-symbols-outlined">chevron_right</span>
                </button>
            </div>
        </div>

        <div class="ch-heatmap" data-heatmap></div>

        <div class="gh-legend">
            <span>Kam</span>
            <span class="gh-day lv-0"></span>
            <span class="gh-day lv-1"></span>
            <span class="gh-day lv-2"></span>
            <span class="gh-day lv-3"></span>
            <span class="gh-day lv-4"></span>
            <span>Ko'p</span>
        </div>

        <div class="gh-detail" data-day-detail></div>
    </section>
</div>

@* ================= G'OLIBLAR MODALI (yangi dizayn) ================= *@
@if (announced is not null)
{
    <div class="ch-modal" data-winners-modal hidden>
        <div class="ch-modal-backdrop" data-modal-close></div>
        <div class="ch-modal-box" role="dialog" aria-modal="true" aria-label="Challenge g'oliblari">
            <div class="ch-modal-header">
                <div class="ch-modal-confetti" aria-hidden="true"></div>
                <button type="button" class="ch-modal-x" data-modal-close aria-label="Yopish">
                    <span class="material-symbols-outlined">close</span>
                </button>
                <span class="material-symbols-outlined ch-modal-crown">workspace_premium</span>
                <h2 class="ch-modal-title">@announced.PeriodLabel g'oliblari</h2>
                <p class="ch-modal-sub">Bu oyda eng ko'p kitob o'qigan kitobxonlar. Tabriklaymiz!</p>
            </div>
            <div class="ch-modal-winners">
                @foreach (var w in announced.Winners)
                {
                    <div class="ch-modal-winner ch-place-@w.Rank">
                        <div class="ch-medal">@Html.Raw(MedalIcon(w.Rank))</div>
                        @if (!string.IsNullOrEmpty(w.AvatarUrl))
                        {
                            <img class="avatar ch-avatar" src="@w.AvatarUrl" alt="@w.FullName" referrerpolicy="no-referrer" />
                        }
                        else
                        {
                            <span class="avatar ch-avatar">@Initial(w.FullName)</span>
                        }
                        <div class="ch-modal-name">@w.FullName</div>
                        <div class="ch-modal-stats muted">
                            @w.PagesRead bet · @w.BooksRead kitob · kuniga @w.AvgPagesPerDay bet
                        </div>
                        @if (!string.IsNullOrEmpty(w.GiftBookTitle))
                        {
                            <div class="ch-modal-gift">
                                @if (!string.IsNullOrEmpty(w.GiftBookCoverUrl))
                                {
                                    <img src="@w.GiftBookCoverUrl" alt="@w.GiftBookTitle" referrerpolicy="no-referrer" />
                                }
                                else
                                {
                                    <span class="ch-modal-gift-noimg"><span class="material-symbols-outlined">menu_book</span></span>
                                }
                                <div class="ch-modal-gift-info">
                                    <span class="ch-modal-gift-label"><span class="material-symbols-outlined">redeem</span> Sovg'a kitob</span>
                                    <span class="ch-modal-gift-title">@w.GiftBookTitle</span>
                                    @if (!string.IsNullOrEmpty(w.GiftBookAuthor))
                                    {
                                        <span class="ch-modal-gift-author">@w.GiftBookAuthor</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
            <button type="button" class="btn btn-accent" data-modal-close>Yopish</button>
        </div>
    </div>
}

<link rel="stylesheet" href="/css/challenge.css" asp-append-version="true" />

@* ================= SUPER ADMIN: OLDINDAN SINAB KO'RISH (ephemeral) ================= *@
@if (Model.MyRole == UserRole.SuperAdmin)
{
    var liveJson = Html.Raw(JsonSerializer.Serialize(Model.LiveStandings, jsonOpts));
    <div class="ch-sa-preview" data-sa-preview-overlay hidden>
        <div class="ch-sa-preview-inner">
            <header class="ch-sa-preview-head">
                <div>
                    <h2 class="ch-sa-preview-title">
                        <span class="material-symbols-outlined">science</span>
                        Sinov rejimi — g'oliblarni oldindan ko'rish
                    </h2>
                    <p class="muted">
                        Joriy davr (<strong>@Model.CurrentPeriodLabel</strong>) yetakchilari g'olib
                        sifatida ko'rsatilmoqda. Bu yerda sovg'a kitob berish va bayram ko'rinishini
                        sinab ko'rasiz. <strong>Hech narsa saqlanmaydi</strong> — «Orqaga qaytish»
                        tugmasi hammasini avvalgi holatga qaytaradi.
                    </p>
                </div>
                <button type="button" class="btn btn-primary ch-sa-back" data-sa-preview-back>
                    <span class="material-symbols-outlined" style="vertical-align:-4px">arrow_back</span>
                    Orqaga qaytish
                </button>
            </header>

            <div class="ch-sa-empty" data-sa-empty hidden>
                <span class="material-symbols-outlined">auto_stories</span>
                <p class="muted">Joriy davrda hali reyting bo'sh — sinash uchun g'olib yo'q.</p>
            </div>

            <section class="ch-sa-section" data-sa-body>
                <h3 class="ch-h3"><span class="material-symbols-outlined">emoji_events</span> G'oliblar (joriy yetakchilar)</h3>
                <div class="ch-sa-winners" data-sa-winners></div>

                <h3 class="ch-h3"><span class="material-symbols-outlined">redeem</span> Sovg'a kitoblarni tayinlash</h3>
                <p class="muted">Har bir g'olibga bittadan kitob tayinlang — quyida «kimga qaysi kitob beriladi» ko'rinadi.</p>
                <div class="ch-sa-gift-forms" data-sa-gift-forms></div>

                <div class="ch-sa-summary" data-sa-summary></div>

                <div class="ch-sa-controls">
                    <button type="button" class="btn btn-accent" data-sa-festive>
                        <span class="material-symbols-outlined" style="vertical-align:-4px">celebration</span>
                        Bayram ko'rinishini yoqish / o'chirish
                    </button>
                    <button type="button" class="btn btn-outline" data-sa-open-modal>
                        <span class="material-symbols-outlined" style="vertical-align:-4px">slideshow</span>
                        G'olib modalini ko'rish
                    </button>
                </div>
            </section>
        </div>
    </div>

    <script type="application/json" data-sa-live>@liveJson</script>
    <script src="~/js/challenge-preview.js" asp-append-version="true"></script>
}

@section Scripts {
    <script type="application/json" data-ch-data>
        {
            "covers": @coversJson,
            "daily": @dailyJson,
            "year": @yearJson,
            "availableYears": @availableYearsJson,
            "monthPages": @Model.Stats.MonthPages,
            "monthActiveDays": @Model.Stats.MonthActiveDays,
            "monthBooks": @Model.Stats.MonthBooks,
            "announced": @announcedJson,
            "announceKey": "@announceKey"
        }
    </script>
    <script type="module" src="~/js/challenge.js" asp-append-version="true"></script>
}
