                <div class="lp-podium-card">
                    <span class="lp-medal silver">2</span>
                    <h3>2-o'rin</h3>
                    <p>Oyning kumush kitobxoni</p>
                    <span class="lp-prize"><span class="material-symbols-outlined">redeem</span> Sovg'a kitob</span>
                </div>
                <div class="lp-podium-card is-first">
                    <span class="lp-medal gold">1</span>
                    <h3>1-o'rin</h3>
                    <p>Oyning eng faol kitobxoni</p>
                    <span class="lp-prize"><span class="material-symbols-outlined">redeem</span> Sovg'a kitob</span>
                </div>
                <div class="lp-podium-card">
                    <span class="lp-medal bronze">3</span>
                    <h3>3-o'rin</h3>
                    <p>Oyning bronza kitobxoni</p>
                    <span class="lp-prize"><span class="material-symbols-outlined">redeem</span> Sovg'a kitob</span>
                </div>
            </div>

