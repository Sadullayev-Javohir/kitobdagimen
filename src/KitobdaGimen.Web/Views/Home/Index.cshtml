@inject KitobdaGimen.Application.Common.Interfaces.ICurrentUserService CurrentUser
@{
    ViewData["Title"] = "O'zbek kitobxonlari uchun ijtimoiy platforma";
    ViewData["HideChrome"] = true;

    // --- SEO ---
    var seoBase = $"{Context.Request.Scheme}://{Context.Request.Host}";
    ViewData["Description"] = "kitobdagimen.uz — o'zbek kitobxonlari uchun bepul ijtimoiy platforma. Kitob haqida post yozing, sevimli iqtiboslarni ulashing, oylik kitobxonlik musobaqasida qatnashib kitob yutib oling, o'qish maqsadlari qo'ying va boshqa kitobsevarlar bilan real vaqtda suhbatlashing.";
    // Barcha landing manzillari (/, /landing, /Home/Landing) bitta kanonik URL'ga birlashtiriladi.
    ViewData["Canonical"] = seoBase + "/";
    ViewData["JsonLd"] = KitobdaGimen.Web.Seo.SeoJsonLd.Website(seoBase);

    var isAuth = CurrentUser.IsAuthenticated;
    // Auth holatига qarab asosiy harakat: kirgan foydalanuvchi tasmaга, anonim — Google login.
    var primaryHref = isAuth ? "/feed" : "/auth/google-login";
    var primaryLabel = isAuth ? "Tasmaga o'tish" : "Kirish";
}

<div class="lp">
    <header class="lp-nav">
        <a class="brand" href="/">
            <img class="brand-logo" src="~/img/logo.svg" alt="kitobdagimen.uz logotipi" />
            <span class="brand-text">kitobdagimen<span style="color:var(--accent)">.uz</span></span>
        </a>
        <nav class="lp-nav-links">
            <a href="#imkoniyatlar">Imkoniyatlar</a>
            <a href="#challenge">Challenge</a>
            <a href="#qanday">Qanday ishlaydi</a>
            <a href="/qollanma">Qo'llanma</a>
            <a href="#savol">Savollar</a>
            <a class="btn btn-accent btn-sm" href="@primaryHref">@primaryLabel</a>
        </nav>
    </header>

    @if (Context.Request.Query.ContainsKey("xato"))
    {
        <div class="lp-alert">Kirishda xatolik yuz berdi. Qaytadan urinib ko'ring.</div>
    }

    <section class="lp-hero">
        <span class="lp-eyebrow">O'zbek kitobxonlari uchun ijtimoiy platforma</span>
        <h1>O'qigan kitoblaringiz bilan yashaydigan jamiyat</h1>
        <p class="lp-sub">
            kitobdagimen.uz — post yozib fikrlaringizni ulashing, sevimli iqtiboslaringizni
            saqlang, oylik kitobxonlik musobaqasida qatnashib kitob yutib oling va boshqa
            kitobxonlar bilan suhbatlashing. Hammasi bitta joyda, o'zbek tilida.
        </p>
        <div class="lp-hero-actions">
            @if (isAuth)
            {
                <a class="btn btn-accent lp-cta-btn" href="/feed">
                    <span class="material-symbols-outlined">dynamic_feed</span>
                    Tasmaga o'tish
                </a>
            }
            else
            {
                <a class="google-btn lp-google" href="/auth/google-login">
                    <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" />
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
                        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05" />
                        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
                    </svg>
                    Google orqali bepul boshlash
                </a>
            }
            <a class="btn btn-outline lp-secondary-btn" href="#imkoniyatlar">Imkoniyatlarni ko'rish</a>
            <a class="btn btn-outline lp-secondary-btn" href="/download/kitobdagimen.apk" download>
                <span class="material-symbols-outlined" style="font-size:20px;vertical-align:bottom">android</span>
                Android ilovasi (.apk)
            </a>
        </div>
        <p class="lp-terms">
            @if (isAuth)
            {
                <text>Siz allaqachon tizimdasiz — istalgan vaqtda tasmangizga qayting.</text>
            }
            else
            {
                <text>Davom etish orqali siz foydalanish shartlariga rozilik bildirasiz</text>
            }
        </p>

        <ul class="lp-trust">
            <li><span class="material-symbols-outlined">verified</span> 100% bepul</li>
            <li><span class="material-symbols-outlined">emoji_events</span> Oylik musobaqa — kitob sovg'a</li>
            <li><span class="material-symbols-outlined">forum</span> Real vaqt suhbat</li>
            <li><span class="material-symbols-outlined">language</span> O'zbek tilida</li>
        </ul>
    </section>

    @if (ViewData["LandingStats"] is KitobdaGimen.Application.Features.Home.Queries.GetLandingStats.LandingStatsDto stats)
    {
        <section class="lp-section lp-stats" id="statistika" aria-label="Platforma statistikasi">
            <div class="lp-stats-grid">
                <div class="lp-stat">
                    <span class="lp-stat-icon"><span class="material-symbols-outlined">group</span></span>
                    <span class="lp-stat-num" data-count="@stats.UserCount">0</span>
                    <span class="lp-stat-label">Kitobxonlar</span>
                </div>
                <div class="lp-stat">
                    <span class="lp-stat-icon"><span class="material-symbols-outlined">menu_book</span></span>
                    <span class="lp-stat-num" data-count="@stats.BooksRead">0</span>
                    <span class="lp-stat-label">O'qib tugatilgan kitoblar</span>
                </div>
                <div class="lp-stat">
                    <span class="lp-stat-icon"><span class="material-symbols-outlined">auto_stories</span></span>
                    <span class="lp-stat-num" data-count="@stats.PagesRead">0</span>
                    <span class="lp-stat-label">O'qilgan betlar</span>
                </div>
            </div>
        </section>
    }

    <section class="lp-section" id="imkoniyatlar">
        <div class="lp-section-head">
            <h2>Platforma imkoniyatlari</h2>
            <p class="muted">Kitobxonlik tajribangizni boyitadigan barcha vositalar — bir joyda</p>
        </div>
        <div class="lp-grid">
            <div class="lp-feature">
                <span class="lp-feature-icon"><span class="material-symbols-outlined">edit_note</span></span>
                <h3>Postlar va taqrizlar</h3>
                <p>O'qigan kitobingiz haqida post yozing, rasm biriktiring va baho bering. Postlaringizga
                    yoqtirishlar va izohlar orqali jonli munozara boshlang.</p>
            </div>
            <div class="lp-feature">
                <span class="lp-feature-icon"><span class="material-symbols-outlined">format_quote</span></span>
                <h3>Iqtiboslar</h3>
                <p>Kitobdagi eng ta'sirchan satrlarni chiroyli kartochka ko'rinishida saqlang. Iqtiboslarni
                    yoqtiring, izoh qoldiring va do'stlaringizga ulashing.</p>
            </div>
            <div class="lp-feature">
                <span class="lp-feature-icon"><span class="material-symbols-outlined">emoji_events</span></span>
                <h3>Challenge — oylik musobaqa</h3>
                <p>Har oy eng ko'p kitob o'qiganlar musobaqasida qatnashing. 1-, 2- va 3-o'rin
                    egalari kitob sovg'asi bilan taqdirlanadi.</p>
            </div>
            <div class="lp-feature">
                <span class="lp-feature-icon"><span class="material-symbols-outlined">target</span></span>
                <h3>O'qish maqsadlari</h3>
                <p>Yillik kitob maqsadingizni belgilang, o'qilgan betlarni kuzating va rivojlanishingizni ko'ring.</p>
            </div>
            <div class="lp-feature">
                <span class="lp-feature-icon"><span class="material-symbols-outlined">forum</span></span>
                <h3>Real vaqt xabarlar</h3>
                <p>Boshqa kitobxonlar bilan jonli suhbatlashing, online holatni ko'ring va tavsiyalar almashing.</p>
            </div>
            <div class="lp-feature">
                <span class="lp-feature-icon"><span class="material-symbols-outlined">auto_stories</span></span>
                <h3>Storylar</h3>
                <p>Hozir nima o'qiyotganingizni qisqa story ko'rinishida — 24 soatlik lahzalarda bo'lishing.</p>
            </div>
