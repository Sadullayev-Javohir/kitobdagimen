            <div class="brand">
                <img class="brand-logo" src="~/img/logo.svg" alt="" />
                <span class="brand-text">kitobdagimen<span style="color:var(--accent)">.uz</span></span>
            </div>
            <p class="muted">O'zbek kitobxonlari uchun ijtimoiy platforma.</p>
        </div>
        <nav class="lp-footer-links">
            <a href="#imkoniyatlar">Imkoniyatlar</a>
            <a href="#postlar">Postlar va iqtiboslar</a>
            <a href="#challenge">Challenge</a>
            <a href="#qanday">Qanday ishlaydi</a>
            <a href="/qollanma">Qo'llanma</a>
            <a href="#savol">Savollar</a>
            <a href="@primaryHref">@primaryLabel</a>
        </nav>
        <p class="lp-copy muted">© 2026 kitobdagimen.uz</p>
    </footer>
</div>

<script>
(function () {
    "use strict";
    // ── Statistika counter animatsiyasi ──
    // Raqamlar bo'lim ekranga kirganda 0 dan haqiqiy qiymatgacha ease-out bilan sanaladi.
    // prefers-reduced-motion yoqilgan yoki IntersectionObserver yo'q bo'lsa — darhol yakuniy qiymat.
    var nums = document.querySelectorAll(".lp-stat-num[data-count]");
    if (!nums.length) return;

    var fmt = new Intl.NumberFormat("ru-RU"); // minglik ajratgich — bo'sh joy (o'zbek yozuviga mos)
    function setFinal(el) { el.textContent = fmt.format(parseInt(el.dataset.count, 10) || 0); }

    var reduced = window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduced || !("IntersectionObserver" in window)) {
        nums.forEach(setFinal);
        return;
    }

    function animate(el) {
        var target = parseInt(el.dataset.count, 10) || 0;
        if (target <= 0) { setFinal(el); return; }
        var duration = 1600;
        var start = null;
        function step(ts) {
            if (start === null) start = ts;
            var p = Math.min(1, (ts - start) / duration);
            var eased = 1 - Math.pow(1 - p, 3); // ease-out cubic
            el.textContent = fmt.format(Math.round(target * eased));
            if (p < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
    }

    var seen = new WeakSet();
    var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
            if (!e.isIntersecting || seen.has(e.target)) return;
            seen.add(e.target);
            animate(e.target);
            io.unobserve(e.target);
        });
    }, { threshold: 0.4 });
    nums.forEach(function (el) { io.observe(el); });
})();
</script>
