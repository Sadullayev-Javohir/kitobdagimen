@using KitobdaGimen.Application.Features.Leaderboard.Dtos
@using KitobdaGimen.Application.Features.Leaderboard.Queries.GetReadingLeaderboard
@model IReadOnlyList<LeaderboardUserDto>
@{
    ViewData["Title"] ??= "Kitobxonlar reytingi";
    var period = ViewData["Period"] as LeaderboardPeriod? ?? LeaderboardPeriod.Daily;

    string TabClass(LeaderboardPeriod p) => p == period ? "lb-tab is-active" : "lb-tab";

    (string label, string sub) = period switch
    {
        LeaderboardPeriod.Daily => ("Bugun", "bugun eng ko'p o'qiganlar"),
        LeaderboardPeriod.Monthly => ("Bu oy", "so'nggi 30 kunda eng ko'p o'qiganlar"),
        LeaderboardPeriod.AllTime => ("Bir umrlik", "barcha vaqt davomida eng ko'p o'qiganlar"),
        _ => ("Bu hafta", "so'nggi 7 kunda eng ko'p o'qiganlar")
    };

    string ProfileUrl(LeaderboardUserDto u) =>
        "/profile/" + (string.IsNullOrWhiteSpace(u.Username) ? u.UserId.ToString() : u.Username);

    var top3 = Model.Where(u => u.Rank <= 3).ToList();
    var rest = Model.Where(u => u.Rank > 3).ToList();

    // Podium ko'rinishi uchun tartib: 2-chi (chap), 1-chi (markaz), 3-chi (o'ng).
    var podiumOrder = new[] { 2, 1, 3 };
}

<div class="container page lb-page">
    <header class="lb-head">
        <h1 class="section-title" style="margin:0">
            <span class="material-symbols-outlined" style="vertical-align:-4px;color:var(--accent)">emoji_events</span>
            Kitobxonlar reytingi
        </h1>
        <p class="muted lb-sub">@label — @sub. Eng faol 23 kitobxon ko'rsatiladi.</p>
    </header>

    <nav class="lb-tabs" aria-label="Davr tanlash">
        <a class="@TabClass(LeaderboardPeriod.Daily)" href="/leaderboards?period=daily">Kunlik</a>
        <a class="@TabClass(LeaderboardPeriod.Weekly)" href="/leaderboards?period=weekly">Haftalik</a>
        <a class="@TabClass(LeaderboardPeriod.Monthly)" href="/leaderboards?period=monthly">Oylik</a>
        <a class="@TabClass(LeaderboardPeriod.AllTime)" href="/leaderboards?period=alltime">Bir umrlik</a>
    </nav>

    @if (Model.Count == 0)
    {
        <div class="card lb-empty">
            <span class="material-symbols-outlined">auto_stories</span>
            <h3>Hozircha reyting bo'sh</h3>
            <p class="muted">Bu davrda hali hech kim kitob o'qimadi. Kutubxonadan kitob qo'shib,
                har kuni o'qigan betlaringizni kiriting — reytingda birinchi bo'ling!</p>
            <a class="btn btn-accent" href="/reading-books">Kutubxonaga o'tish</a>
        </div>
    }
    else
    {
        @* ===== Podium: 1-2-3 o'rin ===== *@
        <section class="lb-podium" aria-label="Top 3 kitobxon">
            @foreach (var slot in podiumOrder)
            {
                var u = top3.FirstOrDefault(x => x.Rank == slot);
                if (u is null) { continue; }
                var place = u.Rank;
                <a class="lb-podium-card lb-place-@place" href="@ProfileUrl(u)">
                    <div class="lb-medal">@(place == 1 ? "🥇" : place == 2 ? "🥈" : "🥉")</div>
                    <div class="lb-avatar-wrap">
                        @if (!string.IsNullOrEmpty(u.AvatarUrl))
                        {
                            <img class="avatar lb-avatar" src="@u.AvatarUrl" alt="@u.FullName" referrerpolicy="no-referrer" />
                        }
                        else
                        {
                            <span class="avatar lb-avatar">@(string.IsNullOrEmpty(u.FullName) ? "?" : u.FullName.Trim()[..1].ToUpper())</span>
                        }
                        <span class="lb-rank-badge">@place</span>
                    </div>
                    <div class="lb-name" title="@u.FullName">@u.FullName</div>
                    <div class="lb-score"><strong>@u.Score</strong> bet</div>
                    <div class="lb-detail muted">@u.Detail</div>
                    <div class="lb-pillar"></div>
                </a>
            }
        </section>

        @* ===== Qolgan o'rinlar: 4–23 ===== *@
        @if (rest.Count > 0)
        {
            <ul class="lb-list card">
                @foreach (var u in rest)
                {
                    <li class="lb-row">
                        <span class="lb-row-rank">@u.Rank</span>
                        <a class="lb-row-user" href="@ProfileUrl(u)">
                            @if (!string.IsNullOrEmpty(u.AvatarUrl))
                            {
                                <img class="avatar lb-row-avatar" src="@u.AvatarUrl" alt="@u.FullName" referrerpolicy="no-referrer" />
                            }
                            else
                            {
                                <span class="avatar lb-row-avatar">@(string.IsNullOrEmpty(u.FullName) ? "?" : u.FullName.Trim()[..1].ToUpper())</span>
                            }
                            <span class="lb-row-name" title="@u.FullName">@u.FullName</span>
                        </a>
                        <span class="lb-row-detail muted">@u.Detail</span>
                        <span class="lb-row-score"><strong>@u.Score</strong> bet</span>
                    </li>
                }
            </ul>
        }
    }
</div>

<style>
    .lb-head { margin-bottom: 14px; }
    .lb-sub { margin: 6px 0 0; font-size: 14px; }

    /* Davr tablari */
    .lb-tabs { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 22px; }
    .lb-tab {
        padding: 8px 16px; border-radius: 999px; font-size: 14px; font-weight: 600;
        border: 1px solid var(--border, #e6ddcd); color: var(--text, #2a2a2a);
        background: var(--surface, #fffdf8); text-decoration: none; transition: all .15s ease;
    }
    .lb-tab:hover { border-color: var(--accent, #e8703a); }
    .lb-tab.is-active { background: var(--primary, #1b4d3e); color: #fff; border-color: var(--primary, #1b4d3e); }

    /* Podium */
    .lb-podium {
        display: flex; align-items: flex-end; justify-content: center; gap: 14px;
        margin: 8px 0 26px; flex-wrap: nowrap;
    }
    .lb-podium-card {
        flex: 1 1 0; max-width: 200px; text-align: center; text-decoration: none;
        color: inherit; display: flex; flex-direction: column; align-items: center;
        padding: 10px 8px 0; border-radius: 18px; transition: transform .15s ease;
    }
    .lb-podium-card:hover { transform: translateY(-3px); }
    .lb-medal { font-size: 26px; line-height: 1; }
    .lb-avatar-wrap { position: relative; margin: 6px 0 8px; }
    .lb-avatar {
        width: 64px; height: 64px; font-size: 26px; border: 3px solid var(--surface, #fffdf8);
        box-shadow: 0 2px 10px rgba(0,0,0,.12);
    }
    .lb-place-1 .lb-avatar { width: 84px; height: 84px; font-size: 34px; border-color: #f2c14e; }
    .lb-place-2 .lb-avatar { border-color: #c7ccd1; }
    .lb-place-3 .lb-avatar { border-color: #d7a06b; }
    .lb-rank-badge {
        position: absolute; bottom: -4px; right: -4px; width: 24px; height: 24px;
        border-radius: 50%; background: var(--accent, #e8703a); color: #fff;
        font-size: 13px; font-weight: 700; display: flex; align-items: center; justify-content: center;
        border: 2px solid var(--surface, #fffdf8);
    }
    .lb-name {
        font-weight: 600; font-size: 14px; max-width: 100%;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .lb-score { font-size: 14px; margin-top: 2px; }
    .lb-score strong { color: var(--accent, #e8703a); font-size: 17px; }
    .lb-detail { font-size: 12px; }
    .lb-pillar {
        margin-top: 10px; width: 100%; border-radius: 12px 12px 0 0;
        background: linear-gradient(180deg, var(--primary, #1b4d3e), color-mix(in srgb, var(--primary, #1b4d3e) 60%, transparent));
    }
    .lb-place-1 .lb-pillar { height: 70px; }
    .lb-place-2 .lb-pillar { height: 48px; }
    .lb-place-3 .lb-pillar { height: 32px; }

    /* Ro'yxat 4–23 */
    .lb-list { list-style: none; margin: 0; padding: 6px 0; }
    .lb-row {
        display: flex; align-items: center; gap: 12px; padding: 10px 16px;
        border-bottom: 1px solid var(--border, #efe7d7);
    }
    .lb-row:last-child { border-bottom: none; }
    .lb-row-rank {
        flex: 0 0 28px; text-align: center; font-weight: 700; font-size: 15px;
        color: var(--muted, #8a8473);
    }
    .lb-row-user {
        flex: 1 1 auto; display: flex; align-items: center; gap: 10px; min-width: 0;
        text-decoration: none; color: inherit;
    }
    .lb-row-avatar { width: 40px; height: 40px; font-size: 16px; flex: 0 0 40px; }
    .lb-row-name { font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .lb-row-user:hover .lb-row-name { color: var(--accent, #e8703a); }
    .lb-row-detail { flex: 0 0 auto; font-size: 13px; }
    .lb-row-score { flex: 0 0 auto; font-size: 14px; white-space: nowrap; }
    .lb-row-score strong { color: var(--accent, #e8703a); }

    /* Bo'sh holat */
    .lb-empty { text-align: center; padding: 40px 20px; }
    .lb-empty .material-symbols-outlined { font-size: 48px; color: var(--accent, #e8703a); }
    .lb-empty h3 { margin: 10px 0 6px; }
    .lb-empty p { max-width: 420px; margin: 0 auto 16px; }

    @@media (max-width: 560px) {
        .lb-podium { gap: 8px; }
        .lb-avatar { width: 54px; height: 54px; font-size: 22px; }
        .lb-place-1 .lb-avatar { width: 68px; height: 68px; font-size: 28px; }
        .lb-row-detail { display: none; }
    }
</style>
