    string Icon(string name, string? cls = null)
    {
        var path = iconPaths.TryGetValue(name, out var p) ? p : "";
        var extra = string.IsNullOrEmpty(cls) ? "" : $" {cls}";
        return $"<svg class=\"yr-ic{extra}\" viewBox=\"0 0 16 16\" fill=\"currentColor\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\">{path}</svg>";
    }

