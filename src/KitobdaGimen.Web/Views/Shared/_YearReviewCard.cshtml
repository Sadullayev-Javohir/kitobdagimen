@using KitobdaGimen.Application.Features.YearReview.Dtos
@model YearReviewDto
@{
    var shareUrl = ViewData["ShareUrl"] as string ?? "";
    var initial = string.IsNullOrWhiteSpace(Model.FullName) ? "?" : Model.FullName.Trim()[..1].ToUpper();

    var avgPerDay = Model.ActiveDays > 0 ? (int)System.Math.Round((double)Model.TotalPages / Model.ActiveDays) : 0;
    var topBook = Model.Books.Count > 0 ? Model.Books[0] : null;
    var maxBookPages = Model.Books.Count > 0 ? System.Math.Max(1, Model.Books.Max(b => b.Pages)) : 1;
    var shownBooks = Model.Books.Take(5).ToList();
    var moreBooks = Model.Books.Count - shownBooks.Count;

