<div class="yr-card yr-theme-@Model.ThemeVariant"
     data-yr-year="@Model.Year"
     data-yr-share-url="@shareUrl"
     data-yr-name="@Model.FullName">

    @* ── Sahna: qat'iy 1080px poster + ekran-effektlari. JS poster'ni konteyner kengligiga
         qarab masshtablaydi (scale). Shu tufayli ekranda ko'ringan narsa aynan yuklab olinadi
         (WYSIWYG) — matnlar hech qachon qayta oqmaydi va buzilmaydi. ── *@
    <div class="yr-stage" data-yr-stage>

    @* ── html2canvas tortib oladigan poster (barcha bezaklar shu ichida, faqat SVG) ── *@
    <div class="yr-poster" data-yr-capture>
        <div class="yr-sky" aria-hidden="true">
            <div class="yr-garland">
                @for (var i = 0; i < 22; i++)
                {
                    <span class="yr-bulb yr-bulb-@(i % 4)"></span>
                }
            </div>
            <span class="yr-star yr-star-1">@Html.Raw(Icon("stars"))</span>
            <span class="yr-star yr-star-2">@Html.Raw(Icon("star"))</span>
            <span class="yr-star yr-star-3">@Html.Raw(Icon("stars"))</span>
            <span class="yr-flurry yr-flurry-1">@Html.Raw(Icon("snow"))</span>
            <span class="yr-flurry yr-flurry-2">@Html.Raw(Icon("snow"))</span>
            <span class="yr-flurry yr-flurry-3">@Html.Raw(Icon("snow"))</span>
            <span class="yr-flurry yr-flurry-4">@Html.Raw(Icon("snow"))</span>
        </div>

        <div class="yr-poster-inner">
            <div class="yr-topbar">
                <div class="yr-brandbox">
                    <span class="yr-logo">@Html.Raw(LogoSvg(38))</span>
                    <span class="yr-brand">kitobdagimen<span class="yr-brand-accent">.uz</span></span>
                </div>
                <div class="yr-badge">@Html.Raw(Icon("snow", "yr-badge-ic")) Yangi yil yakuni</div>
            </div>

            <div class="yr-hero">
                <div class="yr-hero-left">
                    <div class="yr-year">@Model.Year</div>
                    <div class="yr-hero-sub">YILLIK KITOB YAKUNI</div>
                    <div class="yr-user">
                        <span class="yr-avatar">@initial</span>
                        <span class="yr-user-meta">
                            <span class="yr-username">@Model.FullName</span>
                            @if (!string.IsNullOrWhiteSpace(Model.Username))
                            {
                                <span class="yr-handle">@@@Model.Username</span>
                            }
                        </span>
                    </div>
                </div>
                <div class="yr-hero-right" aria-hidden="true">
                    @Html.Raw(SleighScene)
                </div>
            </div>

            @if (Model.HasActivity)
            {
                <div class="yr-stats">
                    <div class="yr-stat">
                        <span class="yr-stat-ic">@Html.Raw(Icon("book"))</span>
                        <span class="yr-stat-num">@Model.BooksRead</span>
                        <span class="yr-stat-label">kitob o'qildi</span>
                    </div>
                    <div class="yr-stat">
                        <span class="yr-stat-ic">@Html.Raw(Icon("journal-text"))</span>
                        <span class="yr-stat-num">@Model.TotalPages</span>
                        <span class="yr-stat-label">bet</span>
                    </div>
                    <div class="yr-stat">
                        <span class="yr-stat-ic">@Html.Raw(Icon("fire"))</span>
                        <span class="yr-stat-num">@Model.ActiveDays</span>
                        <span class="yr-stat-label">faol kun</span>
                    </div>
                    <div class="yr-stat">
                        <span class="yr-stat-ic">@Html.Raw(Icon("lightning"))</span>
                        <span class="yr-stat-num">@avgPerDay</span>
                        <span class="yr-stat-label">kunlik o'rtacha</span>
                    </div>
                </div>

                <div class="yr-grid">
                    <div class="yr-col">
                        <div class="yr-col-head">@Html.Raw(Icon("journals", "yr-head-ic")) O'qigan kitoblaring</div>
                        @if (shownBooks.Count > 0)
                        {
                            <div class="yr-booklist">
                                @foreach (var b in shownBooks)
                                {
                                    var pct = (int)System.Math.Round(100.0 * b.Pages / maxBookPages);
                                    <div class="yr-bookrow">
                                        <div class="yr-bookrow-top">
                                            <span class="yr-book-title">@b.Title</span>
                                            <span class="yr-book-pages">@b.Pages bet</span>
                                        </div>
                                        <div class="yr-book-bar"><span style="width:@pct%"></span></div>
                                    </div>
                                }
                            </div>
                            @if (moreBooks > 0)
                            {
                                <div class="yr-more">va yana +@moreBooks ta kitob</div>
                            }
                        }
                        else
                        {
                            <div class="yr-col-empty">Bu yil o'qish yo'lini boshlading @Html.Raw(Icon("flower", "yr-inline-ic"))</div>
                        }
                    </div>

                    <div class="yr-col">
                        <div class="yr-col-head">@Html.Raw(Icon("stars", "yr-head-ic")) Yilning eng zo'rlari</div>
                        @if (Model.TopPost is not null)
                        {
                            <div class="yr-highlight">
                                <div class="yr-highlight-head">
                                    <span class="yr-highlight-title">@Html.Raw(Icon("trophy", "yr-inline-ic")) Eng mashhur posting</span>
                                    <span class="yr-likes">@Html.Raw(Icon("heart", "yr-inline-ic")) @Model.TopPost.LikeCount</span>
                                </div>
                                <div class="yr-highlight-body">“@Model.TopPost.Snippet”</div>
                                <div class="yr-highlight-meta">@Model.TopPost.BookTitle</div>
                            </div>
                        }
                        @if (Model.TopQuote is not null)
                        {
                            <div class="yr-highlight">
                                <div class="yr-highlight-head">
                                    <span class="yr-highlight-title">@Html.Raw(Icon("chat-quote", "yr-inline-ic")) Eng mashhur iqtibosing</span>
                                    <span class="yr-likes">@Html.Raw(Icon("heart", "yr-inline-ic")) @Model.TopQuote.LikeCount</span>
                                </div>
                                <div class="yr-highlight-body">“@Model.TopQuote.Snippet”</div>
                                <div class="yr-highlight-meta">@Model.TopQuote.BookTitle</div>
                            </div>
                        }
                        @if (Model.TopPost is null && Model.TopQuote is null)
                        {
                            <div class="yr-col-empty">
                                Post va iqtibos ulashib, kelasi yakuningni yanada boyit! @Html.Raw(Icon("pencil", "yr-inline-ic"))
                            </div>
                        }
                        @if (topBook is not null)
                        {
                            <div class="yr-topbook">
                                <span class="yr-topbook-ic">@Html.Raw(Icon("star"))</span>
                                <span>Eng ko'p o'qigan kitobing — <strong>@topBook.Title</strong></span>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="yr-empty">
                    <div class="yr-empty-ic">@Html.Raw(Icon("book"))</div>
                    <p>Bu yil o'qish sari ilk qadamlaringni qo'yding. Kelasi yil yakuning
                        kitoblar bilan to'lib-toshsin!</p>
                </div>
            }

            <div class="yr-motivation">
                <span class="yr-quote-mark">“</span>
                <span class="yr-motivation-text">@Model.Motivation</span>
            </div>

            <div class="yr-foot">
                <span class="yr-foot-logo">@Html.Raw(LogoSvg(22))</span>
                <span class="yr-foot-brand">kitobdagimen.uz</span>
                <span class="yr-foot-dot">•</span>
                <span>@Model.Year yil yakuni</span>
            </div>
        </div>

        <div class="yr-drift" aria-hidden="true">
            <span class="yr-drift-tree yr-drift-tree-1">@Html.Raw(Icon("tree"))</span>
            <span class="yr-drift-tree yr-drift-tree-2">@Html.Raw(Icon("tree"))</span>
            <span class="yr-drift-tree yr-drift-tree-3">@Html.Raw(Icon("gift"))</span>
            <span class="yr-drift-tree yr-drift-tree-4">@Html.Raw(Icon("tree"))</span>
        </div>
    </div>

        @* ── Ekran-effektlari: yog'ayotgan qor + Three.js Qorbobo (poster ustida, rasmga TUSHMAYDI) ── *@
        <div class="yr-fx" data-yr-fx aria-hidden="true">
            <div class="yr-three" data-yr-three>
                @* Three.js bu yerga <canvas> qo'yadi. Agar yuklanmasa — quyidagi SVG chana uchadi. *@
                <div class="yr-sleigh-fallback" data-yr-sleigh-fallback>@Html.Raw(SleighScene)</div>
            </div>
        </div>
    </div>@* /.yr-stage *@

    @* ── Amallar — rasmga tushmaydi ── *@
    <div class="yr-actions" data-yr-actions>
        <button type="button" class="yr-btn yr-btn-primary" data-yr-download="png">
            <span class="material-symbols-outlined">download</span> Rasm (PNG)
        </button>
        <button type="button" class="yr-btn" data-yr-download="jpg">JPG</button>
        <button type="button" class="yr-btn" data-yr-download="pdf">PDF</button>
        <button type="button" class="yr-btn" data-yr-share>
            <span class="material-symbols-outlined">share</span> Ulashish
        </button>
    </div>
</div>
