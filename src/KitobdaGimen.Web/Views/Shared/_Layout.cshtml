@using KitobdaGimen.Application.Common.Interfaces
@using KitobdaGimen.Application.Features.Auth.Queries.GetCurrentUser
@using MediatR
@inject ICurrentUserService CurrentUser
@inject ISender Mediator
@{
    var isAuth = CurrentUser.IsAuthenticated;
    UserDto? me = null;
    if (isAuth)
    {
        me = await Mediator.Send(new GetCurrentUserQuery());
    }
    var initial = string.IsNullOrEmpty(me?.FullName) ? "?" : me!.FullName.Trim()[..1].ToUpper();
    var hideChrome = ViewData["HideChrome"] as bool? ?? false;
    var currentController = ViewContext.RouteData.Values["controller"] as string ?? "";
    var isChatPage = string.Equals(currentController, "Chat", StringComparison.OrdinalIgnoreCase);
    // Mobil pastki navigatsiya: kirgan foydalanuvchida va chrome ko'rinadigan barcha sahifalarda
    // (chat sahifasida ham — input pastki nav ustida turadi, balandlik shунга moslashtirilgan).
    var showBottomNav = isAuth && !hideChrome;
    var mobilePath = (Context.Request.Path.Value ?? "").ToLowerInvariant();
    // Qidiruv ikoni Feed, Chat, Profil, Kutubxona, Iqtiboslar, Challenge va post detali sahifalarida ko'rsatilmaydi.
    // (/feed va /quotes da sahifaning o'z qidiruvi bor — navbardagisi ortiqcha.)
    var hideSearch = isChatPage
        || string.Equals(currentController, "Feed", StringComparison.OrdinalIgnoreCase)
        || string.Equals(currentController, "Profile", StringComparison.OrdinalIgnoreCase)
        || string.Equals(currentController, "ReadingGoals", StringComparison.OrdinalIgnoreCase)
        || string.Equals(currentController, "Quotes", StringComparison.OrdinalIgnoreCase)
        || string.Equals(currentController, "Challenge", StringComparison.OrdinalIgnoreCase)
        || string.Equals(currentController, "Posts", StringComparison.OrdinalIgnoreCase);

    // --- SEO (Google'da yuqori chiqish uchun) ---
    // Har bir sahifa ViewData orqali o'z tavsifini/rasmini/robots holatini bera oladi;
    // berilmasa quyidagi standart qiymatlar ishlatiladi.
    var seoReq = Context.Request;
    var seoBase = $"{seoReq.Scheme}://{seoReq.Host}";
    var seoCanonical = ViewData["Canonical"] as string ?? $"{seoBase}{seoReq.Path}";
    var seoDescription = ViewData["Description"] as string
        ?? "kitobdagimen.uz — o'zbek kitobxonlari uchun ijtimoiy platforma. Kitob taqrizlari yozing, sevimli iqtiboslarni ulashing, o'qish maqsadlari qo'ying va kitobsevarlar bilan tanishing. 100% bepul, o'zbek tilida.";
    var seoImage = ViewData["OgImage"] as string ?? $"{seoBase}/img/og-image.png";
    var seoOgType = ViewData["OgType"] as string ?? "website";
    var seoTitle = ViewData["Title"] != null
        ? ViewData["Title"] + " — kitobdagimen.uz"
        : "kitobdagimen.uz — o'zbek kitobxonlari ijtimoiy platformasi";
    // Maxfiy (auth ortidagi) sahifalar Google indeksiga tushmasin — robots.txt + bu meta birga himoya qiladi.
    var seoNoindexControllers = new[] { "Feed", "Chat", "Profile", "ReadingGoals", "Quotes", "Onboarding", "Notifications", "Stories", "Books", "Auth", "App", "Challenge" };
    var seoRobots = ViewData["Robots"] as string
        ?? (seoNoindexControllers.Contains(currentController, StringComparer.OrdinalIgnoreCase) ? "noindex, follow" : "index, follow, max-image-preview:large");
    var seoJsonLd = ViewData["JsonLd"] as string;
}
<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="utf-8" />
    @* Chat sahifasida klaviatura ochilganda layout KICHRAYADI (resizes-content, Android Chrome 108+):
       xabar yozish paneli klaviatura ustida qoladi, suhbatdosh header'i tepada qotib turadi.
       Boshqa sahifalarda default (resizes-visual) qoladi — pastki nav klaviatura ustiga chiqmaydi. *@
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover@(isChatPage ? ", interactive-widget=resizes-content" : "")" />
    @* Sayt doim video-glass qorong'u dizaynda — kun/tun almashtirish yo'q *@
    <script>document.documentElement.setAttribute('data-theme', 'dark');</script>

    @* Ko'rinish sozlamalari (navbardagi settings ikonasi orqali boshqariladi, localStorage'da
       saqlanadi va CSS custom property sifatida barcha sahifalarda global qo'llaniladi). *@
    <script>
        (function () {
            var STORAGE_KEY = 'kg-display-settings';
            var DEFAULTS = { brightness: 40, cardBlur: 1, cardBg: 50 };
            function loadSettings() {
                try {
                    var raw = localStorage.getItem(STORAGE_KEY);
                    if (!raw) return Object.assign({}, DEFAULTS);
                    var p = JSON.parse(raw);
                    return {
                        brightness: typeof p.brightness === 'number' ? p.brightness : DEFAULTS.brightness,
                        cardBlur: typeof p.cardBlur === 'number' ? p.cardBlur : DEFAULTS.cardBlur,
                        cardBg: typeof p.cardBg === 'number' ? p.cardBg : DEFAULTS.cardBg
                    };
                } catch (e) { return Object.assign({}, DEFAULTS); }
            }
            function clamp(v, min, max) { return Math.min(max, Math.max(min, v)); }
            function applySettings(s) {
                var root = document.documentElement.style;
                var brightness = clamp(s.brightness, 0, 100);
                var cardBlur = clamp(s.cardBlur, 0, 1);
                var cardBg = clamp(s.cardBg, 0, 100);
                root.setProperty('--gx-overlay-alpha', (1 - brightness / 100).toFixed(3));
                root.setProperty('--gx-blur-px', (cardBlur * 22).toFixed(1) + 'px');
                root.setProperty('--gx-card-alpha', ((1 - cardBg / 100) * 0.92).toFixed(3));
            }
            window.kgDisplaySettings = {
                defaults: DEFAULTS,
                get: loadSettings,
                save: function (s) {
                    localStorage.setItem(STORAGE_KEY, JSON.stringify(s));
                    applySettings(s);
                }
            };
            applySettings(loadSettings());
        })();
    </script>
    @* Rasm xatolarini global hal qilish: (1) Google avatar (lh3.googleusercontent.com) Referer
       yuborilganda bloklanadi — xato bo'lsa referrerpolicy=no-referrer bilan QAYTA urinamiz;
       (2) baribir yuklanmasa — avatarni bosh harfga, kitob muqovasini placeholder ikonga almashtiramiz.
       Capture fazasi kerak, chunki <img> error hodisasi "bubble" qilmaydi. *@
    <script>
        (function () {
            function onImgError(e) {
                var img = e.target;
                if (!img || img.tagName !== 'IMG') return;
                // Chat lightbox rasmi o'zining yuklash/xato holatini boshqaradi — global
                // "visibility:hidden" fallback unga tegmasligi kerak (aks holda keyingi ochishda
                // rasm inline visibility:hidden bilan ko'rinmay qoladi).
                if (img.id === 'chatLightboxImg' || (img.closest && img.closest('.chat-lightbox'))) return;
                if (!img.dataset.imgRetry) {
                    img.dataset.imgRetry = '1';
                    try { img.referrerPolicy = 'no-referrer'; } catch (_) { }
                    var s = img.src; img.src = ''; img.src = s;
                    return;
                }
                if (img.dataset.imgFailed) return;
                img.dataset.imgFailed = '1';
                if (img.classList.contains('avatar')) {
                    var name = (img.getAttribute('alt') || '?').trim();
                    var span = document.createElement('span');
                    span.className = img.className;
                    span.textContent = name ? name.charAt(0).toUpperCase() : '?';
                    if (img.parentNode) img.parentNode.replaceChild(span, img);
                } else if (img.closest) {
                    var wrap = img.closest('[class*="cover"]');
                    if (wrap) { wrap.innerHTML = '<span class="material-symbols-outlined">menu_book</span>'; }
                    else { img.style.visibility = 'hidden'; }
                }
            }
            document.addEventListener('error', onImgError, true);
        })();
    </script>
    <title>@seoTitle</title>
    <meta name="description" content="@seoDescription" />
    <meta name="robots" content="@seoRobots" />
    <meta name="googlebot" content="@seoRobots" />
    <link rel="canonical" href="@seoCanonical" />
    <meta name="theme-color" content="#E8703A" />
    <meta name="author" content="kitobdagimen.uz" />
    @* Yandex Webmaster domen tasdiqlash (webmaster.yandex.com) *@
    <meta name="yandex-verification" content="a0f87cc1b8524a06" />
    <meta name="keywords" content="kitob, kitobxonlar, o'zbek kitoblari, kitob taqrizlari, kitob sharhlari, iqtiboslar, o'qish, kutubxona, kitobsevarlar, kitob o'qish, kitobdagimen" />

    @* Open Graph — Telegram/Facebook/LinkedInda ulashilganda chiroyli kartochka *@
    <meta property="og:type" content="@seoOgType" />
    <meta property="og:site_name" content="kitobdagimen.uz" />
    <meta property="og:locale" content="uz_UZ" />
    <meta property="og:title" content="@seoTitle" />
    <meta property="og:description" content="@seoDescription" />
    <meta property="og:url" content="@seoCanonical" />
    <meta property="og:image" content="@seoImage" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    @* Twitter Card *@
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@seoTitle" />
    <meta name="twitter:description" content="@seoDescription" />
    <meta name="twitter:image" content="@seoImage" />

    @if (!string.IsNullOrEmpty(seoJsonLd))
    {
        <script type="application/ld+json">@Html.Raw(seoJsonLd)</script>
    }
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Source+Sans+3:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=swap" rel="stylesheet" />
    <link rel="icon" href="~/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="~/img/logo.svg" />
    <link rel="icon" type="image/png" sizes="192x192" href="~/img/icons/icon-192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="~/img/icons/icon-512.png" />
    <link rel="apple-touch-icon" href="~/img/icons/apple-touch-icon.png" />

    @* PWA — Android (TWA) va telefon "bosh ekranga qo'shish" uchun *@
    <link rel="manifest" href="~/manifest.webmanifest" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="kitobdagimen" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/video-glass.css" asp-append-version="true" />
    @if (isAuth)
    {
        <link rel="stylesheet" href="~/css/year-review.css" asp-append-version="true" />
    }
    @await RenderSectionAsync("Styles", required: false)
</head>
<body data-authenticated="@(isAuth ? "true" : "false")" data-bottomnav="@(showBottomNav ? "true" : "false")" class="@(ViewData["BodyClass"] as string)">
    @Html.AntiForgeryToken()

    @* Orqa fon video (kitob mavzusida) — barcha sahifalarda fixed fon *@
    <video class="lp-bg-video" muted loop playsinline preload="auto" autoplay aria-hidden="true" tabindex="-1">
        <source src="~/videos/book.mp4" type="video/mp4" />
    </video>
    <div class="lp-bg-video-overlay" aria-hidden="true"></div>

    @* Sahifa yuklanish loaderi — barcha resurslar yuklangach JS uni yashiradi *@
    <div class="page-loader" id="pageLoader" role="status" aria-label="Yuklanmoqda">
        <div class="page-loader-box">
            <img class="page-loader-logo" src="~/img/logo.svg" alt="" />
            <span class="page-loader-ring"></span>
        </div>
    </div>

    @if (isAuth && !hideChrome)
    {
        <header class="navbar">
            <div class="navbar-inner">
                <a class="brand" href="/Feed">
                    <img class="brand-logo" src="~/img/logo.svg" alt="kitobdagimen.uz logotipi" />
                    <span class="brand-text">kitobdagimen<span style="color:var(--accent)">.uz</span></span>
                </a>

                <nav class="nav-links" data-nav-links>
                    <a href="/Feed" title="Tasma" aria-label="Tasma">
                        <span class="material-symbols-outlined">dynamic_feed</span>
                    </a>
                    <a href="/reading-books" title="Kutubxona" aria-label="Kutubxona">
                        <span class="material-symbols-outlined">menu_book</span>
                    </a>
                    <a href="/challenge" title="Challenge" aria-label="Challenge">
                        <span class="material-symbols-outlined">military_tech</span>
                    </a>
                    <a href="/quotes" title="Iqtiboslar" aria-label="Iqtiboslar">
                        <span class="material-symbols-outlined">format_quote</span>
                    </a>
                    <a href="/chat" class="nav-msg-link" title="Xabarlar" aria-label="Xabarlar">
                        <span class="material-symbols-outlined">forum</span>
                        <span class="nav-msg-badge" data-msg-badge hidden></span>
                    </a>
                </nav>

                <div class="nav-actions">
                    @if (!hideSearch)
                    {
                        <a class="nav-icon-btn desktop-only" href="/quotes" title="Qidiruv" aria-label="Qidiruv">
                            <span class="material-symbols-outlined">search</span>
                        </a>
                    }
                    <div class="notif-wrap" data-notif-wrap>
                        <button type="button" class="nav-icon-btn notif-bell" data-notif-toggle
                                title="Bildirishnomalar" aria-label="Bildirishnomalar" aria-expanded="false">
                            <span class="material-symbols-outlined">notifications</span>
                            <span class="notif-badge" data-notif-badge hidden></span>
                        </button>
                        <div class="notif-panel" data-notif-panel hidden>
                            <div class="notif-panel-head">
                                <span>Bildirishnomalar</span>
                            </div>
                            <div class="notif-list" data-notif-list>
                                <p class="notif-empty">Yangi bildirishnoma yo'q.</p>
                            </div>
                        </div>
                    </div>
                    <button type="button" class="nav-icon-btn" id="siteSettingsToggle" title="Ko'rinish sozlamalari" aria-label="Ko'rinish sozlamalari">
                        <span class="material-symbols-outlined">settings</span>
                    </button>
                    @if (me != null && me.Role >= KitobdaGimen.Domain.Enums.UserRole.Admin)
                    {
                        <a class="nav-icon-btn" href="/admin" title="Admin panel" aria-label="Admin panel">
                            <span class="material-symbols-outlined">shield_person</span>
                        </a>
                    }
                    <a href="/profile" title="Profil" aria-label="Profil">
                        @if (!string.IsNullOrEmpty(me?.AvatarUrl))
                        {
                            <img class="avatar" src="@me!.AvatarUrl" alt="@me.FullName" referrerpolicy="no-referrer" />
                        }
                        else
                        {
                            <span class="avatar">@initial</span>
                        }
                    </a>
                    <form method="post" action="/auth/logout" class="nav-logout-form"
                          onsubmit="try{window.kitobPush&&window.kitobPush.disable();}catch(e){}">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="nav-icon-btn" title="Chiqish" aria-label="Chiqish">
                            <span class="material-symbols-outlined">logout</span>
                        </button>
                    </form>
                    <button class="nav-icon-btn burger" data-burger aria-label="Menyu">
                        <span class="material-symbols-outlined">menu</span>
                    </button>
                </div>
            </div>
        </header>
    }

    @* ===== Mobil pastki navigatsiya (faqat telefon/planshet, CSS orqali) ===== *@
    @if (showBottomNav)
    {
        <nav class="bottom-nav" aria-label="Asosiy navigatsiya">
            <a href="/Feed" class="@(mobilePath.StartsWith("/feed") ? "active" : "")">
                <span class="material-symbols-outlined">dynamic_feed</span>
                <span class="bn-label">Tasma</span>
            </a>
            <a href="/reading-books" class="@(mobilePath.StartsWith("/reading-books") ? "active" : "")">
                <span class="material-symbols-outlined">menu_book</span>
                <span class="bn-label">Kutubxona</span>
            </a>
            <a href="/challenge" class="@(mobilePath.StartsWith("/challenge") ? "active" : "")">
                <span class="material-symbols-outlined">military_tech</span>
                <span class="bn-label">Challenge</span>
            </a>
            <a href="/quotes" class="@(mobilePath.StartsWith("/quotes") ? "active" : "")">
                <span class="material-symbols-outlined">format_quote</span>
                <span class="bn-label">Iqtiboslar</span>
            </a>
            <a href="/chat" class="@(mobilePath.StartsWith("/chat") ? "active" : "")">
                <span class="material-symbols-outlined">forum</span>
                <span class="bn-badge" data-msg-badge hidden></span>
                <span class="bn-label">Xabarlar</span>
            </a>
            <a href="/profile" class="@(mobilePath.StartsWith("/profile") ? "active" : "")">
                <span class="material-symbols-outlined">person</span>
                <span class="bn-label">Profil</span>
            </a>
            @if (me != null && me.Role >= KitobdaGimen.Domain.Enums.UserRole.Admin)
            {
                <a href="/admin" class="@(mobilePath.StartsWith("/admin") ? "active" : "")">
                    <span class="material-symbols-outlined">shield_person</span>
                    <span class="bn-label">Admin</span>
                </a>
            }
        </nav>
    }

    <main>
        @RenderBody()
    </main>

    <div class="toast-host" id="toastHost" aria-live="polite" aria-atomic="true"></div>

    @if (isAuth)
    {
        <!-- Story ko'rish oynasi (modal) -->
        <div class="story-viewer" id="storyViewer" hidden>
            <button type="button" class="story-close" data-story-close aria-label="Yopish">
                <span class="material-symbols-outlined">close</span>
            </button>
            <button type="button" class="story-nav story-prev" data-story-prev aria-label="Oldingi">
                <span class="material-symbols-outlined">chevron_left</span>
            </button>
            <div class="story-stage">
                <div class="story-progress" id="storyProgress"></div>
                <div class="story-author" id="storyAuthor"></div>
                <div class="story-image-wrap">
                    <img class="story-image" id="storyImage" src="" alt="Story" />
                </div>
                <div class="story-caption" id="storyCaption"></div>
                <div class="story-footer">
                    <span class="story-stat" title="Ko'rishlar">
                        <span class="material-symbols-outlined">visibility</span>
                        <span id="storyViewCount">0</span>
                    </span>
                    <button type="button" class="story-stat story-like-btn" id="storyLikeBtn" aria-label="Yoqtirish">
                        <span class="material-symbols-outlined">favorite</span>
                        <span id="storyLikeCount">0</span>
                    </button>
                    <button type="button" class="story-stat story-delete-btn" id="storyDeleteBtn" hidden aria-label="O'chirish">
                        <span class="material-symbols-outlined">delete</span>
                    </button>
                </div>
            </div>
            <button type="button" class="story-nav story-next" data-story-next aria-label="Keyingi">
                <span class="material-symbols-outlined">chevron_right</span>
            </button>
        </div>

        <!-- Story qo'shish oynasi (modal) -->
        <div class="modal-overlay" id="storyComposer" hidden>
            <div class="modal-box">
                <h3 class="modal-title">Story qo'shish</h3>
                <p class="muted" style="font-size:13px;margin-top:-6px">Sarlavha va matn kiriting, istasangiz rasm yuklang.</p>

                @Html.AntiForgeryToken()

                <div style="margin-top:12px">
                    <input class="input" id="storyTitleInput" placeholder="Sarlavha" autocomplete="off" maxlength="50" />
                    <div class="muted" style="font-size:12px;text-align:right;margin-top:4px">
                        <span id="storyTitleCount">0</span>/50
                    </div>
                </div>

                <div style="margin-top:8px">
                    <textarea class="input" id="storyTextInput" placeholder="Matn" rows="3" maxlength="140" style="resize:vertical"></textarea>
                    <div class="muted" style="font-size:12px;text-align:right;margin-top:4px">
                        <span id="storyTextCount">0</span>/140
                    </div>
                </div>

                <div class="composer-image-picker" style="margin-top:12px">
                    <input type="hidden" id="storyImageUrl" />
                    <div id="storyImgPreview" class="composer-image-preview" hidden>
                        <img id="storyImgPreviewImg" src="" alt="Tanlangan rasm" />
                        <button type="button" class="composer-image-remove" id="storyImgClear" aria-label="Rasmni o'chirish">
                            <span class="material-symbols-outlined">close</span>
                        </button>
                    </div>
                    <label class="btn btn-outline btn-sm" for="storyImageInput">
                        <span class="material-symbols-outlined" style="font-size:18px;vertical-align:bottom">image</span>
                        Rasm qo'shish (ixtiyoriy)
                    </label>
                    <input type="file" id="storyImageInput" accept="image/*" hidden />
                </div>

                <div style="margin-top:14px">
                    <label>Story qancha vaqt ko'rinsin?</label>
                    <div class="story-duration" id="storyDuration" role="radiogroup">
                        <button type="button" class="story-duration-opt" data-duration="12">12 soat</button>
                        <button type="button" class="story-duration-opt is-active" data-duration="24">24 soat</button>
                        <button type="button" class="story-duration-opt" data-duration="48">48 soat</button>
                    </div>
                </div>

                <p class="username-status" id="storyComposerError" data-state="bad" hidden></p>

                <div class="modal-actions">
                    <button type="button" class="btn btn-ghost" data-story-composer-cancel>Bekor qilish</button>
                    <button type="button" class="btn btn-primary" id="storyComposerSubmit" disabled>Joylash</button>
                </div>
            </div>
        </div>

        <!-- Ko'rinish sozlamalari oynasi -->
        <div class="modal-overlay" id="siteSettingsModal" hidden>
            <div class="modal-box" role="dialog" aria-modal="true" aria-label="Ko'rinish sozlamalari">
                <h3 class="modal-title">Ko'rinish sozlamalari</h3>

                <div class="settings-row">
                    <label for="settingBrightness">Sayt yorug'ligi <output id="settingBrightnessOut">40%</output></label>
                    <input type="range" id="settingBrightness" min="0" max="100" step="1" value="40" />
                </div>

                <div class="settings-row">
                    <label for="settingCardBlur">Karta xiralashuvi <output id="settingCardBlurOut">1.00</output></label>
                    <input type="range" id="settingCardBlur" min="0" max="1" step="0.05" value="1" />
                </div>

                <div class="settings-row">
                    <label for="settingCardBg">Fon yorug'ligi <output id="settingCardBgOut">50%</output></label>
                    <input type="range" id="settingCardBg" min="0" max="100" step="1" value="50" />
                </div>

                <div class="modal-actions">
                    <button type="button" class="btn btn-ghost" id="siteSettingsReset">Standart holat</button>
                    <button type="button" class="btn btn-primary" data-settings-close>Yopish</button>
                </div>
            </div>
        </div>

        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    }
    @if (isAuth)
    {
        <script>
        // --- Ko'rinish sozlamalari: navbardagi settings ikonasi butun saytda ishlaydi ---
        (function () {
            const toggle = document.getElementById("siteSettingsToggle");
            const modal = document.getElementById("siteSettingsModal");
            if (!toggle || !modal || !window.kgDisplaySettings) return;

            const brightness = document.getElementById("settingBrightness");
            const brightnessOut = document.getElementById("settingBrightnessOut");
            const cardBlur = document.getElementById("settingCardBlur");
            const cardBlurOut = document.getElementById("settingCardBlurOut");
            const cardBg = document.getElementById("settingCardBg");
            const cardBgOut = document.getElementById("settingCardBgOut");

            function syncInputs() {
                const s = kgDisplaySettings.get();
                brightness.value = s.brightness;
                brightnessOut.textContent = s.brightness + "%";
                cardBlur.value = s.cardBlur;
                cardBlurOut.textContent = Number(s.cardBlur).toFixed(2);
                cardBg.value = s.cardBg;
                cardBgOut.textContent = s.cardBg + "%";
            }

            function onChange() {
                brightnessOut.textContent = brightness.value + "%";
                cardBlurOut.textContent = parseFloat(cardBlur.value).toFixed(2);
                cardBgOut.textContent = cardBg.value + "%";
                kgDisplaySettings.save({
                    brightness: parseInt(brightness.value, 10),
                    cardBlur: parseFloat(cardBlur.value),
                    cardBg: parseInt(cardBg.value, 10)
                });
            }
            [brightness, cardBlur, cardBg].forEach((el) => el.addEventListener("input", onChange));

            document.getElementById("siteSettingsReset").addEventListener("click", () => {
                kgDisplaySettings.save(Object.assign({}, kgDisplaySettings.defaults));
                syncInputs();
            });

            function openModal() {
                syncInputs();
                modal.hidden = false;
                document.body.classList.add("modal-open");
            }
            function closeModal() {
                modal.hidden = true;
                document.body.classList.remove("modal-open");
            }
            toggle.addEventListener("click", openModal);
            modal.querySelectorAll("[data-settings-close]").forEach((el) => el.addEventListener("click", closeModal));
            modal.addEventListener("click", (e) => { if (e.target === modal) closeModal(); });
            document.addEventListener("keydown", (e) => { if (e.key === "Escape" && !modal.hidden) closeModal(); });
        })();
        </script>
    }
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @* PWA service worker — "bosh ekranga qo'shish"/o'rnatish va Android TWA sifati uchun.
       Tarmoq-birinchi strategiya: hech qachon eski (stale) sahifani ko'rsatmaydi. *@
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', function () {
                navigator.serviceWorker.register('/sw.js').catch(function () { /* jim: ixtiyoriy */ });
            });
        }
    </script>
    @if (isAuth)
    {
        <script src="~/js/push.js" asp-append-version="true"></script>
        <script src="~/js/year-review-scene.js" asp-append-version="true"></script>
        <script src="~/js/year-review.js" asp-append-version="true"></script>
    }
</body>
</html>
