@using KitobdaGimen.Application.Common.Interfaces
@inject ICurrentUserService CurrentUser
@model QuoteDto
@{
    var meId = CurrentUser.UserId;
    // Kanonik, ommaviy iqtibos manzili (/iqtibos/{id}) — ichki havolalar ham indekslanadigan
    // URL'ga ishora qilsin (crawler kuzatadi).
    var quoteUrl = KitobdaGimen.Web.ViewHelpers.QuoteUrl(Model.Author.Username, Model.Author.Id, Model.Slug);
    var quoteShareUrl = $"{Context.Request.Scheme}://{Context.Request.Host}{quoteUrl}";
    var avatarBody = !string.IsNullOrEmpty(Model.Author.AvatarUrl)
        ? Html.Raw($"<img class=\"avatar\" src=\"{Model.Author.AvatarUrl}\" alt=\"{Html.Encode(Model.Author.FullName)}\" referrerpolicy=\"no-referrer\" />")
        : Html.Raw($"<span class=\"avatar\">{Html.Encode(KitobdaGimen.Web.ViewHelpers.Initial(Model.Author.FullName))}</span>");
}

<article class="card post-card quote-feed-card" data-quote-id="@Model.Id">
    <header class="post-head">
        @if (Model.AuthorHasStory)
        {
            <span class="post-avatar-wrap has-story" data-open-story="@Model.Author.Id" role="button" tabindex="0" title="Story">
                @avatarBody
            </span>
        }
        else
        {
            <a class="post-avatar-wrap" href="@ViewHelpers.ProfileUrl(Model.Author.Username, Model.Author.Id)">
                @avatarBody
            </a>
        }
        <div class="meta">
            <div class="name-row">
                <a class="name" href="@ViewHelpers.ProfileUrl(Model.Author.Username, Model.Author.Id)">@Model.Author.FullName</a>
                @Html.Raw(KitobdaGimen.Web.ViewHelpers.FounderBadge(Model.Author.Username))
                <span class="badge badge-quote"><span class="material-symbols-outlined">format_quote</span>Iqtibos</span>
            </div>
            <div class="time">@KitobdaGimen.Web.ViewHelpers.RelativeTime(Model.CreatedAt)</div>
        </div>
    </header>

    <div class="quote-feed-body">
        <a class="post-body-link" href="@quoteUrl" aria-label="Iqtibosni ochish"></a>
        <div class="quote-feed-cover">
            @if (!string.IsNullOrEmpty(Model.Book.CoverUrl))
            {
                <img src="@Model.Book.CoverUrl" alt="@Model.Book.Title" loading="lazy" referrerpolicy="no-referrer" />
            }
            else
            {
                <span class="material-symbols-outlined">menu_book</span>
            }
        </div>
        <div class="quote-feed-main">
            <span class="quote-feed-mark material-symbols-outlined" aria-hidden="true">format_quote</span>
            <blockquote class="quote-feed-text">@Model.Text</blockquote>
            <div class="quote-feed-book">
                <span class="qfb-title">@Model.Book.Title</span>
                <span class="qfb-author">@Model.Book.Author</span>
                @Html.Raw(KitobdaGimen.Web.ViewHelpers.SourceCredit(Model.Book.Source))
            </div>
        </div>
    </div>

    <footer class="post-actions">
        <button class="action-btn like-btn @(Model.IsLikedByCurrentUser ? "liked" : "")" data-like-quote="@Model.Id" aria-label="Yoqtirish">
            <span class="material-symbols-outlined">favorite</span>
            <span class="like-count">@Model.LikeCount</span>
        </button>
        <a class="action-btn" href="@quoteUrl" aria-label="Izohlar">
            <span class="material-symbols-outlined">chat_bubble</span>
            <span>@Model.CommentCount</span>
        </a>
        <span class="action-btn action-static" aria-label="Ko'rishlar" title="Ko'rishlar">
            <span class="material-symbols-outlined">visibility</span>
            <span class="quote-view-count">@Model.ViewCount</span>
        </span>
        <span class="post-actions-end">
            <button type="button" class="action-btn" data-share-url="@quoteShareUrl" aria-label="Ulashish" title="Ulashish">
                <span class="material-symbols-outlined">share</span>
            </button>
            @if (meId != null && Model.Author.Id == meId)
            {
                <form method="post" action="/quotes/@Model.Id/delete" onsubmit="return confirm('Iqtibos o\'chirilsinmi?');" style="display:inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="action-btn danger" aria-label="O'chirish" title="O'chirish">
                        <span class="material-symbols-outlined">delete</span>
                    </button>
                </form>
            }
            else if (ViewData["IsAdmin"] as bool? ?? false)
            {
                <button type="button" class="action-btn danger" data-admin-delete-quote="@Model.Id"
                        title="Admin: iqtibosni o'chirish" aria-label="Admin: o'chirish">
                    <span class="material-symbols-outlined">delete</span>
                </button>
            }
        </span>
    </footer>
</article>
