@using KitobdaGimen.Application.Common.Interfaces
@using KitobdaGimen.Application.Features.Auth.Queries.GetCurrentUser
@using KitobdaGimen.Application.Features.Onboarding.Queries.GetGenres
@using MediatR
@inject ISender Mediator
@model PagedResult<FeedItemDto>
@{
    ViewData["Title"] = "Asosiy";
    var me = await Mediator.Send(new GetCurrentUserQuery());
    var meInitial = KitobdaGimen.Web.ViewHelpers.Initial(me?.FullName);
    var genres = await Mediator.Send(new GetGenresQuery());
    ViewData["ShowAuthorActions"] = true;
    var search = ViewData["Search"] as string ?? "";
}

<div class="container page">
    <div class="feed">
        <!-- Qidiruv -->
        <div class="feed-search-bar">
            <button class="action-btn" id="feedSearchToggle" title="Qidirish" aria-label="Qidirish">
                <span class="material-symbols-outlined">search</span>
            </button>
            <form method="get" action="/Feed" id="feedSearchForm" class="feed-search-form" style="@(string.IsNullOrEmpty(search) ? "display:none;" : "")">
                <div class="search-box">
                    <span class="search-ico material-symbols-outlined">search</span>
                    <input class="input" type="search" name="q" id="feedSearchInput"
                           placeholder="Taqriz matni, kitob, muallif yoki muallif ismi bo'yicha qidiring..."
                           value="@search" autocomplete="off" />
                </div>
            </form>
            @if (!string.IsNullOrEmpty(search))
            {
                <a class="btn btn-outline btn-sm" href="/Feed" id="feedSearchClear" title="Qidiruvni tozalash">
                    <span class="material-symbols-outlined ic-sm ic-baseline">close</span>
                    Tozalash
                </a>
            }
        </div>

        @if (!string.IsNullOrEmpty(search))
        {
            <div class="muted" style="margin-bottom:16px; font-size:14px">
                <strong>"@search"</strong> bo'yicha qidiruv natijalari —
                <a href="/Feed">barcha taqrizlarga qaytish</a>
            </div>
        }

        <!-- Post yaratish — qidiruvda yashiriladi, qidiruv tugagach qaytadi -->
        @if (string.IsNullOrEmpty(search))
        {
        <!-- Yopiq holatdagi tugma (bosilganda modal ochiladi) -->
        <button type="button" class="card composer-trigger" id="composerTrigger">
            @if (!string.IsNullOrEmpty(me?.AvatarUrl))
            {
                <img class="avatar" src="@me!.AvatarUrl" alt="@me.FullName" referrerpolicy="no-referrer" />
            }
            else
            {
                <span class="avatar">@meInitial</span>
            }
            <span class="composer-trigger-text">Qaysi kitob haqida fikr bildirasiz?</span>
            <span class="material-symbols-outlined composer-trigger-ico">edit_square</span>
        </button>

        <!-- Taqriz yoki iqtibos tanlash modali — kompozer tugmasi bosilganda birinchi shu ochiladi -->
        <div class="composer-modal" id="typeChoiceModal" hidden>
            <div class="composer-modal-backdrop" data-type-choice-close></div>
            <div class="composer-modal-box card" role="dialog" aria-modal="true" aria-label="Taqriz yoki iqtibos" style="max-width:340px">
                <div class="composer-modal-head">
                    <h3>Qaysi kitob haqida fikr bildirasiz?</h3>
                    <button type="button" class="composer-close" data-type-choice-close aria-label="Yopish">
                        <span class="material-symbols-outlined">close</span>
                    </button>
                </div>
                <div style="display:flex; flex-direction:column; gap:12px; padding:4px 0 8px">
                    <button type="button" class="btn btn-primary btn-block" id="chooseTaqriz">
                        <span class="material-symbols-outlined ic-sm ic-baseline">article</span>
                        Taqriz
                    </button>
                    <button type="button" class="btn btn-outline btn-block" id="chooseIqtibos">
                        <span class="material-symbols-outlined ic-sm ic-baseline">format_quote</span>
                        Iqtibos
                    </button>
                </div>
            </div>
        </div>

        <!-- Taqriz (post) modali -->
        <div class="composer-modal" id="composerModal" hidden>
            <div class="composer-modal-backdrop" data-composer-close></div>
            <div class="composer-modal-box card" role="dialog" aria-modal="true" aria-label="Yangi taqriz">
                <div class="composer-modal-head">
                    <h3>Qaysi kitob haqida fikr bildirasiz?</h3>
                    <button type="button" class="composer-close" data-composer-close aria-label="Yopish">
                        <span class="material-symbols-outlined">close</span>
                    </button>
                </div>

            <form id="postForm" method="post" action="/posts/create">
                @Html.AntiForgeryToken()
                <input type="hidden" name="BookId" id="bookId" />

                <!-- Tanlangan kitob (tanlangach ko'rinadi) -->
                <div id="selectedBook" class="composer-selected" hidden>
                    <span class="material-symbols-outlined">menu_book</span>
                    <span id="selectedBookLabel"></span>
                    <button type="button" class="composer-clear" id="clearBook" aria-label="Bekor qilish">
                        <span class="material-symbols-outlined">close</span>
                    </button>
                </div>

                <!-- Kitob qidirish / qo'shish (kitob tanlanmaganda ko'rinadi) -->
                <div id="bookPicker">
                    <div class="composer-book">
                        <input class="input" id="bookSearch" placeholder="Kitobni qidiring..." autocomplete="off" />
                        <button type="button" class="btn btn-outline btn-sm" id="newBookToggle">Yangi kitob</button>
                        <button type="button" class="btn btn-ghost btn-sm" data-asaxiy-refresh="#bookSearch"
                                title="Kitob qidiruvi ishlamayaptimi? Bosing — qayta ishga tushadi.">
                            <span class="material-symbols-outlined ic-sm ic-baseline">refresh</span>
                            Kitoblarni yangilash
                        </button>
                    </div>
                    <div class="book-suggestions" id="bookSuggestions" hidden></div>

                    <div id="newBookForm" class="composer-newbook stack" hidden>
                        <input class="input" id="nbTitle" placeholder="Kitob nomi" minlength="3" maxlength="100" />
                        <input class="input" id="nbAuthor" placeholder="Muallif" minlength="3" maxlength="100" />
                        <input class="input" id="nbPages" type="number" min="1" max="100000" placeholder="Sahifalar soni" />
                        <select class="input" id="nbGenre">
                            <option value="">Kategoriyani tanlang</option>
                            @foreach (var genre in genres)
                            {
                                <option value="@genre.Id">@genre.Name</option>
                            }
                        </select>

                        <div class="nb-cover">
                            <div class="nb-cover-preview" id="nbCoverPreview">
                                <span class="material-symbols-outlined">image</span>
                            </div>
                            <div class="nb-cover-actions">
                                <label class="btn btn-outline btn-sm" for="nbCover">Muqova rasmi</label>
                                <input type="file" id="nbCover" accept="image/*" hidden />
                                <button type="button" class="btn btn-ghost btn-sm" id="nbCoverClear" hidden>O'chirish</button>
                                <span class="muted" id="nbCoverHint" style="font-size:12px">Ixtiyoriy — JPG/PNG, 5 MB gacha.</span>
                            </div>
                        </div>

                        <button type="button" class="btn btn-outline btn-sm" id="nbSave">Kitobni qo'shish</button>
                    </div>
                </div>

                <partial name="_RichEditor" model='new KitobdaGimen.Web.Models.RichEditorModel { Name = "ReviewText", Placeholder = "Kitob haqida fikringizni yozing...", MinLength = 3, MaxLength = 5000 }' />


                <div class="composer-image-picker">
                    <input type="hidden" name="ImageUrl" id="postImageUrl" />
                    <div id="postImagePreview" class="composer-image-preview" hidden>
                        <img id="postImagePreviewImg" src="" alt="Tanlangan rasm" />
                        <button type="button" class="composer-image-remove" id="postImageClear" aria-label="Rasmni o'chirish">
                            <span class="material-symbols-outlined">close</span>
                        </button>
                    </div>
                    <label class="btn btn-outline btn-sm" for="postImage">
                        <span class="material-symbols-outlined ic-sm ic-baseline">image</span>
                        Rasm qo'shish
                    </label>
                    <input type="file" id="postImage" accept="image/*" hidden />
                </div>

                <div class="composer-actions">
                    <span class="muted" id="composerHint" style="font-size:13px">Avval kitobni tanlang yoki qo'shing.</span>
                    <button type="submit" class="btn btn-primary" id="postSubmit" disabled>Joylash</button>
                </div>
            </form>
            </div>
        </div>

        <!-- Iqtibos modali -->
        <div class="composer-modal" id="quoteComposerModal" hidden>
            <div class="composer-modal-backdrop" data-quote-composer-close></div>
            <div class="composer-modal-box card" role="dialog" aria-modal="true" aria-label="Yangi iqtibos">
                <div class="composer-modal-head">
                    <h3>Qaysi kitobdan iqtibos qo'shasiz?</h3>
                    <button type="button" class="composer-close" data-quote-composer-close aria-label="Yopish">
                        <span class="material-symbols-outlined">close</span>
                    </button>
                </div>

            <form id="quoteComposerForm" method="post" action="/quotes/create">
                @Html.AntiForgeryToken()
                <input type="hidden" name="BookId" id="quoteBookId" />

                <!-- Tanlangan kitob (tanlangach ko'rinadi) -->
                <div id="quoteSelectedBook" class="composer-selected" hidden>
                    <span class="material-symbols-outlined">menu_book</span>
                    <span id="quoteSelectedBookLabel"></span>
                    <button type="button" class="composer-clear" id="quoteClearBook" aria-label="Bekor qilish">
                        <span class="material-symbols-outlined">close</span>
                    </button>
                </div>

                <!-- Kitob qidirish / qo'shish (kitob tanlanmaganda ko'rinadi) -->
                <div id="quoteBookPicker">
                    <div class="composer-book">
                        <input class="input" id="quoteBookSearch" placeholder="Kitobni qidiring..." autocomplete="off" />
                        <button type="button" class="btn btn-outline btn-sm" id="quoteNewBookToggle">Yangi kitob</button>
                        <button type="button" class="btn btn-ghost btn-sm" data-asaxiy-refresh="#quoteBookSearch"
                                title="Kitob qidiruvi ishlamayaptimi? Bosing — qayta ishga tushadi.">
                            <span class="material-symbols-outlined ic-sm ic-baseline">refresh</span>
                            Kitoblarni yangilash
                        </button>
                    </div>
                    <div class="book-suggestions" id="quoteBookSuggestions" hidden></div>

                    <div id="quoteNewBookForm" class="composer-newbook stack" hidden>
                        <input class="input" id="qNbTitle" placeholder="Kitob nomi" minlength="3" maxlength="100" />
                        <input class="input" id="qNbAuthor" placeholder="Muallif" minlength="3" maxlength="100" />
                        <input class="input" id="qNbPages" type="number" min="1" max="100000" placeholder="Sahifalar soni" />
                        <select class="input" id="qNbGenre">
                            <option value="">Kategoriyani tanlang</option>
                            @foreach (var genre in genres)
                            {
                                <option value="@genre.Id">@genre.Name</option>
                            }
                        </select>

                        <div class="nb-cover">
                            <div class="nb-cover-preview" id="qNbCoverPreview">
                                <span class="material-symbols-outlined">image</span>
                            </div>
                            <div class="nb-cover-actions">
                                <label class="btn btn-outline btn-sm" for="qNbCover">Muqova rasmi</label>
                                <input type="file" id="qNbCover" accept="image/*" hidden />
                                <button type="button" class="btn btn-ghost btn-sm" id="qNbCoverClear" hidden>O'chirish</button>
                                <span class="muted" id="qNbCoverHint" style="font-size:12px">Ixtiyoriy — JPG/PNG, 5 MB gacha.</span>
                            </div>
                        </div>

                        <button type="button" class="btn btn-outline btn-sm" id="qNbSave">Kitobni qo'shish</button>
                    </div>
                </div>

                <textarea class="input" name="Text" id="quoteText" placeholder="Iqtibos matni..." minlength="3" maxlength="400" required></textarea>

                <div class="composer-actions">
                    <span class="muted" id="quoteComposerHint" style="font-size:13px">Avval kitobni tanlang yoki qo'shing.</span>
                    <button type="submit" class="btn btn-primary" id="quoteSubmit" disabled>Saqlash</button>
                </div>
            </form>
            </div>
        </div>
        }

        <!-- Postlar -->
        @if (Model.Items.Count == 0)
        {
            <div class="card empty-state">
                <span class="material-symbols-outlined">@(string.IsNullOrEmpty(search) ? "auto_stories" : "search_off")</span>
                <p>
                    @(string.IsNullOrEmpty(search)
                        ? "Hozircha taqriz yo'q. Birinchi bo'lib fikr ulashing yoki boshqa kitobxonlarni kuzating!"
                        : $"\"{search}\" bo'yicha taqriz topilmadi.")
                </p>
            </div>
        }
        else
        {
            @foreach (var item in Model.Items)
            {
                if (item.Kind == "quote" && item.Quote is not null)
                {
                    <partial name="_QuoteFeedCard" model="item.Quote" />
                }
                else if (item.Post is not null)
                {
                    <partial name="_PostCard" model="item.Post" />
                }
            }
        }

        <!-- Pastga tushganda keyingi postlar shu yerga animatsiya bilan qo'shiladi -->
        <div class="infinite-loader" id="feedLoader" hidden>
            <span class="spinner"></span>
        </div>
        <div id="feedSentinel" aria-hidden="true"
             data-page="@Model.Page" data-total-pages="@Model.TotalPages" data-search="@search"></div>
    </div>
</div>

@section Scripts {
<script>
// --- Kompozer tugmasi bosilganda avval "Taqriz yoki Iqtibos" tanlash modali ochiladi;
// tanlovga qarab tegishli modal (taqriz yoki iqtibos) ochiladi. Escape/backdrop/close hammasini yopadi. ---
(function () {
    const trigger = document.getElementById("composerTrigger");
    const typeModal = document.getElementById("typeChoiceModal");
    const postModal = document.getElementById("composerModal");
    const quoteModal = document.getElementById("quoteComposerModal");
    if (!trigger || !typeModal || !postModal || !quoteModal) return;

    function openModal(modal, focusId) {
        modal.hidden = false;
        document.body.classList.add("modal-open");
        const focusTarget = focusId && document.getElementById(focusId);
        if (focusTarget) setTimeout(() => focusTarget.focus(), 50);
    }
    function closeModal(modal) {
        modal.hidden = true;
        document.body.classList.remove("modal-open");
    }
    function closeAll() {
        [typeModal, postModal, quoteModal].forEach(closeModal);
    }

    trigger.addEventListener("click", () => openModal(typeModal));
    typeModal.querySelectorAll("[data-type-choice-close]").forEach((el) => el.addEventListener("click", () => closeModal(typeModal)));
    postModal.querySelectorAll("[data-composer-close]").forEach((el) => el.addEventListener("click", () => closeModal(postModal)));
    quoteModal.querySelectorAll("[data-quote-composer-close]").forEach((el) => el.addEventListener("click", () => closeModal(quoteModal)));

    document.getElementById("chooseTaqriz").addEventListener("click", () => {
        closeModal(typeModal);
        openModal(postModal, "bookSearch");
    });
    document.getElementById("chooseIqtibos").addEventListener("click", () => {
        closeModal(typeModal);
        openModal(quoteModal, "quoteBookSearch");
    });

    document.addEventListener("keydown", (e) => {
        if (e.key !== "Escape") return;
        if (!typeModal.hidden) closeModal(typeModal);
        else if (!postModal.hidden) closeModal(postModal);
        else if (!quoteModal.hidden) closeModal(quoteModal);
    });
})();

// --- Qidiruv: ikona bosilganda qidiruv maydonini ochish/yopish ---
(function () {
    const searchForm = document.getElementById("feedSearchForm");
    const searchInput = document.getElementById("feedSearchInput");
    document.getElementById("feedSearchToggle").addEventListener("click", () => {
        const open = searchForm.style.display !== "none";
        searchForm.style.display = open ? "none" : "block";
        if (!open) searchInput.focus();
    });

    // --- Topilgan so'zlarni yashil rang bilan belgilash (highlight) ---
    const term = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(search));
    function highlightCards(cards) {
        if (!term || !term.trim()) return;
        const needle = term.trim().toLowerCase();
        const escaped = needle.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
        const rx = new RegExp("(" + escaped + ")", "gi");

        const highlightNode = (node) => {
            if (node.nodeType === Node.TEXT_NODE) {
                if (!node.nodeValue.toLowerCase().includes(needle)) return;
                const frag = document.createDocumentFragment();
                let last = 0;
                node.nodeValue.replace(rx, (match, _g, offset) => {
                    if (offset > last) frag.appendChild(document.createTextNode(node.nodeValue.slice(last, offset)));
                    const mark = document.createElement("mark");
                    mark.className = "search-mark";
                    mark.textContent = match;
                    frag.appendChild(mark);
                    last = offset + match.length;
                    return match;
                });
                if (last < node.nodeValue.length) frag.appendChild(document.createTextNode(node.nodeValue.slice(last)));
                node.parentNode.replaceChild(frag, node);
            } else if (node.nodeType === Node.ELEMENT_NODE && node.tagName !== "MARK") {
                [...node.childNodes].forEach(highlightNode);
            }
        };

        // Post/iqtibos matni, kitob nomi/muallifi va muallif ismi bo'yicha
        cards.forEach((card) => {
            card.querySelectorAll(".post-text, .post-book-title, .post-book-author, .quote-feed-text, .qfb-title, .qfb-author, .name").forEach(highlightNode);
        });
    }
    highlightCards(Array.from(document.querySelectorAll(".post-card")));

    // --- Cheksiz skroll: pastga tushganda keyingi postlarni yuklash ---
    const sentinel = document.getElementById("feedSentinel");
    if (sentinel && window.kitob && kitob.infiniteScroll) {
        const loader = document.getElementById("feedLoader");
        kitob.infiniteScroll({
            sentinel,
            container: document.querySelector(".feed"),
            insertBefore: loader,
            loader,
            endpoint: "/Feed/cards",
            page: parseInt(sentinel.dataset.page, 10) || 1,
            totalPages: parseInt(sentinel.dataset.totalPages, 10) || 1,
            search: sentinel.dataset.search || "",
            restoreKey: "feed",
            onAppend: (nodes) => {
                highlightCards(nodes);
                if (kitob.initRichEditors) nodes.forEach((n) => kitob.initRichEditors(n));
                if (kitob.observeQuoteViews) nodes.forEach((n) => kitob.observeQuoteViews(n));
            }
        });
    }
})();

(function () {
    const form = document.getElementById("postForm");
    if (!form) return; // Qidiruv rejimida composer yo'q
    const bookIdInput = document.getElementById("bookId");
    const bookPicker = document.getElementById("bookPicker");
    const search = document.getElementById("bookSearch");
    const suggestions = document.getElementById("bookSuggestions");
    const selectedBook = document.getElementById("selectedBook");
    const selectedLabel = document.getElementById("selectedBookLabel");
    const newBookForm = document.getElementById("newBookForm");
    let searchTimer;
    const submitBtn = document.getElementById("postSubmit");
    const hint = document.getElementById("composerHint");
    const reviewText = form.querySelector("[name='ReviewText']");
    const reviewEditor = form.querySelector("[data-rich-editor]");
    const nbCover = document.getElementById("nbCover");
    const nbCoverPreview = document.getElementById("nbCoverPreview");
    const nbCoverClear = document.getElementById("nbCoverClear");
    const nbCoverHint = document.getElementById("nbCoverHint");
    const postImage = document.getElementById("postImage");
    const postImagePreview = document.getElementById("postImagePreview");
    const postImagePreviewImg = document.getElementById("postImagePreviewImg");
    const postImageClear = document.getElementById("postImageClear");
    const postImageUrl = document.getElementById("postImageUrl");
    let coverUrl = null;       // server URL once uploaded
    let coverFile = null;      // pending file chosen by the user
    let imageUploading = false; // post image upload in progress

    function resetCover() {
        coverUrl = null;
        coverFile = null;
        nbCover.value = "";
        nbCoverPreview.innerHTML = '<span class="material-symbols-outlined">image</span>';
        nbCoverClear.hidden = true;
        nbCoverHint.textContent = "Ixtiyoriy — JPG/PNG, 5 MB gacha.";
    }

    nbCover.addEventListener("change", () => {
        const f = nbCover.files && nbCover.files[0];
        if (!f) { resetCover(); return; }
        coverFile = f;
        coverUrl = null; // re-upload on next save
        nbCoverClear.hidden = false;
        nbCoverHint.textContent = f.name;
        const reader = new FileReader();
        reader.onload = (ev) => {
            nbCoverPreview.innerHTML = "";
            const img = document.createElement("img");
            img.src = ev.target.result;
            nbCoverPreview.appendChild(img);
        };
        reader.readAsDataURL(f);
    });

    nbCoverClear.addEventListener("click", resetCover);

    async function uploadCover(file) {
        const fd = new FormData();
        fd.append("file", file);
        const res = await fetch("/books/upload-cover", {
            method: "POST",
            headers: {
                "X-Requested-With": "XMLHttpRequest",
                "RequestVerificationToken": kitob.antiforgeryToken()
            },
            body: fd
        });
        if (res.status === 401) { window.location.href = "/"; return null; }
        if (!res.ok) {
            let message = "Rasmni yuklab bo'lmadi.";
            try { const d = await res.json(); message = d.message || message; } catch { /* ignore */ }
            throw new Error(message);
        }
        const data = await res.json();
        return data.url;
    }

    function refreshState() {
        const hasBook = !!bookIdInput.value;
        const hasText = (reviewText.value || "").trim().length > 0;
        submitBtn.disabled = !(hasBook && hasText) || imageUploading;
        if (imageUploading) hint.textContent = "Rasm yuklanmoqda...";
        else if (!hasBook) hint.textContent = "Avval kitobni tanlang yoki qo'shing.";
        else if (!hasText) hint.textContent = "Endi fikringizni yozing.";
        else hint.textContent = "Tayyor — fikringizni joylashingiz mumkin.";
    }

    function resetPostImage() {
        postImage.value = "";
        postImageUrl.value = "";
        if (postImagePreviewImg.src) URL.revokeObjectURL(postImagePreviewImg.src);
        postImagePreviewImg.src = "";
        postImagePreview.hidden = true;
        imageUploading = false;
        refreshState();
    }

    postImage.addEventListener("change", async () => {
        const f = postImage.files && postImage.files[0];
        if (!f) return;

        // Base64 (FileReader) o'rniga obyekt-URL — telefon kamerasidan olingan katta
        // rasmlarda ham darhol va ishonchli ko'rinadi (base64 kodlash sekin/xotira talab qiladi).
        if (postImagePreviewImg.src) URL.revokeObjectURL(postImagePreviewImg.src);
        postImagePreviewImg.src = URL.createObjectURL(f);
        postImagePreview.hidden = false;

        postImageUrl.value = "";
        imageUploading = true;
        refreshState();
        try {
            const fd = new FormData();
            fd.append("file", f);
            const res = await fetch("/posts/upload-image", {
                method: "POST",
                headers: {
                    "X-Requested-With": "XMLHttpRequest",
                    "RequestVerificationToken": kitob.antiforgeryToken()
                },
                body: fd
            });
            if (res.status === 401) { window.location.href = "/"; return; }
            if (!res.ok) {
                let message = "Rasmni yuklab bo'lmadi.";
                try { const d = await res.json(); message = d.message || message; } catch { /* ignore */ }
                throw new Error(message);
            }
            const data = await res.json();
            postImageUrl.value = data.url;
        } catch (err) {
            alert(err.message);
            resetPostImage();
            return;
        } finally {
            imageUploading = false;
            refreshState();
        }
    });

    postImageClear.addEventListener("click", resetPostImage);

    function pickBook(book) {
        bookIdInput.value = book.id;
        selectedLabel.textContent = `${book.title} — ${book.author}`;
        selectedBook.hidden = false;
        bookPicker.hidden = true;
        suggestions.hidden = true;
        suggestions.innerHTML = "";
        search.value = "";
        refreshState();
    }

    function clearBook() {
        bookIdInput.value = "";
        selectedBook.hidden = true;
        bookPicker.hidden = false;
        refreshState();
    }

    document.getElementById("clearBook").addEventListener("click", clearBook);
    if (reviewEditor) reviewEditor.addEventListener("rich:input", refreshState);

    // --- Kitob qidirish ---
    search.addEventListener("input", () => {
        clearTimeout(searchTimer);
        const q = search.value.trim();
        if (q.length < 2) { suggestions.hidden = true; return; }
        suggestions.dataset.q = q;
        searchTimer = setTimeout(async () => {
            try {
                const res = await fetch(`/books/search?q=${encodeURIComponent(q)}`, { headers: { "X-Requested-With": "XMLHttpRequest" } });
                if (!res.ok) return;
                const books = await res.json();
                suggestions.innerHTML = "";
                books.forEach(b => {
                    const div = document.createElement("div");
                    div.textContent = `${b.title} — ${b.author} (${b.totalPages} bet)`;
                    div.addEventListener("click", () => pickBook(b));
                    suggestions.appendChild(div);
                });
                suggestions.hidden = books.length === 0;
                window.kitob.renderAsaxiyBooks(q, suggestions, pickBook);
            } catch { /* tarmoq xatosi — jim o'tkazamiz */ }
        }, 250);
    });

    document.getElementById("newBookToggle").addEventListener("click", () => {
        newBookForm.hidden = !newBookForm.hidden;
    });

    const nbSave = document.getElementById("nbSave");
    nbSave.addEventListener("click", async () => {
        const genreId = parseInt(document.getElementById("nbGenre").value, 10) || 0;
        const command = {
            title: document.getElementById("nbTitle").value.trim(),
            author: document.getElementById("nbAuthor").value.trim(),
            totalPages: parseInt(document.getElementById("nbPages").value, 10) || 0,
            genreId: genreId || null
        };
        if (!command.title || !command.author || command.totalPages <= 0) {
            alert("Kitob nomi, muallif va sahifalar sonini kiriting.");
            return;
        }
        if (command.title.length < 3 || command.title.length > 100) {
            alert("Kitob nomi 3 dan 100 tagacha belgidan iborat bo'lishi kerak.");
            return;
        }
        if (command.author.length < 3 || command.author.length > 100) {
            alert("Muallif nomi 3 dan 100 tagacha belgidan iborat bo'lishi kerak.");
            return;
        }
        if (command.totalPages > 100000) {
            alert("Sahifalar soni juda katta.");
            return;
        }
        if (!genreId) {
            alert("Kitob kategoriyasini tanlang.");
            return;
        }
        nbSave.disabled = true;
        try {
            // Upload the cover first (if chosen) so the book is created with its URL.
            if (coverFile && !coverUrl) {
                coverUrl = await uploadCover(coverFile);
            }
            if (coverUrl) command.coverUrl = coverUrl;

            const book = await kitob.apiPost("/books/create", command);
            if (book) pickBook(book);
            newBookForm.hidden = true;
            resetCover();
        } catch (err) { alert(err.message); }
        finally { nbSave.disabled = false; }
    });

    form.addEventListener("submit", (e) => {
        if (reviewEditor && reviewEditor.richEditor) reviewEditor.richEditor.sync();
        if (!bookIdInput.value) {
            e.preventDefault();
            alert("Avval kitobni tanlang yoki qo'shing.");
        } else if (!(reviewText.value || "").trim()) {
            e.preventDefault();
            alert("Kitob haqida fikringizni yozing.");
        } else if (reviewEditor && reviewEditor.richEditor && reviewEditor.richEditor.check().tooShort) {
            e.preventDefault();
            alert("Fikr kamida 3 belgidan iborat bo'lishi kerak.");
        } else if (reviewEditor && reviewEditor.richEditor && reviewEditor.richEditor.check().tooLong) {
            e.preventDefault();
            alert("Fikr 5000 belgidan oshmasligi kerak.");
        } else if (imageUploading) {
            e.preventDefault();
            alert("Rasm hali yuklanmoqda, biroz kuting.");
        }
    });

    refreshState();
})();

// --- Iqtibos qo'shish formasi: kitob tanlash/qo'shish + matn ---
(function () {
    const form = document.getElementById("quoteComposerForm");
    if (!form) return; // Qidiruv rejimida composer yo'q
    const bookIdInput = document.getElementById("quoteBookId");
    const bookPicker = document.getElementById("quoteBookPicker");
    const search = document.getElementById("quoteBookSearch");
    const suggestions = document.getElementById("quoteBookSuggestions");
    const selectedBook = document.getElementById("quoteSelectedBook");
    const selectedLabel = document.getElementById("quoteSelectedBookLabel");
    const newBookForm = document.getElementById("quoteNewBookForm");
    let searchTimer;
    const submitBtn = document.getElementById("quoteSubmit");
    const hint = document.getElementById("quoteComposerHint");
    const quoteText = document.getElementById("quoteText");
    const nbCover = document.getElementById("qNbCover");
    const nbCoverPreview = document.getElementById("qNbCoverPreview");
    const nbCoverClear = document.getElementById("qNbCoverClear");
    const nbCoverHint = document.getElementById("qNbCoverHint");
    let coverUrl = null;       // server URL once uploaded
    let coverFile = null;      // pending file chosen by the user

    function resetCover() {
        coverUrl = null;
        coverFile = null;
        nbCover.value = "";
        nbCoverPreview.innerHTML = '<span class="material-symbols-outlined">image</span>';
        nbCoverClear.hidden = true;
        nbCoverHint.textContent = "Ixtiyoriy — JPG/PNG, 5 MB gacha.";
    }

    nbCover.addEventListener("change", () => {
        const f = nbCover.files && nbCover.files[0];
        if (!f) { resetCover(); return; }
        coverFile = f;
        coverUrl = null; // re-upload on next save
        nbCoverClear.hidden = false;
        nbCoverHint.textContent = f.name;
        const reader = new FileReader();
        reader.onload = (ev) => {
            nbCoverPreview.innerHTML = "";
            const img = document.createElement("img");
            img.src = ev.target.result;
            nbCoverPreview.appendChild(img);
        };
        reader.readAsDataURL(f);
    });

    nbCoverClear.addEventListener("click", resetCover);

    async function uploadCover(file) {
        const fd = new FormData();
        fd.append("file", file);
        const res = await fetch("/books/upload-cover", {
            method: "POST",
            headers: {
                "X-Requested-With": "XMLHttpRequest",
                "RequestVerificationToken": kitob.antiforgeryToken()
            },
            body: fd
        });
        if (res.status === 401) { window.location.href = "/"; return null; }
        if (!res.ok) {
            let message = "Rasmni yuklab bo'lmadi.";
            try { const d = await res.json(); message = d.message || message; } catch { /* ignore */ }
            throw new Error(message);
        }
        const data = await res.json();
        return data.url;
    }

    function refreshState() {
        const hasBook = !!bookIdInput.value;
        const hasText = (quoteText.value || "").trim().length > 0;
        submitBtn.disabled = !(hasBook && hasText);
        if (!hasBook) hint.textContent = "Avval kitobni tanlang yoki qo'shing.";
        else if (!hasText) hint.textContent = "Endi iqtibos matnini yozing.";
        else hint.textContent = "Tayyor — iqtibosni saqlashingiz mumkin.";
    }

    function pickBook(book) {
        bookIdInput.value = book.id;
        selectedLabel.textContent = `${book.title} — ${book.author}`;
        selectedBook.hidden = false;
        bookPicker.hidden = true;
        suggestions.hidden = true;
        suggestions.innerHTML = "";
        search.value = "";
        refreshState();
    }

    function clearBook() {
        bookIdInput.value = "";
        selectedBook.hidden = true;
        bookPicker.hidden = false;
        refreshState();
    }

    document.getElementById("quoteClearBook").addEventListener("click", clearBook);
    quoteText.addEventListener("input", refreshState);

    // --- Kitob qidirish ---
    search.addEventListener("input", () => {
        clearTimeout(searchTimer);
        const q = search.value.trim();
        if (q.length < 2) { suggestions.hidden = true; return; }
        suggestions.dataset.q = q;
        searchTimer = setTimeout(async () => {
            try {
                const res = await fetch(`/books/search?q=${encodeURIComponent(q)}`, { headers: { "X-Requested-With": "XMLHttpRequest" } });
                if (!res.ok) return;
                const books = await res.json();
                suggestions.innerHTML = "";
                books.forEach(b => {
                    const div = document.createElement("div");
                    div.textContent = `${b.title} — ${b.author} (${b.totalPages} bet)`;
                    div.addEventListener("click", () => pickBook(b));
                    suggestions.appendChild(div);
                });
                suggestions.hidden = books.length === 0;
                window.kitob.renderAsaxiyBooks(q, suggestions, pickBook);
            } catch { /* tarmoq xatosi — jim o'tkazamiz */ }
        }, 250);
    });

    document.getElementById("quoteNewBookToggle").addEventListener("click", () => {
        newBookForm.hidden = !newBookForm.hidden;
    });

    const nbSave = document.getElementById("qNbSave");
    nbSave.addEventListener("click", async () => {
        const genreId = parseInt(document.getElementById("qNbGenre").value, 10) || 0;
        const command = {
            title: document.getElementById("qNbTitle").value.trim(),
            author: document.getElementById("qNbAuthor").value.trim(),
            totalPages: parseInt(document.getElementById("qNbPages").value, 10) || 0,
            genreId: genreId || null
        };
        if (!command.title || !command.author || command.totalPages <= 0) {
            alert("Kitob nomi, muallif va sahifalar sonini kiriting.");
            return;
        }
        if (command.title.length < 3 || command.title.length > 100) {
            alert("Kitob nomi 3 dan 100 tagacha belgidan iborat bo'lishi kerak.");
            return;
        }
        if (command.author.length < 3 || command.author.length > 100) {
            alert("Muallif nomi 3 dan 100 tagacha belgidan iborat bo'lishi kerak.");
            return;
        }
        if (command.totalPages > 100000) {
            alert("Sahifalar soni juda katta.");
            return;
        }
        if (!genreId) {
            alert("Kitob kategoriyasini tanlang.");
            return;
        }
        nbSave.disabled = true;
        try {
            // Upload the cover first (if chosen) so the book is created with its URL.
            if (coverFile && !coverUrl) {
                coverUrl = await uploadCover(coverFile);
            }
            if (coverUrl) command.coverUrl = coverUrl;

            const book = await kitob.apiPost("/books/create", command);
            if (book) pickBook(book);
            newBookForm.hidden = true;
            resetCover();
        } catch (err) { alert(err.message); }
        finally { nbSave.disabled = false; }
    });

    form.addEventListener("submit", (e) => {
        if (!bookIdInput.value) {
            e.preventDefault();
            alert("Avval kitobni tanlang yoki qo'shing.");
        } else if (!(quoteText.value || "").trim()) {
            e.preventDefault();
            alert("Iqtibos matnini yozing.");
        }
    });

    refreshState();
})();
</script>
}
