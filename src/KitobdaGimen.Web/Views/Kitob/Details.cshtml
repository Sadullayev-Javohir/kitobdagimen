@using KitobdaGimen.Application.Common.Interfaces
@inject ICurrentUserService CurrentUser
@model KitobdaGimen.Application.Features.Books.Queries.GetBookPage.BookPageDto
@{
    // Sarlavha kitob nomi bilan boshlanadi — Google'da kitob nomi qidirilganda
    // aynan shu jamlovchi sahifa eng kuchli javob bo'lsin.
    ViewData["Title"] = $"{Model.Title} — {Model.Author}: taqrizlar va iqtiboslar";
    var isAuth = CurrentUser.IsAuthenticated;
    var bookUrl = ViewHelpers.BookUrl(Model.Id, Model.Title);
    var seoBase = $"{Context.Request.Scheme}://{Context.Request.Host}";
    var shareUrl = $"{seoBase}{bookUrl}";
    var loginUrl = "/auth/google-login?returnUrl=" + Uri.EscapeDataString(bookUrl);

    // --- SEO: ommaviy, indekslanadigan sahifa ---
    var seoDesc = $"\"{Model.Title}\" ({Model.Author}) kitobi haqida {Model.Posts.Count} ta taqriz va {Model.Quotes.Count} ta iqtibos. Kitobxonlar fikrlari — kitobdagimen.uz da.";
    string? seoImg = Model.CoverUrl;
    if (!string.IsNullOrEmpty(seoImg) && seoImg.StartsWith("/")) seoImg = seoBase + seoImg;
    ViewData["Description"] = seoDesc;
    ViewData["Canonical"] = shareUrl;
    ViewData["Robots"] = "index, follow, max-image-preview:large";
    if (!string.IsNullOrEmpty(seoImg)) { ViewData["OgImage"] = seoImg; }
    ViewData["JsonLd"] = KitobdaGimen.Web.Seo.SeoJsonLd.BookPage(
        url: shareUrl,
        bookTitle: Model.Title,
        bookAuthor: Model.Author,
        imageUrl: seoImg,
        reviewCount: Model.Posts.Count,
        quoteCount: Model.Quotes.Count);

    // Taqriz matnidan toza (HTMLsiz) parcha — kartochkada ko'rsatish uchun.
    static string Excerpt(string html, int max)
    {
        var plain = System.Text.RegularExpressions.Regex.Replace(
            KitobdaGimen.Application.Common.RichTextSanitizer.Sanitize(html), "<[^>]+>", " ");
        plain = System.Net.WebUtility.HtmlDecode(plain);
        plain = System.Text.RegularExpressions.Regex.Replace(plain, "\\s+", " ").Trim();
        return plain.Length > max ? plain[..(max - 1)].TrimEnd() + "…" : plain;
    }
}

<div class="container page pd-page">
    @if (!isAuth)
    {
        <div class="anon-banner">
            <a class="brand" href="/">
                <img class="brand-logo" src="~/img/logo.svg" alt="kitobdagimen.uz logotipi" />
                <span>kitobdagimen<span style="color:var(--accent)">.uz</span></span>
            </a>
            <p>Kitobxonlar jamoasiga qo'shilib, siz ham "@Model.Title" haqida fikr ulashing!</p>
            <a class="btn btn-accent" href="@loginUrl">Ro'yxatdan o'tish</a>
        </div>
    }
    else
    {
        <a class="btn btn-ghost btn-sm pd-back" href="/Feed">
            <span class="material-symbols-outlined" style="font-size:18px">arrow_back</span>
            Asosiyga
        </a>
    }

    <!-- Kitob sarlavhasi -->
    <article class="card pd-article" style="margin-bottom:16px">
        <div class="quote-feed-body" style="padding-left:0;padding-right:0">
            <div class="quote-feed-cover">
                @if (!string.IsNullOrEmpty(Model.CoverUrl))
                {
                    <img src="@Model.CoverUrl" alt="@Model.Title — @Model.Author kitobi muqovasi" referrerpolicy="no-referrer" />
                }
                else
                {
                    <span class="material-symbols-outlined">menu_book</span>
                }
            </div>
            <div class="quote-feed-main">
                <div class="pd-bookhead" style="margin:0">
                    <h1>@Model.Title</h1>
                    <p class="pd-book-author">@Model.Author</p>
                    @Html.Raw(ViewHelpers.SourceCredit(Model.Source))
                    @if (!string.IsNullOrEmpty(Model.GenreName))
                    {
                        <div class="pd-genres">
                            <span class="pd-genre">
                                <span class="material-symbols-outlined">local_library</span>
                                @Model.GenreName
                            </span>
                        </div>
                    }
                </div>
                <div class="pd-stats" style="margin-top:10px">
                    <span><span class="material-symbols-outlined">rate_review</span> @Model.Posts.Count taqriz</span>
                    <span><span class="material-symbols-outlined">format_quote</span> @Model.Quotes.Count iqtibos</span>
                    @if (Model.ReaderCount > 0)
                    {
                        <span><span class="material-symbols-outlined">group</span> @Model.ReaderCount kitobxon</span>
                    }
                </div>
                <div class="pd-actions" style="margin-top:10px">
                    <button type="button" class="pd-action-btn" data-share-url="@shareUrl">
                        <span class="material-symbols-outlined">share</span>
                        <span>Ulashish</span>
                    </button>
                </div>
            </div>
        </div>
    </article>

    <!-- Taqrizlar -->
    <section>
        <h2 class="pd-comments-title" style="margin:18px 0 10px">
            <span class="material-symbols-outlined">rate_review</span>
            Taqrizlar (@Model.Posts.Count)
        </h2>
        @if (Model.Posts.Count == 0)
        {
            <p class="muted">Bu kitobga hali taqriz yozilmagan. Birinchi bo'ling!</p>
        }
        else
        {
            foreach (var p in Model.Posts)
            {
                var postUrl = ViewHelpers.PostUrl(p.AuthorUsername, p.AuthorId, p.Slug);
                <article class="card post-card" style="margin-bottom:12px">
                    <header class="post-head">
                        <a class="post-avatar-wrap" href="@ViewHelpers.ProfileUrl(p.AuthorUsername, p.AuthorId)">
                            @if (!string.IsNullOrEmpty(p.AuthorAvatarUrl))
                            {
                                <img class="avatar" src="@p.AuthorAvatarUrl" alt="@p.AuthorName" referrerpolicy="no-referrer" />
                            }
                            else
                            {
                                <span class="avatar">@ViewHelpers.Initial(p.AuthorName)</span>
                            }
                        </a>
                        <div class="meta">
                            <div class="name-row">
                                <a class="name" href="@ViewHelpers.ProfileUrl(p.AuthorUsername, p.AuthorId)">@p.AuthorName</a>
                                @Html.Raw(ViewHelpers.FounderBadge(p.AuthorUsername))
                            </div>
                            <div class="time">@ViewHelpers.RelativeTime(p.CreatedAt)</div>
                        </div>
                    </header>
                    <p style="margin:8px 0 10px">@Excerpt(p.ReviewText, 300)</p>
                    <footer class="post-actions">
                        <span class="action-btn"><span class="material-symbols-outlined">favorite</span> @p.LikeCount</span>
                        <span class="action-btn"><span class="material-symbols-outlined">chat_bubble</span> @p.CommentCount</span>
                        <a class="btn btn-outline btn-sm" style="margin-left:auto" href="@postUrl">To'liq o'qish</a>
                    </footer>
                </article>
            }
        }
    </section>

    <!-- Iqtiboslar -->
    <section>
        <h2 class="pd-comments-title" style="margin:22px 0 10px">
            <span class="material-symbols-outlined">format_quote</span>
            Iqtiboslar (@Model.Quotes.Count)
        </h2>
        @if (Model.Quotes.Count == 0)
        {
            <p class="muted">Bu kitobdan hali iqtibos qo'shilmagan.</p>
        }
        else
        {
            foreach (var qt in Model.Quotes)
            {
                var quoteUrl = ViewHelpers.QuoteUrl(qt.Id);
                <article class="card post-card quote-feed-card" style="margin-bottom:12px">
                    <div class="quote-feed-body" style="padding-left:0;padding-right:0">
                        <a class="post-body-link" href="@quoteUrl" aria-label="Iqtibosni ochish"></a>
                        <div class="quote-feed-main">
                            <span class="quote-feed-mark material-symbols-outlined" aria-hidden="true">format_quote</span>
                            <blockquote class="quote-feed-text">@qt.Text</blockquote>
                            <div class="quote-feed-book">
                                <span class="qfb-author">@qt.AuthorName qo'shgan · @ViewHelpers.RelativeTime(qt.CreatedAt)</span>
                            </div>
                        </div>
                    </div>
                    <footer class="post-actions">
                        <span class="action-btn"><span class="material-symbols-outlined">favorite</span> @qt.LikeCount</span>
                        <a class="action-btn" href="@quoteUrl" aria-label="Izohlar">
                            <span class="material-symbols-outlined">chat_bubble</span>
                            <span>@qt.CommentCount</span>
                        </a>
                    </footer>
                </article>
            }
        }
    </section>
</div>
