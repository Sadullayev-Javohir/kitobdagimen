@using KitobdaGimen.Application.Features.Books.Queries.GetBooksFeed
@model IReadOnlyList<BookFeedItemDto>

@foreach (var b in Model)
{
    var bookUrl = KitobdaGimen.Web.ViewHelpers.BookUrl(b.Id, b.Title);
    var hasCover = !string.IsNullOrEmpty(b.CoverUrl);
    <a class="bookc" href="@bookUrl">
        <div class="bookc-cover @(hasCover ? "" : "is-empty")">
            @if (hasCover)
            {
                <img src="@b.CoverUrl" alt="@b.Title" loading="lazy" referrerpolicy="no-referrer" />
            }
            else
            {
                <span class="bookc-ph-icon material-symbols-outlined">auto_stories</span>
                <span class="bookc-ph-title">@b.Title</span>
            }
            @if (!string.IsNullOrEmpty(b.GenreName))
            {
                <span class="bookc-genre">@b.GenreName</span>
            }
        </div>
        <div class="bookc-body">
            <h3 class="bookc-title">@b.Title</h3>
            <p class="bookc-author">@b.Author</p>
            <div class="bookc-stats">
                <span class="bookc-stat" title="@b.ReviewCount taqriz">
                    <span class="material-symbols-outlined">rate_review</span>@b.ReviewCount
                </span>
                <span class="bookc-stat" title="@b.QuoteCount iqtibos">
                    <span class="material-symbols-outlined">format_quote</span>@b.QuoteCount
                </span>
                @if (b.ReaderCount > 0)
                {
                    <span class="bookc-stat" title="@b.ReaderCount kitobxon">
                        <span class="material-symbols-outlined">group</span>@b.ReaderCount
                    </span>
                }
            </div>
        </div>
    </a>
}
