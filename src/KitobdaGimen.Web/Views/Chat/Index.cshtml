@using KitobdaGimen.Web
@model ChatPageViewModel
@{
    ViewData["Title"] = "Xabarlar";
    var active = Model.ActiveConversation;
    // Zamonaviy SVG ikonlar (matn emoji o'rniga). Tick'lar IsRead bo'yicha rang oladi.
    const string singleTick = "<svg class=\"tick-svg\" viewBox=\"0 0 18 12\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M2 7l3.4 3.4L13 2.4\"/></svg>";
    const string doubleTick = "<svg class=\"tick-svg dbl\" viewBox=\"0 0 22 12\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M1 7l3.4 3.4L12 2.4\"/><path d=\"M8.5 9.6L16.5 2\"/></svg>";
    const string bookIcon = "<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M4 19.5A2.5 2.5 0 0 1 6.5 17H20\"/><path d=\"M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z\"/></svg>";
    const string pencilIcon = "<svg class=\"act-svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 20h9\"/><path d=\"M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z\"/></svg>";
    const string trashIcon = "<svg class=\"act-svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M3 6h18\"/><path d=\"M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2\"/><path d=\"M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6\"/></svg>";
    // Modern (SVG) reaksiya (kulgichli) ikoni — xabar ustidagi "reaksiya qo'shish" tugmasi.
    const string reactIcon = "<svg class=\"act-svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"9\"/><path d=\"M8.5 14.5a4.5 4.5 0 0 0 7 0\"/><line x1=\"9\" y1=\"9.5\" x2=\"9\" y2=\"9.5\"/><line x1=\"15\" y1=\"9.5\" x2=\"15\" y2=\"9.5\"/></svg>";
    var stickers = KitobdaGimen.Web.ChatStickers.All;
    // Backend'dagi ruxsat etilgan reaksiyalar bilan bir xil (ToggleReactionCommandHandler).
    var reactionEmojis = new[] { "❤️", "👍", "👎", "😂", "😮", "😢", "🔥", "🎉", "📚", "🙏" };
}

<div class="chat @(Model.ActiveConversationId != null ? "has-active" : "")">
    <aside class="chat-sidebar">
        <div class="chat-search">
            <div class="search-box">
                <span class="search-ico">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4"/></svg>
                </span>
                <input class="input" id="userSearch" type="search" placeholder="Kitobxonlarni qidiring..." autocomplete="off" />
            </div>
        </div>

        <div class="chat-search-results" id="searchResults"></div>

        <div class="chat-requests" id="requestsBlock" hidden>
            <div class="chat-list-title">Kelgan takliflar</div>
            <div id="requestsList"></div>
        </div>

        <div id="conversationsBlock">
            <div class="chat-list-title">Suhbatlar</div>
            @if (Model.Conversations.Count == 0)
            {
                <p class="muted" style="padding:0 16px 16px">Hali suhbat yo'q. Yuqoridan kimnidir qidirib taklif qiling.</p>
            }
            else
            {
                foreach (var c in Model.Conversations)
                {
                    <a class="conv-item @(c.Id == Model.ActiveConversationId ? "active" : "")" href="/chat?conversationId=@c.Id">
                        <span class="avatar-wrap">
                            @if (!string.IsNullOrEmpty(c.OtherUser.AvatarUrl))
                            {
                                <img class="avatar" src="@c.OtherUser.AvatarUrl" alt="@c.OtherUser.FullName" referrerpolicy="no-referrer" />
                            }
                            else
                            {
                                <span class="avatar">@ViewHelpers.Initial(c.OtherUser.FullName)</span>
                            }
                            <span class="online-dot @(c.IsOnline ? "on" : "")" data-online-for="@c.OtherUser.Id"></span>
                        </span>
                        <div class="info">
                            <div class="name">@c.OtherUser.FullName@Html.Raw(ViewHelpers.FounderBadgeMini(c.OtherUser.Username))</div>
                            <div class="last">@(c.LastMessageText ?? "Yangi suhbat")</div>
                        </div>
                        @if (c.UnreadCount > 0)
                        {
                            <span class="unread-badge">@c.UnreadCount</span>
                        }
                    </a>
                }
            }
        </div>
    </aside>

    <section class="chat-main">
        @if (Model.FloatingBookCovers.Count > 0)
        {
            var rnd = new Random(20260701);
            <div class="chat-books-bg chat-books-real" aria-hidden="true">
                @for (var i = 0; i < Model.FloatingBookCovers.Count; i++)
                {
                    var url = Model.FloatingBookCovers[i];
                    var left = rnd.Next(-2, 95);
                    var top = rnd.Next(-2, 94);
                    var w = rnd.Next(48, 96);
                    var dur = rnd.Next(13, 26);
                    var delay = Math.Round(rnd.NextDouble() * 6, 1);
                    var rot = rnd.Next(-14, 14);
                    var style = $"left:{left}%;top:{top}%;width:{w}px;animation-duration:{dur}s;animation-delay:{delay}s;--rot:{rot}deg";
                    <span class="fb cover" style="@style"><img src="@url" alt="" loading="lazy" referrerpolicy="no-referrer" /></span>
                }
            </div>
        }
        else
        {
            <div class="chat-books-bg" aria-hidden="true">
                <span class="fb fb1">@Html.Raw(bookIcon)</span>
                <span class="fb fb2">@Html.Raw(stickers["open"])</span>
                <span class="fb fb3">@Html.Raw(stickers["bookmark"])</span>
                <span class="fb fb4">@Html.Raw(bookIcon)</span>
                <span class="fb fb5">@Html.Raw(stickers["quill"])</span>
                <span class="fb fb6">@Html.Raw(stickers["open"])</span>
                <span class="fb fb7">@Html.Raw(stickers["glasses"])</span>
                <span class="fb fb8">@Html.Raw(bookIcon)</span>
            </div>
        }
        @if (active == null)
        {
            <div class="chat-empty">Suhbatni tanlang yoki yangi kitobxonni qidirib taklif qiling.</div>
        }
        else
        {
            <div class="chat-header">
                <a href="/chat" class="btn btn-ghost btn-sm btn-icon" data-back aria-label="Orqaga">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
                </a>
                <span class="avatar-wrap">
                    @if (!string.IsNullOrEmpty(active.OtherUser.AvatarUrl))
                    {
                        <img class="avatar" src="@active.OtherUser.AvatarUrl" alt="@active.OtherUser.FullName" />
                    }
                    else
                    {
                        <span class="avatar">@ViewHelpers.Initial(active.OtherUser.FullName)</span>
                    }
                    <span class="online-dot @(active.IsOnline ? "on" : "")" data-online-for="@active.OtherUser.Id"></span>
                </span>
                <div class="info">
                    <span class="name">@active.OtherUser.FullName @Html.Raw(ViewHelpers.FounderBadge(active.OtherUser.Username))</span>
                    <span class="presence @(active.IsOnline ? "online" : "")" id="headerPresence"
                          data-user="@active.OtherUser.Id"
                          data-last-seen="@(active.LastSeenAt?.ToString("o"))">
                        @ViewHelpers.Presence(active.IsOnline, active.LastSeenAt)
                    </span>
                    <span class="typing-indicator" id="typingIndicator" hidden>
                        yozayapti<span class="typing-dots"><i></i><i></i><i></i></span>
                    </span>
                </div>
            </div>
            <div class="messages" id="messages" data-other-user="@active.OtherUser.Id">
                @if (Model.Messages != null)
                {
                    foreach (var m in Model.Messages.Items)
                    {
                        var isSticker = !string.IsNullOrEmpty(m.StickerKey) && stickers.ContainsKey(m.StickerKey!);
                        <div class="msg @(m.IsMine ? "out" : "in") @(isSticker ? "is-sticker" : "") @(!string.IsNullOrEmpty(m.ImageUrl) ? "has-image" : "")" data-msg-id="@m.Id">
                            <div class="msg-content">
                                @if (isSticker)
                                {
                                    <span class="msg-sticker">@Html.Raw(stickers[m.StickerKey!])</span>
                                }
                                @if (!string.IsNullOrEmpty(m.ImageUrl))
                                {
                                    <img class="msg-image" src="@m.ImageUrl" data-full="@m.ImageUrl" alt="rasm" loading="lazy" />
                                }
                                @if (!string.IsNullOrEmpty(m.Text))
                                {
                                    <span class="msg-text">@m.Text</span>
                                }
                                @if (m.SharedPost != null)
                                {
                                    <a class="shared-card" href="/posts/@m.SharedPost.PostId">
                                        <span class="shared-ico">@Html.Raw(bookIcon)</span>
                                        <span class="shared-meta">
                                            <span class="shared-title">@m.SharedPost.BookTitle</span>
                                            <span class="shared-author">@m.SharedPost.BookAuthor</span>
                                        </span>
                                    </a>
                                }
                                <span class="meta-row">
                                    @if (m.EditedAt != null)
                                    {
                                        <span class="msg-edited">tahrirlangan</span>
                                    }
                                    <span class="msg-time" data-ts="@m.SentAt.ToString("o")">@m.SentAt.ToLocalTime().ToString("HH:mm")</span>
                                    @if (m.IsMine)
                                    {
                                        <span class="ticks @(m.IsRead ? "read" : "")">@Html.Raw(m.IsRead ? doubleTick : singleTick)</span>
                                    }
                                </span>
                            </div>
                            @if (m.Reactions.Count > 0)
                            {
                                <div class="msg-reactions">
                                    @foreach (var r in m.Reactions)
                                    {
                                        <button type="button" class="reaction-chip @(r.Mine ? "mine" : "")" data-reaction="@r.Emoji">@r.Emoji<span class="rc-count">@r.Count</span></button>
                                    }
                                </div>
                            }
                            <div class="msg-actions">
                                <button type="button" class="msg-act" data-react-open aria-label="Reaksiya">@Html.Raw(reactIcon)</button>
                                @if (m.IsMine && !string.IsNullOrEmpty(m.Text))
                                {
                                    <button type="button" class="msg-act" data-edit-msg aria-label="Tahrirlash">@Html.Raw(pencilIcon)</button>
                                }
                                @if (m.IsMine)
                                {
                                    <button type="button" class="msg-act" data-del-msg aria-label="O'chirish">@Html.Raw(trashIcon)</button>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
            <form class="msg-form" id="msgForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="conversationId" value="@active.Id" />
                <div class="row">
                    <button type="button" class="chat-tool-btn" id="stickerBtn" aria-label="Stikerlar" title="Stikerlar">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 12V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h6"/><path d="M20 12a8 8 0 0 1-8 8"/><path d="M20 12h-4a4 4 0 0 0-4 4v4"/></svg>
                    </button>
                    <button type="button" class="chat-tool-btn" id="imageBtn" aria-label="Rasm yuborish" title="Rasm yuborish">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="8.5" cy="8.5" r="1.6"/><path d="M21 15l-5-5L5 21"/></svg>
                    </button>
                    <input type="file" id="imageInput" accept="image/jpeg,image/png,image/webp,image/gif" hidden />
                    <input class="input" id="msgText" placeholder="Xabar yozing..." autocomplete="off" maxlength="5000" />
                    <button type="submit" class="btn btn-primary btn-icon" aria-label="Yuborish">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13"/><path d="M22 2l-7 20-4-9-9-4 20-7z"/></svg>
                    </button>
                </div>
                <div class="char-count"><span id="charCount">0</span>/5000</div>

                <div class="sticker-panel" id="stickerPanel" hidden>
                    @foreach (var s in stickers)
                    {
                        <button type="button" class="sticker-item" data-sticker="@s.Key" aria-label="@s.Key">@Html.Raw(s.Value)</button>
                    }
                </div>
            </form>
        }
    </section>
</div>

<!-- Reaksiya tanlagich (bitta umumiy element, kerakli xabar yoniga joylashtiriladi) -->
<div class="reaction-picker" id="reactionPicker" hidden>
    @foreach (var e in reactionEmojis)
    {
        <button type="button" class="rp-emoji" data-emoji="@e">@e</button>
    }
</div>

<!-- Rasmni to'liq o'lchamda ko'rish (lightbox) -->
<div class="chat-lightbox" id="chatLightbox" hidden>
    <button type="button" class="chat-lightbox-close" id="chatLightboxClose" aria-label="Yopish">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18"/><path d="M6 6l12 12"/></svg>
    </button>
    <img id="chatLightboxImg" src="" alt="Rasm" />
</div>

@section Scripts {
<script>
(function () {
    "use strict";
    const api = window.kitob;
    function esc(s) { const d = document.createElement("div"); d.textContent = s == null ? "" : s; return d.innerHTML; }

    // Zamonaviy SVG ikonlar (server-render bilan bir xil).
    const ICON = {
        single: '<svg class="tick-svg" viewBox="0 0 18 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 7l3.4 3.4L13 2.4"/></svg>',
        double: '<svg class="tick-svg dbl" viewBox="0 0 22 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 7l3.4 3.4L12 2.4"/><path d="M8.5 9.6L16.5 2"/></svg>',
        book: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>',
        pencil: '<svg class="act-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"/></svg>',
        trash: '<svg class="act-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>',
        react: '<svg class="act-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M8.5 14.5a4.5 4.5 0 0 0 7 0"/><line x1="9" y1="9.5" x2="9" y2="9.5"/><line x1="15" y1="9.5" x2="15" y2="9.5"/></svg>'
    };

    // Stiker SVG'lari (server bilan bir xil manba — ChatStickers.cs).
    const STICKERS = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(stickers));

    // ───────── O'zbekiston vaqti (UTC+5, DSTsiz) — qurilma timezone'idan MUSTAQIL ─────────
    // Server barcha vaqtlarni hardcoded +5 bilan renderlaydi (ViewHelpers.LastSeen). Mijoz ham
    // AYNAN shu zonada ko'rsatishi SHART — aks holda qurilmasi Toshkent vaqtida bo'lmagan
    // foydalanuvchi (UTC/boshqa region/avto-TZ xatosi) "oxirgi marta faol"ni soatlab xato ko'radi.
    // UTC instantni +5 soatga suramiz va getUTC* maydonlarini o'qiymiz → Toshkent devor-vaqti.
    const UZ_OFFSET_MS = 5 * 60 * 60 * 1000;
    function uzDate(value) {
        const d = new Date(value);
        return isNaN(d) ? null : new Date(d.getTime() + UZ_OFFSET_MS);
    }
    // Toshkent vaqti bo'yicha YYYYMMDD (kun solishtirish uchun).
    function uzYmd(d) { return d.getUTCFullYear() * 10000 + (d.getUTCMonth() + 1) * 100 + d.getUTCDate(); }
    const pad2 = n => String(n).padStart(2, "0");

    // ───────── Last-seen — aniq vaqt/sana (Toshkent vaqti) ─────────
    // Bugun → "oxirgi marta 09:10:12 da"; kecha → "oxirgi marta kecha 09:10:12 da";
    // undan oldin → "oxirgi marta 18.06.26".
    function lastSeenText(iso) {
        if (!iso) return "oflayn";
        const then = uzDate(iso);
        if (!then) return "oflayn";
        const now = uzDate(new Date());
        const time = `${pad2(then.getUTCHours())}:${pad2(then.getUTCMinutes())}:${pad2(then.getUTCSeconds())}`;

        const thenYmd = uzYmd(then);
        const yest = new Date(now.getTime() - 86400000);
        if (thenYmd === uzYmd(now)) return `oxirgi marta ${time} da`;
        if (thenYmd === uzYmd(yest)) return `oxirgi marta kecha ${time} da`;

        const date = `${pad2(then.getUTCDate())}.${pad2(then.getUTCMonth() + 1)}.${String(then.getUTCFullYear()).slice(-2)}`;
        return `oxirgi marta ${date}`;
    }

    // ───────── Taklif yuborilgan vaqtni humanize qilish (client) ─────────
    function sentAgo(iso) {
        if (!iso) return "";
        const then = new Date(iso), now = new Date();
        const sec = Math.floor((now - then) / 1000);
        if (sec < 60) return "hozirgina yubordi";
        const min = Math.floor(sec / 60);
        if (min < 60) return `${min} daqiqa oldin yubordi`;
        const hr = Math.floor(min / 60);
        if (hr < 24) return `${hr} soat oldin yubordi`;
        const day = Math.floor(hr / 24);
        if (day < 7) return `${day} kun oldin yubordi`;
        const d = uzDate(then);
        return d ? `${pad2(d.getUTCDate())}.${pad2(d.getUTCMonth() + 1)}.${String(d.getUTCFullYear()).slice(-2)} da yubordi` : "";
    }

    // Xabar vaqti — Toshkent vaqtida (UTC+5) HH:mm. Server UTC saqlaydi; qurilma
    // timezone'iga bog'liq emas (lastSeenText bilan bir xil zona).
    function fmtTime(iso) {
        if (!iso) return "";
        const d = uzDate(iso);
        if (!d) return "";
        return `${pad2(d.getUTCHours())}:${pad2(d.getUTCMinutes())}`;
    }

    function applyPresence(userId, isOnline, lastSeenAt) {
        document.querySelectorAll(`.online-dot[data-online-for="${userId}"]`).forEach(d => {
            d.classList.toggle("on", !!isOnline);
        });
        const hp = document.getElementById("headerPresence");
        if (hp && String(hp.dataset.user) === String(userId)) {
            if (isOnline) { hp.textContent = "online"; hp.classList.add("online"); }
            else { hp.textContent = lastSeenText(lastSeenAt || hp.dataset.lastSeen); hp.classList.remove("online"); }
        }
    }

    // Suhbatlar ro'yxatidagi bitta elementni JONLI yangilaydi: oxirgi xabar matni, o'qilmagan
    // nishon (+1) va eng tepaga ko'tarish. Shu tufayli boshqa suhbatda/ro'yxatda turganda ham
    // yangi xabar kelgani sahifani yangilamasdan ko'rinadi.
    function updateConvListItem(m, incrementUnread) {
        const block = document.getElementById("conversationsBlock");
        if (!block || !m) return;
        const item = block.querySelector(`.conv-item[href$="conversationId=${m.conversationId}"]`);
        if (!item) return; // ro'yxatda yo'q (mas. butunlay yangi suhbat) — refresh ko'rsatadi
        const last = item.querySelector(".last");
        if (last) last.textContent = m.text ? m.text : (m.imageUrl ? "Rasm" : (m.stickerKey ? "Stiker" : "Post ulashildi"));
        if (incrementUnread) {
            let badge = item.querySelector(".unread-badge");
            if (!badge) {
                badge = document.createElement("span");
                badge.className = "unread-badge";
                badge.textContent = "0";
                item.appendChild(badge);
            }
            badge.textContent = String((parseInt(badge.textContent, 10) || 0) + 1);
        }
        // Eng so'nggi suhbatni sarlavhadan keyin (tepaga) ko'taramiz.
        const title = block.querySelector(".chat-list-title");
        const anchorNext = title ? title.nextElementSibling : block.firstElementChild;
        if (anchorNext && item !== anchorNext) block.insertBefore(item, anchorNext);
    }

    // ───────── Active conversation messaging ─────────
    const form = document.getElementById("msgForm");
    const list = document.getElementById("messages");
    const conversationId = form ? parseInt(document.getElementById("conversationId").value, 10) : null;

    function scrollBottom() { if (list) list.scrollTop = list.scrollHeight; }

    // Xabar sinf(class)lari — stiker/rasm holatiga qarab bubble ko'rinishini o'zgartiradi.
    function msgClass(m) {
        let c = `msg ${m.isMine ? "out" : "in"}`;
        if (m.stickerKey && STICKERS[m.stickerKey]) c += " is-sticker";
        if (m.imageUrl) c += " has-image";
        return c;
    }

    // Reaksiya chiplari (emoji + son). "mine" — joriy foydalanuvchi qo'ygan.
    function reactionsHtml(m) {
        if (!m.reactions || m.reactions.length === 0) return "";
        const chips = m.reactions.map(r =>
            `<button type="button" class="reaction-chip ${r.mine ? "mine" : ""}" data-reaction="${esc(r.emoji)}">${esc(r.emoji)}<span class="rc-count">${r.count}</span></button>`
        ).join("");
        return `<div class="msg-reactions">${chips}</div>`;
    }

    // Bitta xabarning ichki HTML'i (kontent + meta + reaksiyalar + amal tugmalari).
    function msgInner(m) {
        let content = "";
        if (m.stickerKey && STICKERS[m.stickerKey]) content += `<span class="msg-sticker">${STICKERS[m.stickerKey]}</span>`;
        if (m.imageUrl) content += `<img class="msg-image" src="${esc(m.imageUrl)}" data-full="${esc(m.imageUrl)}" alt="rasm" loading="lazy" />`;
        if (m.text) content += `<span class="msg-text">${esc(m.text)}</span>`;
        if (m.sharedPost) {
            content += `<a class="shared-card" href="/posts/${m.sharedPost.postId}">` +
                `<span class="shared-ico">${ICON.book}</span>` +
                `<span class="shared-meta"><span class="shared-title">${esc(m.sharedPost.bookTitle || "")}</span>` +
                `<span class="shared-author">${esc(m.sharedPost.bookAuthor || "")}</span></span></a>`;
        }
        let meta = "";
        if (m.editedAt) meta += `<span class="msg-edited">tahrirlangan</span>`;
        meta += `<span class="msg-time" data-ts="${esc(m.sentAt || "")}">${fmtTime(m.sentAt)}</span>`;
        if (m.isMine) meta += `<span class="ticks ${m.isRead ? "read" : ""}">${m.isRead ? ICON.double : ICON.single}</span>`;

        let actions = `<div class="msg-actions">` +
            `<button type="button" class="msg-act" data-react-open aria-label="Reaksiya">${ICON.react}</button>` +
            (m.isMine && m.text ? `<button type="button" class="msg-act" data-edit-msg aria-label="Tahrirlash">${ICON.pencil}</button>` : "") +
            (m.isMine ? `<button type="button" class="msg-act" data-del-msg aria-label="O'chirish">${ICON.trash}</button>` : "") +
            `</div>`;

        return `<div class="msg-content">${content}` +
            (meta ? `<span class="meta-row">${meta}</span>` : "") + `</div>` +
            reactionsHtml(m) + actions;
    }

    function renderMessage(m) {
        if (!list) return;
        const div = document.createElement("div");
        div.className = msgClass(m);
        div.dataset.msgId = m.id;
        div.innerHTML = msgInner(m);
        list.appendChild(div);
        scrollBottom();
    }

    function findMsgEl(id) { return list ? list.querySelector(`.msg[data-msg-id="${id}"]`) : null; }
    function updateMessageEl(m) { const el = findMsgEl(m.id); if (el) { el.className = msgClass(m); el.innerHTML = msgInner(m); } }
    function removeMessageEl(id) { const el = findMsgEl(id); if (el) el.remove(); }

    // ── O'z xabarini tahrirlash (inline) ──
    function enterEdit(msgEl) {
        if (!msgEl || msgEl.classList.contains("editing")) return;
        const textEl = msgEl.querySelector(".msg-text");
        const current = textEl ? textEl.textContent : "";
        msgEl.classList.add("editing");
        const editor = document.createElement("div");
        editor.className = "msg-edit";
        editor.innerHTML = `<textarea class="msg-edit-input input" maxlength="5000" rows="2"></textarea>` +
            `<div class="msg-edit-acts"><button type="button" class="btn btn-ghost btn-sm" data-edit-cancel>Bekor</button>` +
            `<button type="button" class="btn btn-primary btn-sm" data-edit-save>Saqlash</button></div>`;
        msgEl.appendChild(editor);
        const ta = editor.querySelector("textarea");
        ta.value = current;
        ta.focus(); ta.setSelectionRange(current.length, current.length);
    }
    function exitEdit(msgEl) {
        if (!msgEl) return;
        msgEl.classList.remove("editing");
        const ed = msgEl.querySelector(".msg-edit");
        if (ed) ed.remove();
    }
    async function saveEdit(msgEl) {
        const ta = msgEl.querySelector(".msg-edit-input");
        if (!ta) return;
        const value = ta.value.trim();
        if (!value) return;
        const id = parseInt(msgEl.dataset.msgId, 10);
        try {
            const m = await api.apiPost(`/chat/message/${id}/edit`, { text: value });
            if (m) updateMessageEl(m); else exitEdit(msgEl);
        } catch (err) { alert(err.message); }
    }
    async function deleteMsg(msgEl) {
        const id = parseInt(msgEl.dataset.msgId, 10);
        if (!confirm("Xabarni o'chirmoqchimisiz?")) return;
        try {
            await api.apiPost(`/chat/message/${id}/delete`);
            msgEl.remove();
        } catch (err) { alert(err.message); }
    }

    if (list) {
        // Rasm yuklanmasa (404/tarmoq) — brauzerning katta "singan rasm" ikonini butun katakni
        // qoplashiga yo'l qo'ymay, uni ixcham placeholder ikonga almashtiramiz. `error` bubble
        // qilmaydi, shuning uchun capture bosqichida ushlaymiz. `data-failed` — cheksiz siklni oldini oladi.
        const IMG_PLACEHOLDER = "data:image/svg+xml;utf8," + encodeURIComponent(
            "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='#1B4D3E' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><path d='M4 19.5A2.5 2.5 0 0 1 6.5 17H20'/><path d='M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z'/></svg>");
        list.addEventListener("error", (e) => {
            const t = e.target;
            if (t && t.classList && t.classList.contains("msg-image") && !t.dataset.failed) {
                t.dataset.failed = "1";
                t.classList.add("img-failed");
                t.removeAttribute("data-full");
                t.src = IMG_PLACEHOLDER;
            }
        }, true);

        list.addEventListener("click", async (e) => {
            // Rasmni to'liq o'lchamda ochish (lightbox). Yuklanmagan rasm uchun ochmaymiz.
            const img = e.target.closest(".msg-image");
            if (img) { if (!img.classList.contains("img-failed")) openLightbox(img.dataset.full || img.src); return; }

            const msgEl = e.target.closest(".msg");
            if (!msgEl) return;
            if (e.target.closest("[data-edit-save]")) { await saveEdit(msgEl); return; }
            if (e.target.closest("[data-edit-cancel]")) { exitEdit(msgEl); return; }
            if (e.target.closest("[data-edit-msg]")) { enterEdit(msgEl); return; }
            if (e.target.closest("[data-del-msg]")) { await deleteMsg(msgEl); return; }
            if (e.target.closest("[data-react-open]")) { openReactionPicker(msgEl, e.target.closest("[data-react-open]")); return; }
            const chip = e.target.closest(".reaction-chip");
            if (chip) { await toggleReaction(parseInt(msgEl.dataset.msgId, 10), chip.dataset.reaction); return; }
            // Sensorli qurilmalar uchun: xabarga teginish amal tugmalarini ko'rsatadi.
            if (!e.target.closest("a, button")) {
                msgEl.classList.toggle("show-actions");
            }
        });
    }

    // ───────── Rasm lightbox (to'liq o'lcham) ─────────
    const lightbox = document.getElementById("chatLightbox");
    const lightboxImg = document.getElementById("chatLightboxImg");
    function openLightbox(url) {
        if (!lightbox || !lightboxImg || !url) return;
        // Rasm tayyor bo'lguncha "Yuklanmoqda…", xato bo'lsa xabar ko'rsatamiz — hech qachon
        // faqat qora oyna qolmaydi.
        lightbox.classList.remove("is-error");
        lightbox.classList.add("is-loading");
        lightboxImg.onload = () => lightbox.classList.remove("is-loading", "is-error");
        lightboxImg.onerror = () => { lightbox.classList.remove("is-loading"); lightbox.classList.add("is-error"); };
        lightboxImg.src = url;
        lightbox.hidden = false;
        document.body.classList.add("chat-lightbox-open");
    }
    function closeLightbox() {
        if (!lightbox) return;
        lightbox.hidden = true;
        lightboxImg.src = "";
        lightbox.classList.remove("is-loading", "is-error");
        document.body.classList.remove("chat-lightbox-open");
    }
    if (lightbox) {
        lightbox.addEventListener("click", (e) => {
            if (e.target === lightbox || e.target.closest("#chatLightboxClose")) closeLightbox();
        });
        document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeLightbox(); });
    }

    // ───────── Reaksiya tanlagich (Telegram uslubi) ─────────
    const reactionPicker = document.getElementById("reactionPicker");
    let reactionTargetId = null;
    function openReactionPicker(msgEl, btn) {
        if (!reactionPicker || !msgEl) return;
        reactionTargetId = parseInt(msgEl.dataset.msgId, 10);
        reactionPicker.hidden = false;
        // Tugma yoki xabar yoniga joylashtiramiz (ekrandan chiqib ketmasin).
        const anchor = (btn || msgEl).getBoundingClientRect();
        const pw = reactionPicker.offsetWidth || 260;
        const ph = reactionPicker.offsetHeight || 48;
        let left = Math.min(Math.max(8, anchor.left), window.innerWidth - pw - 8);
        let top = anchor.top - ph - 8;
        if (top < 8) top = anchor.bottom + 8;
        reactionPicker.style.left = left + "px";
        reactionPicker.style.top = top + "px";
    }
    function closeReactionPicker() {
        if (reactionPicker) reactionPicker.hidden = true;
        reactionTargetId = null;
    }
    if (reactionPicker) {
        reactionPicker.addEventListener("click", async (e) => {
            const b = e.target.closest("[data-emoji]");
            if (!b || reactionTargetId == null) return;
            const id = reactionTargetId;
            closeReactionPicker();
            await toggleReaction(id, b.dataset.emoji);
        });
        // Tashqariga bosilganda yopish.
        document.addEventListener("click", (e) => {
            if (reactionPicker.hidden) return;
            if (e.target.closest("#reactionPicker") || e.target.closest("[data-react-open]")) return;
            closeReactionPicker();
        });
        window.addEventListener("scroll", closeReactionPicker, true);
    }

    async function toggleReaction(messageId, emoji) {
        if (!messageId || !emoji) return;
        try {
            const m = await api.apiPost(`/chat/message/${messageId}/react`, { emoji });
            if (m) updateMessageEl(m);
        } catch (err) { alert(err.message); }
    }

    // SignalR ulanishi (typing signalini yuborish uchun) — pastda tayinlanadi.
    let chatConn = null;

    // Umumiy yuborish yordamchisi (matn / stiker / rasm).
    async function sendPayload(payload) {
        try {
            const m = await api.apiPost("/chat/send", Object.assign({ conversationId }, payload));
            if (m) renderMessage(m);
            return m;
        } catch (err) { alert(err.message); return null; }
    }

    if (form) {
        const text = document.getElementById("msgText");
        const counter = document.getElementById("charCount");
        scrollBottom();

        // Server HH:mm ni brauzer mahalliy vaqtiga moslab qayta yozamiz (server TZ noaniq).
        list.querySelectorAll(".msg-time[data-ts]").forEach(el => {
            const t = fmtTime(el.dataset.ts);
            if (t) el.textContent = t;
        });

        // Typing signalini debounce bilan yuboramiz (har bosishda emas, ~2s oralatib).
        let lastTypingSent = 0;
        function signalTyping() {
            if (!chatConn || chatConn.state !== signalR.HubConnectionState.Connected) return;
            const now = Date.now();
            if (now - lastTypingSent < 2000) return;
            lastTypingSent = now;
            chatConn.invoke("Typing", conversationId).catch(() => {});
        }

        text.addEventListener("input", () => {
            counter.textContent = text.value.length;
            counter.parentElement.classList.toggle("over", text.value.length > 5000);
            if (text.value.trim()) signalTyping();
        });

        form.addEventListener("submit", async (e) => {
            e.preventDefault();
            const value = text.value.trim();
            if (!value) return;
            const m = await sendPayload({ text: value });
            if (m) { text.value = ""; counter.textContent = "0"; }
        });

        // ── Stiker paneli ──
        const stickerBtn = document.getElementById("stickerBtn");
        const stickerPanel = document.getElementById("stickerPanel");
        if (stickerBtn && stickerPanel) {
            stickerBtn.addEventListener("click", () => { stickerPanel.hidden = !stickerPanel.hidden; });
            stickerPanel.addEventListener("click", async (e) => {
                const b = e.target.closest("[data-sticker]");
                if (!b) return;
                stickerPanel.hidden = true;
                await sendPayload({ stickerKey: b.dataset.sticker });
            });
            document.addEventListener("click", (e) => {
                if (stickerPanel.hidden) return;
                if (e.target.closest("#stickerPanel") || e.target.closest("#stickerBtn")) return;
                stickerPanel.hidden = true;
            });
        }

        // ── Rasm yuborish ──
        const imageBtn = document.getElementById("imageBtn");
        const imageInput = document.getElementById("imageInput");
        if (imageBtn && imageInput) {
            imageBtn.addEventListener("click", () => imageInput.click());
            imageInput.addEventListener("change", async () => {
                const file = imageInput.files && imageInput.files[0];
                imageInput.value = ""; // keyingi tanlov uchun tozalaymiz
                if (!file) return;
                imageBtn.classList.add("uploading");
                try {
                    const fd = new FormData();
                    fd.append("file", file);
                    const res = await fetch("/chat/upload-image", {
                        method: "POST",
                        headers: { "X-Requested-With": "XMLHttpRequest", "RequestVerificationToken": api.antiforgeryToken() },
                        credentials: "include",
                        body: fd
                    });
                    if (!res.ok) {
                        let msg = "Rasm yuklanmadi.";
                        try { const d = await res.json(); msg = d.message || msg; } catch { /* ignore */ }
                        throw new Error(msg);
                    }
                    const data = await res.json();
                    if (data && data.url) await sendPayload({ imageUrl: data.url });
                } catch (err) { alert(err.message); }
                finally { imageBtn.classList.remove("uploading"); }
            });
        }
    }

    // ───────── People search ─────────
    const search = document.getElementById("userSearch");
    const results = document.getElementById("searchResults");
    const convBlock = document.getElementById("conversationsBlock");
    let searchTimer = null;

    function connButton(u) {
        switch (u.connectionState) {
            case 1: return `<button class="btn btn-outline btn-sm conn-btn" data-cancel="${u.connectionId}" data-uid="${u.id}">Yuborildi</button>`;
            case 2: return `<button class="btn btn-primary btn-sm conn-btn" data-accept="${u.connectionId}" data-uid="${u.id}">Qabul qilish</button>`;
            case 3: return `<a class="btn btn-ghost btn-sm conn-btn" href="/chat" data-uid="${u.id}">Suhbatlashish</a>`;
            default: return `<button class="btn btn-primary btn-sm conn-btn" data-connect="${u.id}">Taklif qilish</button>`;
        }
    }

    function searchCard(u) {
        const avatar = u.avatarUrl
            ? `<img class="avatar" src="${esc(u.avatarUrl)}" alt="">`
            : `<span class="avatar">${esc((u.fullName || "?").trim().charAt(0).toUpperCase())}</span>`;
        const presence = u.isOnline ? `<span class="presence" style="color:#2a9d4a">online</span>`
                                    : `<span class="presence">${esc(lastSeenText(u.lastSeenAt))}</span>`;
        return `<div class="search-card" data-card="${u.id}">
            <span class="avatar-wrap ${u.hasStory ? "has-story" : ""}">${avatar}
                <span class="online-dot ${u.isOnline ? "on" : ""}" data-online-for="${u.id}"></span></span>
            <div class="meta">
                <div class="name">${esc(u.fullName)} ${api.founderBadge(u.username)}</div>
                ${u.username ? `<div class="uname">@@${esc(u.username)}</div>` : ""}
                ${u.bio ? `<div class="bio">${esc(u.bio)}</div>` : ""}
                ${presence}
            </div>
            ${connButton(u)}
        </div>`;
    }

    async function runSearch(q) {
        try {
            const res = await fetch(`/chat/search?q=${encodeURIComponent(q)}`, { headers: { "X-Requested-With": "XMLHttpRequest" } });
            if (!res.ok) return;
            const data = await res.json();
            const items = data.items || [];
            if (items.length === 0) {
                results.innerHTML = `<div class="search-empty">Hech kim topilmadi.</div>`;
            } else {
                results.innerHTML = items.map(searchCard).join("");
            }
            results.classList.add("show");
            convBlock.style.display = "none";
        } catch (e) { /* ignore */ }
    }

    if (search) {
        search.addEventListener("input", () => {
            const q = search.value.trim();
            clearTimeout(searchTimer);
            if (q.length === 0) {
                results.classList.remove("show"); results.innerHTML = "";
                convBlock.style.display = ""; return;
            }
            searchTimer = setTimeout(() => runSearch(q), 300);
        });

        // Connect / cancel / accept actions inside search results.
        results.addEventListener("click", async (e) => {
            const card = e.target.closest(".search-card");
            if (!card) return;
            const connectId = e.target.closest("[data-connect]");
            const cancelId = e.target.closest("[data-cancel]");
            const acceptId = e.target.closest("[data-accept]");
            try {
                if (connectId) {
                    const dto = await api.apiPost("/chat/connect", { addresseeId: parseInt(connectId.dataset.connect, 10) });
                    if (dto && dto.status === 1) { api.showToast("Bog'landingiz! Endi suhbatlashishingiz mumkin."); setTimeout(() => location.reload(), 600); }
                    else { connectId.outerHTML = `<button class="btn btn-outline btn-sm conn-btn" data-cancel="${dto.id}">Yuborildi</button>`; api.showToast("Taklif yuborildi."); }
                } else if (cancelId) {
                    await api.apiPost(`/chat/connect/${parseInt(cancelId.dataset.cancel, 10)}/cancel`);
                    const uid = card.dataset.card;
                    cancelId.outerHTML = `<button class="btn btn-primary btn-sm conn-btn" data-connect="${uid}">Taklif qilish</button>`;
                    api.showToast("Taklif bekor qilindi.");
                } else if (acceptId) {
                    await api.apiPost(`/chat/connect/${parseInt(acceptId.dataset.accept, 10)}/respond`, { accept: true });
                    api.showToast("Taklif qabul qilindi!"); setTimeout(() => location.reload(), 600);
                }
            } catch (err) { alert(err.message); }
        });
    }

    // ───────── Pending requests panel (suhbatlar ro'yxati tepasida) ─────────
    const requestsList = document.getElementById("requestsList");
    const requestsBlock = document.getElementById("requestsBlock");

    function renderRequests(reqs) {
        if (!requestsList) return;
        if (!reqs || reqs.length === 0) {
            requestsList.innerHTML = "";
            if (requestsBlock) requestsBlock.hidden = true;
            return;
        }
        if (requestsBlock) requestsBlock.hidden = false;
        requestsList.innerHTML = reqs.map(r => {
            const u = r.otherUser;
            const avatar = u.avatarUrl ? `<img class="avatar" src="${esc(u.avatarUrl)}" alt="">`
                : `<span class="avatar">${esc((u.fullName || "?").trim().charAt(0).toUpperCase())}</span>`;
            return `<div class="req-item" data-req="${r.id}">
                <span class="avatar-wrap">${avatar}</span>
                <div class="meta">
                    <div class="name">${esc(u.fullName)} ${api.founderBadge(u.username)}</div>
                    <div class="req-time">${esc(sentAgo(r.createdAt))}</div>
                </div>
                <div class="acts">
                    <button class="btn btn-primary btn-sm" data-req-accept="${r.id}">Qabul</button>
                    <button class="btn btn-outline btn-sm" data-req-decline="${r.id}">Rad</button>
                </div>
            </div>`;
        }).join("");
    }

    async function loadRequests() {
        try {
            const res = await fetch("/chat/requests", { headers: { "X-Requested-With": "XMLHttpRequest" } });
            if (res.ok) renderRequests(await res.json());
        } catch (e) { /* ignore */ }
    }

    async function respondRequest(id, accept) {
        try {
            await api.apiPost(`/chat/connect/${id}/respond`, { accept });
        } catch (err) { alert(err.message); return; }
        if (accept) {
            api.showToast("Yangi suhbatdosh qo'shildi!");
            // Boyo'g'li (owl) animatsiyasi IXTIYORIY — u xato bersa ham sahifa qayta
            // yuklanishini (va yangi suhbatdosh paydo bo'lishini) bloklamasligi kerak.
            try { if (owl && owl.happy) owl.happy(); } catch (e) { /* e'tiborsiz */ }
            setTimeout(() => location.reload(), 700);
        } else {
            loadRequests();
        }
    }

    if (requestsList) {
        requestsList.addEventListener("click", (e) => {
            const a = e.target.closest("[data-req-accept]");
            const d = e.target.closest("[data-req-decline]");
            if (a) respondRequest(parseInt(a.dataset.reqAccept, 10), true);
            else if (d) respondRequest(parseInt(d.dataset.reqDecline, 10), false);
        });
        loadRequests();
    }

    // Owl alert bubble queue (someone invited me, live).
    function showNextAlert() {
        if (currentAlert || alertQueue.length === 0) return;
        currentAlert = alertQueue.shift();
        owlBubbleText.textContent = `🦉 ${currentAlert.name} sizni suhbatga taklif qildi!`;
        owlBubble.classList.add("show");
        owl && owl.alert();
    }
    function dismissAlert() {
        owlBubble.classList.remove("show");
        currentAlert = null;
        owl && owl.idle();
        showNextAlert();
    }
    document.getElementById("owlAccept")?.addEventListener("click", async () => {
        if (!currentAlert) return;
        await respondRequest(currentAlert.connectionId, true);
        dismissAlert();
    });
    document.getElementById("owlDecline")?.addEventListener("click", async () => {
        if (!currentAlert) return;
        await respondRequest(currentAlert.connectionId, false);
        dismissAlert();
    });

    // Owl follows the cursor (CURIOUS).
    document.addEventListener("mousemove", (e) => { owl && owl.lookAt(e.clientX, e.clientY); });

    // Lazy-load the 3D owl module (falls back to a 2D owl on its own if WebGL is missing).
    const owlCanvas = document.getElementById("owlCanvas");
    if (owlCanvas) {
        import("/js/owl.js")
            .then(mod => { owl = mod.mountOwl(owlCanvas); })
            .catch(err => { console.warn("Boyo'g'li yuklanmadi:", err); if (owlCaption) owlCaption.textContent = "🦉"; });
    }

    // ───────── Real-time (SignalR) — to'xtamaydigan, doimiy qayta-ulanuvchi ─────────
    if (window.signalR) {
        // Cheksiz qayta-ulanish siyosati: hech qachon null qaytarmaydi (default 4 urinishdan keyin to'xtardi).
        const foreverRetry = {
            nextRetryDelayInMilliseconds: (ctx) =>
                Math.min(1000 * Math.pow(2, Math.min(ctx.previousRetryCount, 4)), 15000) // 1s→15s, abadiy
        };
        const chat = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/chat")
            .withAutomaticReconnect(foreverRetry)
            .build();
        chatConn = chat;

        chat.on("ReceiveMessage", (m) => {
            if (!m) return;
            if (conversationId && m.conversationId === conversationId) {
                renderMessage(m);
                api.apiPost(`/chat/${conversationId}/read`).catch(() => {});
                updateConvListItem(m, false); // ochiq suhbat: o'qilgan — faqat oxirgi xabar + tartib
            } else {
                updateConvListItem(m, true);  // boshqa suhbat/ro'yxat: o'qilmagan nishon +1
                api.showToast(`${esc(m.sender ? m.sender.fullName : "Yangi")} xabar yubordi`, { url: "/chat" });
            }
        });

        chat.on("MessageEdited", (m) => {
            if (!m || !conversationId || m.conversationId !== conversationId) return;
            updateMessageEl(m);
        });

        chat.on("MessageDeleted", (p) => {
            if (!p || !conversationId || p.conversationId !== conversationId) return;
            removeMessageEl(p.messageId);
        });

        chat.on("MessagesRead", (p) => {
            if (!p || !conversationId || p.conversationId !== conversationId) return;
            document.querySelectorAll("#messages .msg.out .ticks").forEach(t => { t.innerHTML = ICON.double; t.classList.add("read"); });
        });

        chat.on("PresenceChanged", (p) => { if (p) applyPresence(p.userId, p.isOnline, p.lastSeenAt); });

        // Reaksiya o'zgarishi — tegishli xabarni jonli yangilaymiz.
        chat.on("MessageReaction", (m) => {
            if (!m || !conversationId || m.conversationId !== conversationId) return;
            updateMessageEl(m);
        });

        // "yozayapti..." indikatori — 4 soniyada avtomatik o'chadi.
        let typingTimer = null;
        const typingEl = document.getElementById("typingIndicator");
        const presenceEl = document.getElementById("headerPresence");
        function showTyping(userId) {
            if (!typingEl || !list) return;
            if (String(userId) !== String(list.dataset.otherUser)) return;
            typingEl.hidden = false;
            if (presenceEl) presenceEl.style.display = "none";
            clearTimeout(typingTimer);
            typingTimer = setTimeout(() => {
                typingEl.hidden = true;
                if (presenceEl) presenceEl.style.display = "";
            }, 4000);
        }
        chat.on("UserTyping", (p) => { if (p && conversationId && p.conversationId === conversationId) showTyping(p.userId); });

        let heartbeat = null;
        function beat() { chat.invoke("Heartbeat").catch(() => {}); }

        // Qayta ulanilganda: heartbeat darhol + o'qilganlarni belgilash + takliflarni yangilash (o'tkazib yuborilgan eventlar uchun).
        chat.onreconnected(() => {
            beat();
            if (conversationId) api.apiPost(`/chat/${conversationId}/read`).catch(() => {});
            loadRequests();
        });

        // To'liq yopilsa (server qayta ishga tushdi va auto-reconnect ham bermasa) — qo'lda qayta urinamiz.
        let closedRestart = null;
        chat.onclose(() => {
            if (closedRestart) return;
            closedRestart = setInterval(() => {
                if (chat.state === signalR.HubConnectionState.Disconnected) startChat();
                else { clearInterval(closedRestart); closedRestart = null; }
            }, 5000);
        });

        async function startChat() {
            try {
                await chat.start();
                if (closedRestart) { clearInterval(closedRestart); closedRestart = null; }
                beat();
                if (!heartbeat) heartbeat = setInterval(beat, 30000);
            } catch {
                // Boshlanishida server tayyor bo'lmasa — 5 soniyadan keyin yana urinamiz.
                setTimeout(startChat, 5000);
            }
        }
        startChat();

        // Sahifa orqaga qaytganda/ko'rinishga kelganda uzilgan bo'lsa darhol tiklaymiz.
        document.addEventListener("visibilitychange", () => {
            if (!document.hidden && chat.state === signalR.HubConnectionState.Disconnected) startChat();
        });

        window.addEventListener("beforeunload", () => { if (heartbeat) clearInterval(heartbeat); });
    }

    // The global notification hub (site.js) broadcasts a DOM event; the owl reacts to invites.
    document.addEventListener("kitob:notification", (e) => {
        const n = e.detail;
        if (!n) return;
        if (n.type === "connection_request") {
            alertQueue.push({ connectionId: n.relatedId, name: n.actorName || "Kimdir" });
            showNextAlert();
            loadRequests();
        } else if (n.type === "connection_accepted") {
            api.showToast(n.message || "Taklifingiz qabul qilindi", { url: "/chat" });
            owl && owl.happy();
            loadRequests();
        }
        // reading_reminder esa global owl-toast (site.js) orqali ko'rsatiladi — bu sahifada
        // boyo'g'li paneli markup'i yo'q, shuning uchun bu yerda alohida ish qilmaymiz.
    });
})();
</script>
}
