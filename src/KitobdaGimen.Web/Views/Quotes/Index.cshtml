@using KitobdaGimen.Application.Features.Onboarding.Queries.GetGenres
@using MediatR
@inject ISender Mediator
@model PagedResult<QuoteDto>
@{
    ViewData["Title"] ??= "Iqtiboslar";
    var path = Context.Request.Path.Value ?? "/quotes";
    string Tab(string href, string label) =>
        $"<a class=\"btn {(path.Equals(href, StringComparison.OrdinalIgnoreCase) ? "btn-primary" : "btn-outline")} btn-sm\" href=\"{href}\">{label}</a>";
    var search = ViewData["Search"] as string ?? "";
    var genres = await Mediator.Send(new GetGenresQuery());
}

<div class="container page">
    <div style="display:flex; align-items:center; justify-content:space-between; gap:16px; flex-wrap:wrap">
        <h1 class="section-title" style="margin-top:0">@ViewData["Title"]</h1>
        <div class="flex items-center gap-8">
            <button class="action-btn" id="quoteSearchToggle" title="Qidirish" aria-label="Qidirish">
                <span class="material-symbols-outlined">search</span>
            </button>
            <button class="btn btn-accent" id="newQuoteToggle">+ Yangi iqtibos</button>
        </div>
    </div>

    <form method="get" action="/quotes" id="quoteSearchForm" style="@(string.IsNullOrEmpty(search) ? "display:none;" : "") margin-top:16px; margin-bottom:20px">
        <div style="display:flex; align-items:center; gap:10px">
            <div class="search-box" style="flex:1">
                <span class="search-ico material-symbols-outlined">search</span>
                <input class="input" type="search" name="q" id="quoteSearchInput"
                       placeholder="Iqtibos matni, kitob, muallif yoki yozuvchi bo'yicha qidiring..."
                       value="@search" autocomplete="off" />
            </div>
            @if (!string.IsNullOrEmpty(search))
            {
                <a class="btn btn-outline" href="/quotes" id="quoteSearchClear" title="Qidiruvni tozalash">
                    <span class="material-symbols-outlined" style="font-size:18px;vertical-align:bottom">close</span>
                    Tozalash
                </a>
            }
        </div>
    </form>

    <div class="tabs">
        @Html.Raw(Tab("/quotes", "Barcha"))
        @Html.Raw(Tab("/quotes/my", "Mening"))
        @Html.Raw(Tab("/quotes/saved", "Saqlangan"))
    </div>

    <div class="card" id="newQuoteForm" style="display:none; margin-bottom:24px">
        <h3 style="margin-bottom:14px">Yangi iqtibos</h3>
        <form method="post" action="/quotes/create" id="quoteForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="BookId" id="quoteBookId" />

            <!-- Tanlangan kitob (tanlangach ko'rinadi) -->
            <div id="quoteSelectedBook" class="composer-selected" hidden>
                <span class="material-symbols-outlined">menu_book</span>
                <span id="quoteSelectedBookLabel"></span>
                <button type="button" class="composer-clear" id="quoteClearBook" aria-label="Bekor qilish">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>

            <!-- Kitob qidirish / qo'shish (kitob tanlanmaganda ko'rinadi) -->
            <div id="quoteBookPicker">
                <div class="composer-book">
                    <input class="input" id="quoteBookSearch" placeholder="Kitobni qidiring..." autocomplete="off" />
                    <button type="button" class="btn btn-outline btn-sm" id="quoteNewBookToggle">Yangi kitob</button>
                    <button type="button" class="btn btn-ghost btn-sm" data-asaxiy-refresh="#quoteBookSearch"
                            title="Kitob qidiruvi ishlamayaptimi? Bosing — qayta ishga tushadi.">
                        <span class="material-symbols-outlined" style="font-size:18px;vertical-align:bottom">refresh</span>
                        Kitoblarni yangilash
                    </button>
                </div>
                <div class="book-suggestions" id="quoteBookSuggestions" hidden></div>

                <div id="quoteNewBookForm" class="composer-newbook stack" hidden>
                    <input class="input" id="qNbTitle" placeholder="Kitob nomi" minlength="3" maxlength="100" />
                    <input class="input" id="qNbAuthor" placeholder="Muallif" minlength="3" maxlength="100" />
                    <input class="input" id="qNbPages" type="number" min="1" max="100000" placeholder="Sahifalar soni" />
                    <select class="input" id="qNbGenre">
                        <option value="">Kategoriyani tanlang</option>
                        @foreach (var genre in genres)
                        {
                            <option value="@genre.Id">@genre.Name</option>
                        }
                    </select>

                    <div class="nb-cover">
                        <div class="nb-cover-preview" id="qNbCoverPreview">
                            <span class="material-symbols-outlined">image</span>
                        </div>
                        <div class="nb-cover-actions">
                            <label class="btn btn-outline btn-sm" for="qNbCover">Muqova rasmi</label>
                            <input type="file" id="qNbCover" accept="image/*" hidden />
                            <button type="button" class="btn btn-ghost btn-sm" id="qNbCoverClear" hidden>O'chirish</button>
                            <span class="muted" id="qNbCoverHint" style="font-size:12px">Ixtiyoriy — JPG/PNG, 5 MB gacha.</span>
                        </div>
                    </div>

                    <button type="button" class="btn btn-outline btn-sm" id="qNbSave">Kitobni qo'shish</button>
                </div>
            </div>

            <textarea class="input" name="Text" placeholder="Iqtibos matni..." minlength="3" maxlength="400" required></textarea>
            <div class="composer-actions">
                <a class="btn btn-ghost" href="#" onclick="document.getElementById('newQuoteForm').style.display='none';return false;">Bekor</a>
                <button type="submit" class="btn btn-primary">Saqlash</button>
            </div>
        </form>
    </div>

    @if (Model.Items.Count == 0)
    {
        <div class="card text-center muted">
            @(string.IsNullOrEmpty(search) ? "Iqtiboslar topilmadi." : $"\"{search}\" bo'yicha iqtibos topilmadi.")
        </div>
    }
    else
    {
        var tab = path.Equals("/quotes/my", StringComparison.OrdinalIgnoreCase) ? "my"
            : path.Equals("/quotes/saved", StringComparison.OrdinalIgnoreCase) ? "saved" : "all";
        var bookId = Context.Request.Query["bookId"].ToString();
        <div class="feed" id="quoteGrid"
             data-page="@Model.Page" data-total-pages="@Model.TotalPages"
             data-tab="@tab" data-search="@search" data-book-id="@bookId">
            <partial name="_QuoteCards" model="Model.Items" />
        </div>
        <div class="infinite-loader" id="quoteLoader" hidden>
            <span class="spinner"></span>
        </div>
        <div id="quoteSentinel" aria-hidden="true"></div>
    }
</div>

@section Scripts {
<script>
(function () {
    document.getElementById("newQuoteToggle").addEventListener("click", () => {
        const f = document.getElementById("newQuoteForm");
        f.style.display = f.style.display === "none" ? "block" : "none";
    });

    // --- Qidiruv: ikona bosilganda qidiruv maydonini ochish/yopish ---
    const searchForm = document.getElementById("quoteSearchForm");
    const searchInput = document.getElementById("quoteSearchInput");
    document.getElementById("quoteSearchToggle").addEventListener("click", () => {
        const open = searchForm.style.display !== "none";
        searchForm.style.display = open ? "none" : "block";
        if (!open) searchInput.focus();
    });

    // --- Topilgan so'zlarni yashil rang bilan belgilash (highlight) ---
    const term = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(search));
    function highlightCards(cards) {
        if (!term || !term.trim()) return;
        const needle = term.trim().toLowerCase();
        const escaped = needle.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
        const rx = new RegExp("(" + escaped + ")", "gi");

        const highlightNode = (node) => {
            if (node.nodeType === Node.TEXT_NODE) {
                if (!node.nodeValue.toLowerCase().includes(needle)) return;
                const frag = document.createDocumentFragment();
                let last = 0;
                node.nodeValue.replace(rx, (match, _g, offset) => {
                    if (offset > last) frag.appendChild(document.createTextNode(node.nodeValue.slice(last, offset)));
                    const mark = document.createElement("mark");
                    mark.className = "quote-mark";
                    mark.textContent = match;
                    frag.appendChild(mark);
                    last = offset + match.length;
                    return match;
                });
                if (last < node.nodeValue.length) frag.appendChild(document.createTextNode(node.nodeValue.slice(last)));
                node.parentNode.replaceChild(frag, node);
            } else if (node.nodeType === Node.ELEMENT_NODE && node.tagName !== "MARK") {
                [...node.childNodes].forEach(highlightNode);
            }
        };

        // Matn, kitob/muallif manbasi va yozuvchi ismi bo'yicha
        cards.forEach((card) => {
            card.querySelectorAll(".quote-feed-text, .qfb-title, .qfb-author, .name").forEach(highlightNode);
        });
    }
    highlightCards(Array.from(document.querySelectorAll(".quote-feed-card")));

    // --- Cheksiz skroll: pastga tushganda keyingi iqtiboslarni yuklash ---
    const grid = document.getElementById("quoteGrid");
    const sentinel = document.getElementById("quoteSentinel");
    if (grid && sentinel && window.kitob && kitob.infiniteScroll) {
        kitob.infiniteScroll({
            sentinel,
            container: grid,
            loader: document.getElementById("quoteLoader"),
            endpoint: "/quotes/cards",
            page: parseInt(grid.dataset.page, 10) || 1,
            totalPages: parseInt(grid.dataset.totalPages, 10) || 1,
            search: grid.dataset.search || "",
            params: { tab: grid.dataset.tab, bookId: grid.dataset.bookId },
            onAppend: (nodes) => highlightCards(nodes)
        });
    }

    const form = document.getElementById("quoteForm");
    const bookIdInput = document.getElementById("quoteBookId");
    const bookPicker = document.getElementById("quoteBookPicker");
    const selectedBook = document.getElementById("quoteSelectedBook");
    const selectedLabel = document.getElementById("quoteSelectedBookLabel");
    const newBookForm = document.getElementById("quoteNewBookForm");
    const bookSearch = document.getElementById("quoteBookSearch");
    const suggestions = document.getElementById("quoteBookSuggestions");
    let searchTimer;

    function pickBook(book) {
        bookIdInput.value = book.id;
        selectedLabel.textContent = `${book.title} — ${book.author}`;
        selectedBook.hidden = false;
        bookPicker.hidden = true;
        suggestions.hidden = true;
        suggestions.innerHTML = "";
        bookSearch.value = "";
    }

    function clearBook() {
        bookIdInput.value = "";
        selectedBook.hidden = true;
        bookPicker.hidden = false;
    }

    document.getElementById("quoteClearBook").addEventListener("click", clearBook);

    // --- Kitob qidirish ---
    bookSearch.addEventListener("input", () => {
        clearTimeout(searchTimer);
        const q = bookSearch.value.trim();
        if (q.length < 2) { suggestions.hidden = true; suggestions.innerHTML = ""; return; }
        suggestions.dataset.q = q;
        searchTimer = setTimeout(async () => {
            try {
                const res = await fetch(`/books/search?q=${encodeURIComponent(q)}`, { headers: { "X-Requested-With": "XMLHttpRequest" } });
                if (!res.ok) return;
                const books = await res.json();
                suggestions.innerHTML = "";
                books.forEach(b => {
                    const div = document.createElement("div");
                    div.className = "book-suggestion";
                    div.textContent = `${b.title} — ${b.author}`;
                    div.addEventListener("click", () => pickBook(b));
                    suggestions.appendChild(div);
                });
                suggestions.hidden = books.length === 0;
                window.kitob.renderAsaxiyBooks(q, suggestions, pickBook);
            } catch { /* ignore */ }
        }, 300);
    });

    document.getElementById("quoteNewBookToggle").addEventListener("click", () => {
        newBookForm.hidden = !newBookForm.hidden;
    });

    // --- Muqova rasmi (cover) ---
    const nbCover = document.getElementById("qNbCover");
    const nbCoverPreview = document.getElementById("qNbCoverPreview");
    const nbCoverClear = document.getElementById("qNbCoverClear");
    const nbCoverHint = document.getElementById("qNbCoverHint");
    let coverUrl = null;   // server URL once uploaded
    let coverFile = null;  // pending file chosen by the user

    function resetCover() {
        coverUrl = null;
        coverFile = null;
        nbCover.value = "";
        nbCoverPreview.innerHTML = '<span class="material-symbols-outlined">image</span>';
        nbCoverClear.hidden = true;
        nbCoverHint.textContent = "Ixtiyoriy — JPG/PNG, 5 MB gacha.";
    }

    nbCover.addEventListener("change", () => {
        const f = nbCover.files && nbCover.files[0];
        if (!f) { resetCover(); return; }
        coverFile = f;
        coverUrl = null; // re-upload on next save
        nbCoverClear.hidden = false;
        nbCoverHint.textContent = f.name;
        const reader = new FileReader();
        reader.onload = (ev) => {
            nbCoverPreview.innerHTML = "";
            const img = document.createElement("img");
            img.src = ev.target.result;
            nbCoverPreview.appendChild(img);
        };
        reader.readAsDataURL(f);
    });

    nbCoverClear.addEventListener("click", resetCover);

    async function uploadCover(file) {
        const fd = new FormData();
        fd.append("file", file);
        const res = await fetch("/books/upload-cover", {
            method: "POST",
            headers: {
                "X-Requested-With": "XMLHttpRequest",
                "RequestVerificationToken": kitob.antiforgeryToken()
            },
            body: fd
        });
        if (res.status === 401) { window.location.href = "/"; return null; }
        if (!res.ok) {
            let message = "Rasmni yuklab bo'lmadi.";
            try { const d = await res.json(); message = d.message || message; } catch { /* ignore */ }
            throw new Error(message);
        }
        const data = await res.json();
        return data.url;
    }

    const nbSave = document.getElementById("qNbSave");
    nbSave.addEventListener("click", async () => {
        const genreId = parseInt(document.getElementById("qNbGenre").value, 10) || 0;
        const command = {
            title: document.getElementById("qNbTitle").value.trim(),
            author: document.getElementById("qNbAuthor").value.trim(),
            totalPages: parseInt(document.getElementById("qNbPages").value, 10) || 0,
            genreId: genreId || null
        };
        if (!command.title || !command.author || command.totalPages <= 0) {
            alert("Kitob nomi, muallif va sahifalar sonini kiriting.");
            return;
        }
        if (command.title.length < 3 || command.title.length > 100) {
            alert("Kitob nomi 3 dan 100 tagacha belgidan iborat bo'lishi kerak.");
            return;
        }
        if (command.author.length < 3 || command.author.length > 100) {
            alert("Muallif nomi 3 dan 100 tagacha belgidan iborat bo'lishi kerak.");
            return;
        }
        if (command.totalPages > 100000) {
            alert("Sahifalar soni juda katta.");
            return;
        }
        if (!genreId) {
            alert("Kitob kategoriyasini tanlang.");
            return;
        }
        nbSave.disabled = true;
        try {
            // Upload the cover first (if chosen) so the book is created with its URL.
            if (coverFile && !coverUrl) {
                coverUrl = await uploadCover(coverFile);
            }
            if (coverUrl) command.coverUrl = coverUrl;

            const book = await kitob.apiPost("/books/create", command);
            if (book) pickBook(book);
            newBookForm.hidden = true;
            resetCover();
        } catch (err) { alert(err.message); }
        finally { nbSave.disabled = false; }
    });

    form.addEventListener("submit", (e) => {
        if (!bookIdInput.value) {
            e.preventDefault();
            alert("Avval kitobni tanlang yoki qo'shing.");
        }
    });
})();
</script>
}
