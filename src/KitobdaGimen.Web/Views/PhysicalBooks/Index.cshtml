@using KitobdaGimen.Web.Models
@model PhysicalBooksPageViewModel
@{
    ViewData["Title"] = "Kitob almashish";
}

@section Styles {
    <link rel="stylesheet" href="~/css/physical-books.css" asp-append-version="true" />
}

<div class="container page pb-page">
    <div class="pb-head">
        <div>
            <h1 class="section-title" style="margin:0">Kitob almashish</h1>
            <p class="pb-subtitle">O'zingizdagi kitobni qo'shing, boshqalarnikini o'qing.</p>
        </div>
        <button class="btn btn-accent" id="pbAddToggle">
            <span class="material-symbols-outlined">add</span>
            Kitob qo'shish
        </button>
    </div>

    @* ===== Kitob qo'shish formasi ===== *@
    <div class="pb-add-panel" id="pbAddPanel" hidden>
        <label class="pb-field-label">Kitobni qidiring</label>
        <div class="search-box">
            <span class="search-ico material-symbols-outlined">search</span>
            <input class="input" type="search" id="pbSearchInput" autocomplete="off"
                   placeholder="Kitob nomi yoki muallif bo'yicha qidiring..." />
        </div>
        <div class="pb-suggestions" id="pbSuggestions" hidden></div>

        @* Tanlangan kitob *@
        <div class="pb-selected" id="pbSelected" hidden>
            <span class="material-symbols-outlined">check_circle</span>
            <span id="pbSelectedText"></span>
            <button type="button" class="pb-selected-clear" id="pbSelectedClear" aria-label="Bekor qilish">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>

        <button type="button" class="pb-manual-toggle" id="pbManualToggle">
            Kitob topilmadimi? Qo'lda kiriting
        </button>

        @* Qo'lda kiritish *@
        <div class="pb-manual" id="pbManualForm" hidden>
            <input class="input" type="text" id="pbManualTitle" maxlength="150" placeholder="Kitob nomi *" />
            <input class="input" type="text" id="pbManualAuthor" maxlength="150" placeholder="Muallif (ixtiyoriy)" />
        </div>

        <div class="pb-add-actions">
            <button class="btn btn-accent" id="pbAddSave">Qo'shish</button>
            <button class="btn btn-ghost" id="pbAddCancel">Bekor qilish</button>
        </div>
    </div>

    @* ===== Mening kitoblarim ===== *@
    <section class="pb-section">
        <h2 class="pb-section-title">Mening kitoblarim</h2>
        <div class="pb-grid" id="pbMineGrid">
            @foreach (var book in Model.Mine)
            {
                <partial name="_PhysicalBookCard" model="book" />
            }
        </div>
        <p class="pb-empty" id="pbMineEmpty" @(Model.Mine.Count > 0 ? "hidden" : null)>
            Hali kitob qo'shmagansiz. "Kitob qo'shish" tugmasi orqali boshlang.
        </p>
    </section>

    @* ===== Kutubxona ===== *@
    <section class="pb-section">
        <div class="pb-section-head">
            <h2 class="pb-section-title">Kutubxona</h2>
            <div class="search-box pb-lib-search">
                <span class="search-ico material-symbols-outlined">search</span>
                <input class="input" type="search" id="pbLibSearch" autocomplete="off"
                       placeholder="Kutubxonadan qidiring..." />
            </div>
        </div>
        <div class="pb-grid" id="pbLibGrid">
            @foreach (var book in Model.Library)
            {
                <partial name="_PhysicalBookCard" model="book" />
            }
        </div>
        <p class="pb-empty" id="pbLibEmpty" @(Model.Library.Count > 0 ? "hidden" : null)>
            Hozircha almashish uchun mavjud kitob yo'q.
        </p>
    </section>
</div>

@section Scripts {
    <script src="~/js/physical-books.js" asp-append-version="true"></script>
}
