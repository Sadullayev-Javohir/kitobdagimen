@using KitobdaGimen.Application.Features.PhysicalBooks.Dtos
@using KitobdaGimen.Domain.Enums
@model PhysicalBookDto

@{
    var statusClass = Model.Status switch
    {
        PhysicalBookStatus.Mavjud => "pb-badge--free",
        PhysicalBookStatus.BandQilindi => "pb-badge--reserved",
        PhysicalBookStatus.OqiyApti => "pb-badge--reading",
        _ => "pb-badge--free"
    };
    // Band qilindi holatida 24 soatlik teskari sanoq uchun tugash vaqti (ISO 8601, UTC).
    var expiresIso = Model.ReservationExpiresAt?.ToUniversalTime().ToString("o");
}

<article class="pb-card" data-pb-card="@Model.Id" data-status="@((int)Model.Status)">
    <div class="pb-cover">
        @if (!string.IsNullOrEmpty(Model.CoverUrl))
        {
            <img src="@Model.CoverUrl" alt="@Model.Title muqovasi" loading="lazy" referrerpolicy="no-referrer" />
        }
        else
        {
            <span class="material-symbols-outlined pb-cover-ph">menu_book</span>
        }
        <span class="pb-badge @statusClass">@Model.StatusText</span>
    </div>

    <div class="pb-body">
        <h3 class="pb-title" title="@Model.Title">@Model.Title</h3>
        <p class="pb-author">@Model.Author</p>

        @* Kitob kimniki — barcha foydalanuvchilarga ko'rinadi. *@
        <p class="pb-meta pb-meta--muted">
            <span class="material-symbols-outlined">person</span>
            @if (Model.IsMine)
            {
                <span>Sizning kitobingiz</span>
            }
            else
            {
                <span>Egasi: <a class="pb-user-link" href="@Model.OwnerProfileUrl">@Model.OwnerName</a></span>
            }
        </p>

        @* Band qilindi / O'qiyapti holati — kim band qilgan yoki o'qiyotgani hammaga ko'rinadi. *@
        @if (Model.Status == PhysicalBookStatus.BandQilindi && Model.ReserverName is not null)
        {
            <p class="pb-meta">
                <span class="material-symbols-outlined">schedule</span>
                <span>
                    <a class="pb-user-link" href="@Model.ReserverProfileUrl">@Model.ReserverName</a> band qildi
                </span>
            </p>
            @if (expiresIso is not null)
            {
                <p class="pb-countdown" data-pb-expires="@expiresIso">
                    <span class="material-symbols-outlined">hourglass_bottom</span>
                    <span class="pb-countdown-text">—</span>
                </p>
            }
        }
        else if (Model.Status == PhysicalBookStatus.OqiyApti && Model.ReserverName is not null)
        {
            <p class="pb-meta">
                <span class="material-symbols-outlined">auto_stories</span>
                <span>
                    <a class="pb-user-link" href="@Model.ReserverProfileUrl">@Model.ReserverName</a> o'qiyapti
                </span>
            </p>
        }

        @* Amallar — kim ko'rayotganiga qarab. *@
        @if (Model.IsMine)
        {
            @if (Model.Status == PhysicalBookStatus.BandQilindi)
            {
                <div class="pb-actions">
                    <button class="btn btn-accent btn-sm" data-pb-action="confirm" data-pb-id="@Model.Id">Topshirdim</button>
                    <button class="btn btn-ghost btn-sm" data-pb-action="cancel" data-pb-id="@Model.Id">Bekor qilish</button>
                </div>
            }
            else if (Model.Status == PhysicalBookStatus.OqiyApti)
            {
                <div class="pb-actions">
                    <button class="btn btn-accent btn-sm" data-pb-action="return" data-pb-id="@Model.Id">Qaytarildi</button>
                </div>
            }
            else
            {
                <div class="pb-actions">
                    <button class="btn btn-ghost btn-sm" data-pb-action="delete" data-pb-id="@Model.Id">O'chirish</button>
                </div>
            }
        }
        else
        {
            @if (Model.Status == PhysicalBookStatus.Mavjud)
            {
                <div class="pb-actions">
                    <button class="btn btn-accent btn-sm" data-pb-action="reserve" data-pb-id="@Model.Id">O'qimoqchiman</button>
                </div>
            }
            else if (Model.ReservedByMe && Model.Status == PhysicalBookStatus.BandQilindi)
            {
                <div class="pb-actions">
                    <button class="btn btn-ghost btn-sm" data-pb-action="cancel" data-pb-id="@Model.Id">Bandni bekor qilish</button>
                </div>
            }
        }
    </div>
</article>
