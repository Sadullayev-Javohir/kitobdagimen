@using KitobdaGimen.Domain.Enums
@{
    ViewData["Title"] = "Admin panel";
    ViewData["Robots"] = "noindex, nofollow";
    var myRole = (UserRole)(ViewData["MyRole"] ?? UserRole.User);
    var isSuper = myRole == UserRole.SuperAdmin;
    var userCount = (int)(ViewData["UserCount"] ?? 0);
    var bgVideoUrl = ViewData["BackgroundVideoUrl"] as string;

    string RoleLabel(UserRole r) => r switch
    {
        UserRole.SuperAdmin => "Super admin",
        UserRole.Admin => "Admin",
        _ => "Foydalanuvchi"
    };
}

<div class="container page">
    <div class="admin-head">
        <h1>Admin panel</h1>
        <p class="muted">Jami @userCount foydalanuvchi. Sizning rolingiz: <strong>@RoleLabel(myRole)</strong>.</p>
        @if (isSuper)
        {
            <a href="/admin/analytics" class="btn btn-primary" style="margin-top:10px; display:inline-flex; align-items:center; gap:8px">
                <span class="material-symbols-outlined" style="font-size:20px">insights</span>
                Founder analitika (DAU / retention / konversiya)
            </a>
        }
        <a href="/yil-yakuni/preview" target="_blank" class="btn btn-outline" style="margin-top:10px; display:inline-flex; align-items:center; gap:8px">
            <span class="material-symbols-outlined" style="font-size:20px">celebration</span>
            Yillik yakunni hoziroq sinab ko'rish
        </a>
    </div>

    @if (isSuper)
    {
        <div class="card" style="margin-bottom:18px; padding:18px">
            <h2 style="margin:0 0 8px 0; font-size:18px; display:flex; align-items:center; gap:8px">
                <span class="material-symbols-outlined" style="font-size:22px">movie</span>
                Fon video (barcha sahifalar va landing uchun)
            </h2>
            <p class="muted" style="font-size:13px; margin:0 0 14px 0; line-height:1.5">
                Bu yerda yuklagan video <strong>barcha foydalanuvchilarga va landing sahifasiga</strong> fon
                sifatida qo'llanadi. .mp4, .webm, .mov, .mkv, .ogg, .avi formatlari qabul qilinadi
                (hajmi 150 MB dan oshmasin).
            </p>

            <video id="bgVideoPreview" muted loop playsinline autoplay
                   style="width:100%; max-width:420px; border-radius:12px; border:1px solid var(--border); display:block; margin-bottom:14px">
                <source id="bgVideoPreviewSource" src="@(bgVideoUrl ?? "/videos/book.mp4")" type="video/mp4" />
            </video>

            <div style="display:flex; align-items:center; gap:12px; flex-wrap:wrap">
                <label class="btn btn-outline btn-sm" for="bgVideoInput">
                    <span class="material-symbols-outlined" style="font-size:18px;vertical-align:bottom">upload</span>
                    Video tanlash
                </label>
                <input type="file" id="bgVideoInput" accept="video/*,.mp4,.webm,.mov,.mkv,.ogg,.ogv,.avi" hidden />
                <span id="bgVideoFileName" class="muted" style="font-size:13px"></span>
                <button type="button" id="bgVideoUploadBtn" class="btn btn-primary btn-sm" disabled>
                    <span class="material-symbols-outlined" style="font-size:18px;vertical-align:bottom">cloud_upload</span>
                    Yuklash
                </button>
            </div>
            <div id="bgVideoStatus" class="muted" style="font-size:13px; margin-top:10px; min-height:18px"></div>
        </div>
    }

    <div class="admin-hub-grid">
        <a class="admin-hub-tile" href="/admin/allusers">
            <span class="status-icon status-ok"><span class="material-symbols-outlined">group</span></span>
            <div>
                <div class="admin-hub-tile-label">Foydalanuvchilar</div>
                <div class="admin-hub-tile-desc">Ro'yxat, rol va o'chirish</div>
            </div>
        </a>

        <a class="admin-hub-tile" href="/admin/server-status">
            <span class="status-icon status-ok"><span class="material-symbols-outlined">monitoring</span></span>
            <div>
                <div class="admin-hub-tile-label">Server holati</div>
                <div class="admin-hub-tile-desc">CPU, DB, Redis, HTTP trafik</div>
            </div>
        </a>

        @if (isSuper)
        {
            <a class="admin-hub-tile" href="/admin/year-review">
                <span class="status-icon status-ok"><span class="material-symbols-outlined">campaign</span></span>
                <div>
                    <div class="admin-hub-tile-label">Yillik kitob</div>
                    <div class="admin-hub-tile-desc">Yillik yakunni yuborish</div>
                </div>
            </a>

            <a class="admin-hub-tile" href="/admin/broadcast">
                <span class="status-icon status-ok"><span class="material-symbols-outlined">forum</span></span>
                <div>
                    <div class="admin-hub-tile-label">Broadcast</div>
                    <div class="admin-hub-tile-desc">Barchaga xabar yuborish</div>
                </div>
            </a>

            <a class="admin-hub-tile" href="/admin/settings">
                <span class="status-icon status-ok"><span class="material-symbols-outlined">settings</span></span>
                <div>
                    <div class="admin-hub-tile-label">Tizim sozlamalari</div>
                    <div class="admin-hub-tile-desc">Kesh, muqovalar, statistika</div>
                </div>
            </a>

            <a class="admin-hub-tile" href="/admin/chat-monitor" target="_blank" rel="noopener">
                <span class="status-icon status-ok"><span class="material-symbols-outlined">visibility</span></span>
                <div>
                    <div class="admin-hub-tile-label">Foydalanuvchilarni kuzatish</div>
                    <div class="admin-hub-tile-desc">Xabar almashish auditi (yangi oyna)</div>
                </div>
            </a>
        }
    </div>

    <p class="muted admin-note">
        Postlar va iqtiboslarni o'chirish: tasma (<a href="/feed">/feed</a>) sahifasidagi har bir
        post yoki iqtibos ustidagi <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle">delete</span>
        tugmasi orqali (admin va super admin uchun ko'rinadi).
    </p>
</div>

@section Scripts {
<script>
(function () {
    function token() { var el = document.querySelector('input[name="__RequestVerificationToken"]'); return el ? el.value : ''; }

    var fileInput = document.getElementById("bgVideoInput");
    var uploadBtn = document.getElementById("bgVideoUploadBtn");
    var fileNameEl = document.getElementById("bgVideoFileName");
    var statusEl = document.getElementById("bgVideoStatus");
    var preview = document.getElementById("bgVideoPreview");
    var previewSource = document.getElementById("bgVideoPreviewSource");
    if (!fileInput || !uploadBtn) { return; }

    var extToType = { mp4: "video/mp4", webm: "video/webm", ogg: "video/ogg", ogv: "video/ogg",
        mov: "video/quicktime", mkv: "video/x-matroska", avi: "video/x-msvideo" };

    fileInput.addEventListener("change", function () {
        var f = fileInput.files && fileInput.files[0];
        fileNameEl.textContent = f ? f.name : "";
        uploadBtn.disabled = !f;
    });

    uploadBtn.addEventListener("click", async function () {
        var f = fileInput.files && fileInput.files[0];
        if (!f) { return; }
        uploadBtn.disabled = true;
        statusEl.textContent = "Yuklanmoqda... (video hajmiga qarab biroz vaqt olishi mumkin)";
        try {
            var fd = new FormData();
            fd.append("file", f);
            var r = await fetch("/admin/background-video/upload", {
                method: "POST",
                headers: { "RequestVerificationToken": token(), "X-Requested-With": "XMLHttpRequest" },
                body: fd
            });
            if (!r.ok) { throw new Error("Xatolik (" + r.status + ")"); }
            var d = await r.json();
            statusEl.textContent = d.success ? "✓ " + d.message : "✗ " + d.message;
            if (d.success && d.url) {
                var ext = (d.url.split(".").pop() || "").toLowerCase();
                previewSource.src = d.url;
                previewSource.type = extToType[ext] || "video/mp4";
                preview.load();
                preview.play().catch(function () {});
                fileInput.value = "";
                fileNameEl.textContent = "";
            }
        } catch (e) {
            statusEl.textContent = "✗ Xato: " + e.message;
        } finally {
            uploadBtn.disabled = false;
        }
    });
})();
</script>
}
