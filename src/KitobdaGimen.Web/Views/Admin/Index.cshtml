@using KitobdaGimen.Application.Features.Admin.Dtos
@using KitobdaGimen.Application.Features.Admin.Monitoring
@using KitobdaGimen.Domain.Enums
@model IReadOnlyList<AdminUserDto>
@{
    ViewData["Title"] = "Admin panel";
    ViewData["Robots"] = "noindex, nofollow";
    var myRole = (UserRole)(ViewData["MyRole"] ?? UserRole.User);
    var isSuper = myRole == UserRole.SuperAdmin;
    var serverSnapshot = ViewData["ServerSnapshot"] as ServerSnapshot;

    string RoleLabel(UserRole r) => r switch
    {
        UserRole.SuperAdmin => "Super admin",
        UserRole.Admin => "Admin",
        _ => "Foydalanuvchi"
    };
    string RoleClass(UserRole r) => r switch
    {
        UserRole.SuperAdmin => "role-super",
        UserRole.Admin => "role-admin",
        _ => "role-user"
    };
}

<div class="container page">
    <div class="admin-head">
        <h1>Admin panel</h1>
        <p class="muted">Jami @Model.Count foydalanuvchi. Sizning rolingiz: <strong>@RoleLabel(myRole)</strong>.</p>
        @if (isSuper)
        {
            <a href="/admin/analytics" class="btn btn-primary" style="margin-top:10px; display:inline-flex; align-items:center; gap:8px">
                <span class="material-symbols-outlined" style="font-size:20px">insights</span>
                Founder analitika (DAU / retention / konversiya)
            </a>
        }
    </div>

    @if (serverSnapshot == null)
    {
        <div class="card" style="margin-bottom:18px; padding:16px; display:flex; align-items:center; gap:10px">
            <span class="material-symbols-outlined" style="font-size:20px">hourglass_top</span>
            <span class="muted">Server metrikalari yig'ilmoqda — bir necha soniyadan so'ng sahifani yangilang.</span>
        </div>
    }

    @if (serverSnapshot != null)
    {
        var bannerClass = serverSnapshot.OverallRisk switch
        {
            RiskLevel.Critical => "risk-banner risk-critical",
            RiskLevel.Warning => "risk-banner risk-warning",
            _ => "risk-banner risk-ok"
        };
        var activeRisks = serverSnapshot.Risks.Where(r => r.Severity != RiskLevel.Ok).ToList();
        var bannerText = serverSnapshot.OverallRisk switch
        {
            RiskLevel.Critical => $"Jiddiy muammo — {activeRisks.Count} ta xavf aniqlandi",
            RiskLevel.Warning => $"{activeRisks.Count} ta ogohlantirish",
            _ => "Tizim barqaror — muammolar yo'q"
        };
        var bannerIcon = serverSnapshot.OverallRisk switch
        {
            RiskLevel.Critical => "error",
            RiskLevel.Warning => "warning",
            _ => "check_circle"
        };

        <div class="@bannerClass" style="margin-bottom:18px; padding:14px 18px; border-radius:14px; display:flex; align-items:center; gap:10px">
            <span class="material-symbols-outlined">@bannerIcon</span>
            <strong>@bannerText</strong>
        </div>

        @if (activeRisks.Count > 0)
        {
            <div class="card" style="margin-bottom:18px; padding:16px">
                <h2 style="margin:0 0 12px 0; font-size:16px; display:flex; align-items:center; gap:8px">
                    <span class="material-symbols-outlined" style="font-size:20px">gpp_maybe</span>
                    Xavf-xatarlar
                </h2>
                <div style="display:flex; flex-direction:column; gap:8px">
                    @foreach (var risk in activeRisks)
                    {
                        var dot = risk.Severity == RiskLevel.Critical ? "status-error" : "status-warn";
                        <div style="display:flex; align-items:flex-start; gap:10px; padding:10px 12px; background:var(--bg); border-radius:10px; border:1px solid var(--border)">
                            <span class="status-dot @dot" style="margin-top:3px; width:10px; height:10px; border-radius:50%; flex-shrink:0"></span>
                            <div>
                                <strong style="display:block">@risk.Title</strong>
                                <span class="muted" style="font-size:13px">@risk.Detail</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <div class="card admin-server-status" style="margin-bottom:18px; padding:20px">
            <h2 style="margin:0 0 16px 0; font-size:18px; display:flex; align-items:center; gap:8px">
                <span class="material-symbols-outlined" style="font-size:22px">monitoring</span>
                Server holati
            </h2>
            <div class="status-grid">
                <!-- Database -->
                <div class="status-card">
                    <div class="status-icon @(serverSnapshot.Database.Up ? "status-ok" : "status-error")">
                        <span class="material-symbols-outlined">storage</span>
                    </div>
                    <div class="status-info">
                        <div class="status-label">Ma'lumotlar bazasi</div>
                        <div class="status-value">@(serverSnapshot.Database.Up ? "Faol" : "Ulanmagan")</div>
                        @if (serverSnapshot.Database.Up)
                        {
                            <div class="status-detail">Ping: @serverSnapshot.Database.PingMs.ToString("0.0") ms</div>
                            <div class="status-detail">Ulanishlar: @serverSnapshot.Database.ActiveConnections</div>
                        }
                    </div>
                </div>

                <!-- Redis -->
                <div class="status-card">
                    <div class="status-icon @(serverSnapshot.Redis.Up ? "status-ok" : serverSnapshot.Redis.Configured ? "status-error" : "status-warn")">
                        <span class="material-symbols-outlined">memory</span>
                    </div>
                    <div class="status-info">
                        <div class="status-label">Redis (kesh)</div>
                        <div class="status-value">
                            @if (!serverSnapshot.Redis.Configured)
                            {
                                <span>Sozlanmagan</span>
                            }
                            else if (serverSnapshot.Redis.Up)
                            {
                                <span>Faol</span>
                            }
                            else
                            {
                                <span>Ulanmagan</span>
                            }
                        </div>
                        @if (serverSnapshot.Redis.Up)
                        {
                            <div class="status-detail">Ping: @serverSnapshot.Redis.PingMs.ToString("0.0") ms</div>
                            <div class="status-detail">Xotira: @serverSnapshot.Redis.UsedMemory</div>
                        }
                    </div>
                </div>

                <!-- CPU & RAM -->
                <div class="status-card">
                    <div class="status-icon @(serverSnapshot.System.CpuPercent < 80 ? "status-ok" : "status-warn")">
                        <span class="material-symbols-outlined">speed</span>
                    </div>
                    <div class="status-info">
                        <div class="status-label">CPU va xotira</div>
                        <div class="status-value">CPU: @serverSnapshot.System.CpuPercent.ToString("0.0")%</div>
                        <div class="status-detail">RAM: @serverSnapshot.System.WorkingSetMb MB</div>
                        <div class="status-detail">Managed: @serverSnapshot.System.ManagedHeapMb MB</div>
                    </div>
                </div>

                <!-- Realtime -->
                <div class="status-card">
                    <div class="status-icon status-ok">
                        <span class="material-symbols-outlined">hub</span>
                    </div>
                    <div class="status-info">
                        <div class="status-label">Real-time (SignalR)</div>
                        <div class="status-value">@serverSnapshot.Realtime.OnlineUsers ta onlayn</div>
                        <div class="status-detail">Ulanishlar: @serverSnapshot.Realtime.ActiveConnections</div>
                    </div>
                </div>

                <!-- HTTP traffic -->
                <div class="status-card">
                    <div class="status-icon @(serverSnapshot.Http.ErrorRate5xxPercent < 1 ? "status-ok" : "status-warn")">
                        <span class="material-symbols-outlined">traffic</span>
                    </div>
                    <div class="status-info">
                        <div class="status-label">HTTP trafik</div>
                        <div class="status-value">@serverSnapshot.Http.RequestsPerSecond.ToString("0.0") so'rov/s</div>
                        <div class="status-detail">O'rtacha: @serverSnapshot.Http.AvgResponseMs.ToString("0") ms | p95: @serverSnapshot.Http.P95ResponseMs.ToString("0") ms</div>
                        <div class="status-detail">
                            5xx: @serverSnapshot.Http.ErrorRate5xxPercent.ToString("0.0")% |
                            429/daq: @serverSnapshot.Http.RateLimitedPerMinute
                        </div>
                        <div class="status-detail">Jami so'rovlar: @serverSnapshot.Http.TotalRequests</div>
                    </div>
                </div>

                <!-- Hangfire -->
                @if (serverSnapshot.Hangfire.Available)
                {
                    <div class="status-card">
                        <div class="status-icon @(serverSnapshot.Hangfire.Failed > 0 ? "status-warn" : "status-ok")">
                            <span class="material-symbols-outlined">schedule</span>
                        </div>
                        <div class="status-info">
                            <div class="status-label">Hangfire (fon vazifalari)</div>
                            <div class="status-value">@serverSnapshot.Hangfire.Enqueued navbatda</div>
                            <div class="status-detail">Muvaffaqiyatli: @serverSnapshot.Hangfire.Succeeded</div>
                            @if (serverSnapshot.Hangfire.Failed > 0)
                            {
                                <div class="status-detail status-error-text">Xato: @serverSnapshot.Hangfire.Failed</div>
                            }
                        </div>
                    </div>
                }

                <!-- Disk -->
                <div class="status-card">
                    <div class="status-icon @(serverSnapshot.Disk.FreePercent > 20 ? "status-ok" : "status-warn")">
                        <span class="material-symbols-outlined">hard_drive</span>
                    </div>
                    <div class="status-info">
                        <div class="status-label">Disk</div>
                        <div class="status-value">Bo'sh: @serverSnapshot.Disk.FreePercent.ToString("0.0")%</div>
                        <div class="status-detail">Yuklangan fayllar: @serverSnapshot.Disk.UploadsSizeMb MB</div>
                        <div class="status-detail">Bo'sh joy: @serverSnapshot.Disk.DriveFreeMb MB</div>
                    </div>
                </div>
            </div>

            @if (serverSnapshot.Http.TopEndpoints.Any())
            {
                <div style="margin-top:16px; padding-top:16px; border-top:1px solid var(--border-color)">
                    <div class="status-label" style="margin-bottom:8px">Eng band endpointlar</div>
                    <div style="display:flex; flex-direction:column; gap:6px">
                        @foreach (var ep in serverSnapshot.Http.TopEndpoints)
                        {
                            <div style="display:flex; justify-content:space-between; gap:12px; font-size:13px">
                                <code style="overflow:hidden; text-overflow:ellipsis; white-space:nowrap">@ep.Path</code>
                                <span class="muted" style="flex-shrink:0">@ep.Count ta · @ep.AvgMs.ToString("0") ms</span>
                            </div>
                        }
                    </div>
                </div>
            }

            <div style="margin-top:16px; padding-top:16px; border-top:1px solid var(--border-color); font-size:13px; color:var(--text-muted)">
                <strong>Tizim:</strong> @serverSnapshot.System.OsDescription |
                <strong>Uptime:</strong> @serverSnapshot.System.Uptime |
                <strong>.NET:</strong> @serverSnapshot.System.DotNetVersion |
                <strong>Oxirgi yangilanish:</strong> @serverSnapshot.Timestamp.ToString("HH:mm:ss")
            </div>
        </div>
    }

    @if (isSuper)
    {
        <div class="card" style="margin-bottom:18px; padding:18px">
            <h2 style="margin:0 0 16px 0; font-size:18px; display:flex; align-items:center; gap:8px">
                <span class="material-symbols-outlined" style="font-size:22px">settings</span>
                Tizim sozlamalari
            </h2>
            
            <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(300px, 1fr)); gap:16px">
                <!-- Keshni tozalash -->
                <div style="display:flex; align-items:center; gap:14px; padding:14px; background:var(--bg); border-radius:10px; border:1px solid var(--border)">
                    <div style="flex:1; min-width:0">
                        <strong style="display:block; margin-bottom:4px">Redis keshlarini tozalash</strong>
                        <div class="muted" style="font-size:13px">Barcha keshlangan ma'lumotlar (feed, profillar, kitoblar) tozalanadi.</div>
                    </div>
                    <button type="button" id="clearCacheBtn" class="btn btn-danger btn-sm" style="flex-shrink:0">
                        <span class="material-symbols-outlined" style="font-size:18px;vertical-align:bottom">delete_sweep</span>
                        Tozalash
                    </button>
                </div>

                <!-- Muqovalarni tiklash -->
                <div style="display:flex; align-items:center; gap:14px; padding:14px; background:var(--bg); border-radius:10px; border:1px solid var(--border)">
                    <div style="flex:1; min-width:0">
                        <strong style="display:block; margin-bottom:4px">Kitob muqovalarini tiklash</strong>
                        <div class="muted" style="font-size:13px">Yo'qolgan muqovalar asaxiy.uz dan qayta yuklanadi.</div>
                    </div>
                    <button type="button" id="refreshCoversBtn" class="btn btn-primary btn-sm" style="flex-shrink:0">
                        <span class="material-symbols-outlined" style="font-size:18px;vertical-align:bottom">image</span>
                        Tiklash
                    </button>
                </div>
            </div>

            <div id="settingsStatus" class="muted" style="font-size:13px; margin-top:12px; min-height:20px"></div>
        </div>
    }

    <div class="card admin-card">
        <div class="admin-table-wrap">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Foydalanuvchi</th>
                        <th>Rol</th>
                        <th>Ro'yxatdan o'tgan</th>
                        <th>Oxirgi kirgan</th>
                        <th>Post / Iqtibos</th>
                        <th>Amallar</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        <tr>
                            <td>
                                <div class="admin-user">
                                    @if (!string.IsNullOrEmpty(u.AvatarUrl))
                                    {
                                        <img class="avatar sm" src="@u.AvatarUrl" alt="@u.FullName" referrerpolicy="no-referrer" />
                                    }
                                    else
                                    {
                                        <span class="avatar sm">@KitobdaGimen.Web.ViewHelpers.Initial(u.FullName)</span>
                                    }
                                    <div class="admin-user-meta">
                                        <a class="name" href="@KitobdaGimen.Web.ViewHelpers.ProfileUrl(u.Username, u.Id)">@u.FullName</a>
                                        <span class="muted">@u.Email</span>
                                    </div>
                                </div>
                            </td>
                            <td><span class="role-badge @RoleClass(u.Role)">@RoleLabel(u.Role)</span></td>
                            <td class="admin-time">@KitobdaGimen.Web.ViewHelpers.ExactLocal(u.CreatedAt)</td>
                            <td class="admin-time">@KitobdaGimen.Web.ViewHelpers.ExactLocal(u.LastSeenAt)</td>
                            <td>@u.PostCount / @u.QuoteCount</td>
                            <td>
                                @if (isSuper && u.Role != UserRole.SuperAdmin)
                                {
                                    <div class="admin-actions">
                                        @if (u.Role == UserRole.Admin)
                                        {
                                            <form method="post" action="/admin/users/@u.Id/role" style="display:inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="makeAdmin" value="false" />
                                                <button type="submit" class="btn btn-outline btn-sm">Adminlikdan olish</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form method="post" action="/admin/users/@u.Id/role" style="display:inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="makeAdmin" value="true" />
                                                <button type="submit" class="btn btn-primary btn-sm">Admin qilish</button>
                                            </form>
                                        }
                                        <form method="post" action="/admin/users/@u.Id/delete" style="display:inline"
                                              onsubmit="return confirm('@u.FullName ni va uning barcha kontentini butunlay o\'chirishni tasdiqlaysizmi?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-danger btn-sm">O'chirish</button>
                                        </form>
                                    </div>
                                }
                                else if (u.Role == UserRole.SuperAdmin)
                                {
                                    <span class="muted">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <p class="muted admin-note">
        Postlar va iqtiboslarni o'chirish: tasma (<a href="/feed">/feed</a>) sahifasidagi har bir
        post yoki iqtibos ustidagi <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle">delete</span>
        tugmasi orqali (admin va super admin uchun ko'rinadi).
    </p>
</div>

@section Scripts {
<script>
(function () {
    function token() { var el = document.querySelector('input[name="__RequestVerificationToken"]'); return el ? el.value : ''; }
    var status = document.getElementById("settingsStatus");
    
    // Keshni tozalash
    var clearCacheBtn = document.getElementById("clearCacheBtn");
    if (clearCacheBtn) {
        clearCacheBtn.addEventListener("click", async function () {
            if (!confirm("Barcha keshlarni tozalashni tasdiqlaysizmi? Bu sahifalar sekinroq yuklanishiga olib kelishi mumkin.")) {
                return;
            }
            clearCacheBtn.disabled = true;
            status.textContent = "Tozalanmoqda...";
            try {
                var r = await fetch("/admin/clear-cache", {
                    method: "POST",
                    headers: { "RequestVerificationToken": token(), "X-Requested-With": "XMLHttpRequest" }
                });
                if (!r.ok) throw new Error("Xatolik (" + r.status + ")");
                var d = await r.json();
                status.textContent = d.success ? "✓ " + d.message : "✗ " + d.message;
            } catch (e) {
                status.textContent = "✗ Xato: " + e.message;
            } finally {
                clearCacheBtn.disabled = false;
            }
        });
    }

    // Muqovalarni tiklash
    var refreshCoversBtn = document.getElementById("refreshCoversBtn");
    if (refreshCoversBtn) {
        refreshCoversBtn.addEventListener("click", async function () {
            refreshCoversBtn.disabled = true;
            status.textContent = "Tiklanmoqda... (biroz vaqt oladi)";
            try {
                var r = await fetch("/admin/refresh-covers", {
                    method: "POST",
                    headers: { "RequestVerificationToken": token(), "X-Requested-With": "XMLHttpRequest" }
                });
                if (!r.ok) throw new Error("Xatolik (" + r.status + ")");
                var d = await r.json();
                status.textContent = "✓ Tiklandi: " + d.fixedCount + " ta. Qolgan: " + d.remaining +
                    ". Jami asaxiy kitoblar: " + d.totalAsaxiy + ".";
                if (d.fixedCount > 0) setTimeout(function () { location.reload(); }, 1500);
            } catch (e) {
                status.textContent = "✗ Xato: " + e.message;
            } finally {
                refreshCoversBtn.disabled = false;
            }
        });
    }
})();
</script>
}
