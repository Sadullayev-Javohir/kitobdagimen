@using KitobdaGimen.Web
@{
    ViewData["Title"] = "Chat kuzatuv";
    ViewData["Robots"] = "noindex, nofollow";
    var preselected = ViewData["PreselectedConversationId"] as int?;
    var stickers = KitobdaGimen.Web.ChatStickers.All;
}

<div class="chat chat-monitor">
    <aside class="chat-sidebar">
        <div class="chat-search">
            <div class="search-box">
                <span class="search-ico">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4"/></svg>
                </span>
                <input class="input" id="cmSearch" type="search" placeholder="Ism yoki foydalanuvchi nomi..." autocomplete="off" />
            </div>
        </div>

        <div class="chat-list-title">Suhbatlar (kim kim bilan)</div>
        <div id="cmList" class="cm-list"></div>
        <div id="cmMoreWrap" class="cm-more"></div>
    </aside>

    <section class="chat-main">
        <div id="cmEmpty" class="chat-empty">
            <div>
                <span class="material-symbols-outlined">forum</span>
                <p>Chap tomondan kuzatmoqchi bo‘lgan suhbatni tanlang.</p>
                <p class="muted">Faqat super admin ko‘ra oladi — bu yerda xabar yuborib bo‘lmaydi.</p>
            </div>
        </div>

        <div id="cmThread" class="cm-thread" hidden>
            <header class="chat-header cm-header" id="cmHeader"></header>

            <div class="messages" id="messages"></div>

            <div class="cm-notice">
                <span class="material-symbols-outlined">visibility</span>
                Faqat kuzatuv rejimi — xabar yuborish, tahrirlash yoki o‘chirish mumkin emas.
            </div>

            <!-- Rasm lightbox -->
            <div class="chat-lightbox" id="cmLightbox" hidden>
                <button type="button" class="chat-lightbox-close" id="cmLightboxClose" aria-label="Yopish">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18"/><path d="M6 6l12 12"/></svg>
                </button>
                <img id="cmLightboxImg" src="" alt="Rasm" />
            </div>
        </div>
    </section>
</div>

@section Scripts {
<script>
(function () {
    "use strict";
    function esc(s) { const d = document.createElement("div"); d.textContent = s == null ? "" : s; return d.innerHTML; }
    const pad2 = n => String(n).padStart(2, "0");

    // ── O'zbekiston vaqti (UTC+5) — /chat bilan bir xil, qurilma timezone'idan mustaqil ──
    const UZ_OFFSET_MS = 5 * 60 * 60 * 1000;
    function uzDate(value) { const d = new Date(value); return isNaN(d) ? null : new Date(d.getTime() + UZ_OFFSET_MS); }
    function fmtTime(iso) {
        if (!iso) return "";
        const d = uzDate(iso); if (!d) return "";
        return `${pad2(d.getUTCHours())}:${pad2(d.getUTCMinutes())}`;
    }
    function fmtListTime(iso) {
        if (!iso) return "";
        const d = uzDate(iso); if (!d) return "";
        const now = uzDate(new Date());
        const sameDay = d.getUTCFullYear() === now.getUTCFullYear()
            && d.getUTCMonth() === now.getUTCMonth() && d.getUTCDate() === now.getUTCDate();
        if (sameDay) return fmtTime(iso);
        return `${pad2(d.getUTCDate())}.${pad2(d.getUTCMonth() + 1)}.${String(d.getUTCFullYear()).slice(-2)}`;
    }

    // Stikerlar (server bilan bir xil manba).
    const STICKERS = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(stickers));

    const ICON = {
        single: '<svg class="tick-svg" viewBox="0 0 18 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 7l3.4 3.4L13 2.4"/></svg>',
        double: '<svg class="tick-svg dbl" viewBox="0 0 22 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 7l3.4 3.4L12 2.4"/><path d="M8.5 9.6L16.5 2"/></svg>',
        book: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>',
        play: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>',
        pause: '<svg viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="5" width="4" height="14" rx="1"/><rect x="14" y="5" width="4" height="14" rx="1"/></svg>'
    };

    function initials(name) {
        if (!name) return "?";
        const parts = String(name).trim().split(/\s+/);
        return ((parts[0] ? parts[0][0] : "") + (parts[1] ? parts[1][0] : "") || "?").toUpperCase();
    }
    function avatarHtml(u, cls) {
        if (u && u.avatarUrl) return `<img class="${cls}" src="${esc(u.avatarUrl)}" alt="${esc(u.fullName || "")}" referrerpolicy="no-referrer" />`;
        return `<span class="${cls}">${esc(initials(u ? u.fullName : ""))}</span>`;
    }
    function msgPreview(m) {
        if (m.text) return m.text;
        if (m.imageUrl) return "📷 Rasm";
        if (m.voiceUrl) return "🎤 Ovozli xabar";
        if (m.stickerKey) return "Stiker";
        if (m.sharedPost) return "📚 Post";
        return "";
    }
    function fmtDur(sec) { sec = Math.max(0, Math.round(sec || 0)); return `${Math.floor(sec / 60)}:${String(sec % 60).padStart(2, "0")}`; }

    const state = {
        convId: null, page: 1, totalPages: 1, loading: false,
        userPage: 1, userTerm: "",
        users: null, perspectiveId: null,
        messages: []
    };

    const chatRoot = document.querySelector(".chat.chat-monitor");
    const listEl = document.getElementById("cmList");
    const moreWrap = document.getElementById("cmMoreWrap");
    const emptyEl = document.getElementById("cmEmpty");
    const threadEl = document.getElementById("cmThread");
    const headerEl = document.getElementById("cmHeader");
    const messagesEl = document.getElementById("messages");
    const searchEl = document.getElementById("cmSearch");

    // Mobile: suhbat ochilganda ro'yxat yashirilib, xabarlar ko'rsatilishi uchun
    // `.chat`ga `has-active` klassi qo'shilishi kerak (site.css mobil qoidasi).
    function setActive(on) { if (chatRoot) chatRoot.classList.toggle("has-active", !!on); }

    // ── Suhbatlar ro'yxati ───────────────────────────────────────────────
    async function loadConversations(reset) {
        if (reset) state.userPage = 1;
        const q = searchEl.value.trim();
        if (q !== state.userTerm) { state.userTerm = q; state.userPage = 1; }
        const r = await fetch(`/admin/chat-monitor/conversations?q=${encodeURIComponent(q)}&page=${state.userPage}`,
            { headers: { "X-Requested-With": "XMLHttpRequest" } });
        if (!r.ok) return;
        const d = await r.json();
        if (state.userPage === 1) listEl.innerHTML = "";
        if (state.userPage === 1 && d.items.length === 0) {
            listEl.innerHTML = `<p class="muted cm-empty-list">Suhbat topilmadi.</p>`;
        }
        d.items.forEach(c => listEl.appendChild(buildConvRow(c)));

        const hasMore = (state.userPage * d.pageSize) < d.total;
        moreWrap.innerHTML = "";
        if (hasMore) {
            const b = document.createElement("button");
            b.type = "button"; b.className = "btn btn-outline btn-sm"; b.textContent = "Ko‘proq suhbat";
            b.addEventListener("click", () => { state.userPage++; loadConversations(false); });
            moreWrap.appendChild(b);
        }
    }

    function buildConvRow(c) {
        const a = document.createElement("a");
        a.className = "cm-conv";
        a.dataset.id = c.id;
        a.href = "#";
        const active = state.convId === c.id;
        if (active) a.classList.add("active");

        const avs = document.createElement("span");
        avs.className = "cm-avatars";
        avs.innerHTML = avatarHtml(c.user1, "cm-av cm-av-1") + avatarHtml(c.user2, "cm-av cm-av-2");

        const info = document.createElement("div");
        info.className = "cm-conv-info";
        const names = document.createElement("div");
        names.className = "cm-conv-names";
        names.innerHTML = `${esc(c.user1.fullName)} <span class="cm-conv-x">⇄</span> ${esc(c.user2.fullName)}`;
        const last = document.createElement("div");
        last.className = "cm-conv-last";
        last.textContent = c.lastMessageText || "Suhbat boshlandi";
        info.appendChild(names);
        info.appendChild(last);

        const time = document.createElement("div");
        time.className = "cm-conv-time";
        time.textContent = fmtListTime(c.lastMessageAt);

        a.appendChild(avs);
        a.appendChild(info);
        a.appendChild(time);
        a.addEventListener("click", (e) => { e.preventDefault(); openConversation(c.id); });
        return a;
    }

    // ── Suhbatni ochish (xabarlar oqimi) ───────────────────────────────
    async function openConversation(convId) {
        state.convId = convId;
        state.page = 1;
        state.messages = [];

        Array.prototype.forEach.call(listEl.querySelectorAll(".cm-conv"), el => {
            el.classList.toggle("active", el.dataset.id === String(convId));
        });

        emptyEl.hidden = true;
        threadEl.hidden = false;
        setActive(true);
        messagesEl.innerHTML = "";
        headerEl.innerHTML = `<div class="cm-loading">Yuklanmoqda…</div>`;

        const r = await fetch(`/admin/chat-monitor/conversation/${convId}/messages?page=1`,
            { headers: { "X-Requested-With": "XMLHttpRequest" } });
        if (!r.ok) { headerEl.innerHTML = `<div class="cm-loading">Xatolik yuz berdi.</div>`; return; }
        const d = await r.json();

        state.users = { user1: d.user1, user2: d.user2 };
        state.page = d.page;
        state.totalPages = d.totalPages;
        state.perspectiveId = d.user2.id; // default: ikkinchi ishtirokchi "o'zim" tomonida
        state.messages = d.items.slice();

        renderHeader();
        renderAll();
    }

    function renderHeader() {
        if (!state.users) return;
        const u1 = state.users.user1, u2 = state.users.user2;
        headerEl.innerHTML = "";

        const back = document.createElement("button");
        back.type = "button";
        back.className = "chat-tool-btn";
        back.dataset.back = "1";
        back.setAttribute("aria-label", "Orqaga");
        back.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>';
        back.addEventListener("click", () => {
            setActive(false);
            threadEl.hidden = true;
            emptyEl.hidden = false;
            state.convId = null;
            Array.prototype.forEach.call(listEl.querySelectorAll(".cm-conv"), el => el.classList.remove("active"));
        });
        headerEl.appendChild(back);

        const avs = document.createElement("span");
        avs.className = "cm-avatars cm-avatars-lg";
        avs.innerHTML = avatarHtml(u1, "cm-av cm-av-1") + avatarHtml(u2, "cm-av cm-av-2");

        const info = document.createElement("div");
        info.className = "cm-head-info";
        info.innerHTML = `<div class="cm-head-names">${esc(u1.fullName)} <span class="cm-conv-x">⇄</span> ${esc(u2.fullName)}</div>` +
            `<div class="cm-head-sub muted">Kim kim bilan yozishganini kuzatish</div>`;

        const toggle = document.createElement("div");
        toggle.className = "cm-persp";
        toggle.innerHTML = `<span class="cm-persp-label muted">Ko‘rinish:</span>`;
        [u1, u2].forEach(u => {
            const b = document.createElement("button");
            b.type = "button";
            b.className = "cm-persp-btn" + (state.perspectiveId === u.id ? " active" : "");
            b.innerHTML = `${avatarHtml(u, "cm-persp-av")}<span>${esc(u.fullName.split(" ")[0])}</span>`;
            b.addEventListener("click", () => {
                state.perspectiveId = u.id;
                Array.prototype.forEach.call(toggle.querySelectorAll(".cm-persp-btn"), x => x.classList.remove("active"));
                b.classList.add("active");
                renderAll();
            });
            toggle.appendChild(b);
        });

        headerEl.appendChild(avs);
        headerEl.appendChild(info);
        headerEl.appendChild(toggle);
    }

    function renderAll() {
        messagesEl.innerHTML = "";
        const frag = document.createDocumentFragment();
        state.messages.forEach(m => frag.appendChild(renderMessage(m)));
        messagesEl.appendChild(frag);
        messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    function buildMsgInner(m) {
        const mine = m.senderId === state.perspectiveId;
        let content = "";
        if (m.replyToId) {
            content += `<button type="button" class="msg-reply-quote" data-reply-to="${m.replyToId}">` +
                `<span class="rq-name">${esc(m.replyToSenderName || "")}</span>` +
                `<span class="rq-text">${esc(m.replyToPreview || "")}</span></button>`;
        }
        if (m.stickerKey && STICKERS[m.stickerKey]) content += `<span class="msg-sticker">${STICKERS[m.stickerKey]}</span>`;
        if (m.imageUrl) content += `<img class="msg-image" src="${esc(m.imageUrl)}" data-full="${esc(m.imageUrl)}" alt="rasm" loading="lazy" />`;
        if (m.voiceUrl) {
            content += `<div class="msg-voice" data-voice="${esc(m.voiceUrl)}" data-dur="${m.voiceDurationSeconds || 0}">` +
                `<button type="button" class="mv-play" aria-label="Ovozni eshitish">${ICON.play}</button>` +
                `<div class="mv-body"><div class="mv-track"><span class="mv-fill"></span></div>` +
                `<div class="mv-dur">${fmtDur(m.voiceDurationSeconds)}</div></div>` +
                `<audio src="${esc(m.voiceUrl)}" preload="none"></audio></div>`;
        }
        if (m.text) content += `<span class="msg-text">${esc(m.text)}</span>`;
        if (m.sharedPost) {
            content += `<a class="shared-card" href="/posts/${m.sharedPost.postId}">` +
                `<span class="shared-ico">${ICON.book}</span>` +
                `<span class="shared-meta"><span class="shared-title">${esc(m.sharedPost.bookTitle || "")}</span>` +
                `<span class="shared-author">${esc(m.sharedPost.bookAuthor || "")}</span></span></a>`;
        }
        let meta = "";
        if (m.editedAt) meta += `<span class="msg-edited">tahrirlangan</span>`;
        meta += `<span class="msg-time" data-ts="${esc(m.sentAt || "")}">${fmtTime(m.sentAt)}</span>`;
        if (mine) meta += `<span class="ticks ${m.isRead ? "read" : ""}">${m.isRead ? ICON.double : ICON.single}</span>`;

        const reactions = (m.reactions && m.reactions.length)
            ? `<div class="msg-reactions">` + m.reactions.map(r =>
                `<span class="reaction-chip"><span>${esc(r.emoji)}</span><span class="rc-count">${r.count}</span></span>`).join("") + `</div>`
            : "";

        const nameLabel = `<div class="msg-sender">${esc(m.senderName || "")}</div>`;
        return `<div class="msg-content">${nameLabel}${content}` +
            (meta ? `<span class="meta-row">${meta}</span>` : "") + `</div>` + reactions;
    }

    function renderMessage(m) {
        const mine = m.senderId === state.perspectiveId;
        const isSticker = !!(m.stickerKey && STICKERS[m.stickerKey]);
        const div = document.createElement("div");
        div.className = `msg ${mine ? "out" : "in"} ${isSticker ? "is-sticker" : ""} ${m.imageUrl ? "has-image" : ""} ${m.isDeleted ? "is-deleted" : ""}`;
        div.dataset.msgId = m.id;
        div.dataset.replyName = m.senderName || "";
        div.dataset.replyPreview = msgPreview(m);
        div.innerHTML = buildMsgInner(m) + (m.isDeleted ? `<div class="msg-del-note">🗑 O‘chirilgan</div>` : "");
        return div;
    }

    // ── Eski xabarlarni yuklash (tepaga aylantirilganda) ──
    async function loadOlder() {
        if (state.loading || state.page >= state.totalPages || !state.convId) return;
        state.loading = true;
        try {
            const r = await fetch(`/admin/chat-monitor/conversation/${state.convId}/messages?page=${state.page + 1}`,
                { headers: { "X-Requested-With": "XMLHttpRequest" } });
            if (!r.ok) return;
            const d = await r.json();
            state.page = d.page;
            state.totalPages = d.totalPages;
            if (d.items && d.items.length) {
                const prevHeight = messagesEl.scrollHeight;
                const frag = document.createDocumentFragment();
                d.items.forEach(m => { state.messages.unshift(m); frag.appendChild(renderMessage(m)); });
                messagesEl.insertBefore(frag, messagesEl.firstElementChild);
                messagesEl.scrollTop += messagesEl.scrollHeight - prevHeight;
            }
        } finally { state.loading = false; }
    }

    if (messagesEl) {
        messagesEl.addEventListener("scroll", () => { if (messagesEl.scrollTop < 80) loadOlder(); });
    }

    // ── Ovozli xabar ijrosi ──
    let currentVoiceEl = null;
    function toggleVoice(voiceEl) {
        if (!voiceEl) return;
        const audio = voiceEl.querySelector("audio");
        const fill = voiceEl.querySelector(".mv-fill");
        const durEl = voiceEl.querySelector(".mv-dur");
        const playBtn = voiceEl.querySelector(".mv-play");
        if (!audio) return;
        if (currentVoiceEl && currentVoiceEl !== voiceEl) {
            const other = currentVoiceEl.querySelector("audio"); if (other) other.pause();
        }
        if (audio.paused) {
            currentVoiceEl = voiceEl;
            audio.play().catch(() => {});
            if (playBtn) playBtn.innerHTML = ICON.pause;
            audio.ontimeupdate = () => {
                if (audio.duration && fill) fill.style.width = (audio.currentTime / audio.duration * 100) + "%";
                if (durEl && audio.duration) durEl.textContent = fmtDur(audio.duration - audio.currentTime);
            };
            audio.onended = () => {
                if (playBtn) playBtn.innerHTML = ICON.play;
                if (fill) fill.style.width = "0";
                if (durEl) durEl.textContent = fmtDur(parseInt(voiceEl.dataset.dur, 10) || audio.duration);
                currentVoiceEl = null;
            };
        } else {
            audio.pause();
            if (playBtn) playBtn.innerHTML = ICON.play;
        }
    }

    // ── Rasm lightbox ──
    const lightbox = document.getElementById("cmLightbox");
    const lightboxImg = document.getElementById("cmLightboxImg");
    function openLightbox(url) {
        if (!lightbox || !url) return;
        lightboxImg.src = url;
        lightbox.hidden = false;
    }
    function closeLightbox() { if (!lightbox) return; lightbox.hidden = true; lightboxImg.src = ""; }
    if (lightbox) {
        lightbox.addEventListener("click", (e) => { if (e.target === lightbox || e.target.closest("#cmLightboxClose")) closeLightbox(); });
        document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeLightbox(); });
    }

    function scrollToMessage(id) {
        const el = messagesEl ? messagesEl.querySelector(`.msg[data-msg-id="${id}"]`) : null;
        if (!el) return;
        el.scrollIntoView({ behavior: "smooth", block: "center" });
        el.classList.remove("flash"); void el.offsetWidth; el.classList.add("flash");
    }

    // ── Xabarlar maydonidagi bosishlar ──
    if (messagesEl) {
        const IMG_PLACEHOLDER = "data:image/svg+xml;utf8," + encodeURIComponent(
            "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='#1B4D3E' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><path d='M4 19.5A2.5 2.5 0 0 1 6.5 17H20'/><path d='M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z'/></svg>");
        messagesEl.addEventListener("error", (e) => {
            const t = e.target;
            if (t && t.classList && t.classList.contains("msg-image") && !t.dataset.failed) {
                t.dataset.failed = "1"; t.classList.add("img-failed"); t.removeAttribute("data-full"); t.src = IMG_PLACEHOLDER;
            }
        }, true);

        messagesEl.addEventListener("click", (e) => {
            const img = e.target.closest(".msg-image");
            if (img) { if (!img.classList.contains("img-failed")) openLightbox(img.dataset.full || img.src); return; }
            const playBtn = e.target.closest(".mv-play");
            if (playBtn) { toggleVoice(playBtn.closest(".msg-voice")); return; }
            const quote = e.target.closest(".msg-reply-quote");
            if (quote) { scrollToMessage(parseInt(quote.dataset.replyTo, 10)); return; }
        });
    }

    // ── Qidiruv (debounce) ──
    let t;
    searchEl.addEventListener("input", () => { clearTimeout(t); t = setTimeout(() => loadConversations(true), 250); });

    // ── Ishga tushirish ──
    loadConversations(true);
    const PRESELECTED = @(preselected.HasValue ? preselected.Value.ToString() : "null");
    if (PRESELECTED) openConversation(PRESELECTED);
})();
</script>

<style>
    .chat-monitor .cm-list { display: flex; flex-direction: column; }
    .chat-monitor .cm-empty-list { padding: 14px 16px; font-size: 13px; }

    .chat-monitor .cm-conv {
        display: flex; gap: 12px; align-items: center; padding: 12px 16px;
        border-bottom: 1px solid var(--border); cursor: pointer; text-decoration: none; color: var(--text);
    }
    .chat-monitor .cm-conv:hover, .chat-monitor .cm-conv.active { background: var(--primary-soft); }
    .chat-monitor .cm-conv-info { flex: 1; min-width: 0; }
    .chat-monitor .cm-conv-names { font-weight: 600; font-size: 14px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .chat-monitor .cm-conv-x { color: var(--primary); font-weight: 700; margin: 0 2px; }
    .chat-monitor .cm-conv-last { font-size: 13px; color: var(--text-secondary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 2px; }
    .chat-monitor .cm-conv-time { font-size: 11px; color: var(--text-secondary); white-space: nowrap; }
    .chat-monitor .cm-more { padding: 12px 16px; text-align: center; }

    .chat-monitor .cm-avatars { position: relative; flex-shrink: 0; width: 44px; height: 38px; }
    .chat-monitor .cm-av {
        position: absolute; top: 0; width: 30px; height: 30px; border-radius: 50%;
        object-fit: cover; border: 2px solid var(--surface); display: flex; align-items: center;
        justify-content: center; font-size: 12px; font-weight: 700; background: var(--primary-soft); color: var(--primary);
    }
    .chat-monitor .cm-av-1 { left: 0; z-index: 2; }
    .chat-monitor .cm-av-2 { left: 16px; z-index: 1; }
    .chat-monitor .cm-avatars-lg { width: 64px; height: 52px; flex-shrink: 0; }
    .chat-monitor .cm-avatars-lg .cm-av { width: 40px; height: 40px; font-size: 15px; }
    .chat-monitor .cm-avatars-lg .cm-av-2 { left: 24px; }

    .chat-monitor .cm-thread { display: flex; flex-direction: column; min-height: 0; height: 100%; }
    .chat-monitor .cm-loading { padding: 20px; color: var(--text-secondary); }

    .chat-monitor .cm-header { gap: 14px; flex-wrap: wrap; }
    .chat-monitor .cm-head-info { flex: 1; min-width: 0; }
    .chat-monitor .cm-head-names { font-weight: 700; font-size: 16px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .chat-monitor .cm-head-sub { font-size: 12px; margin-top: 2px; }

    .chat-monitor .cm-persp { display: flex; align-items: center; gap: 8px; }
    .chat-monitor .cm-persp-label { font-size: 12px; }
    .chat-monitor .cm-persp-btn {
